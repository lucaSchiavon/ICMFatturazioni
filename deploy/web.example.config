<?xml version="1.0" encoding="utf-8"?>
<!--
  Template di esempio per IIS hosting di ICMFatturazioni.Web (ASP.NET Core in-process).

  USO:
    - 'dotnet publish -c Release' genera gia' un web.config base nella cartella di output.
    - Questo file serve come riferimento per VEDERE quali sezioni puoi/devi modificare:
      timeout, stdout log, variabili d'ambiente, sicurezza header.
    - In genere NON serve sostituire il web.config generato: basta editarlo per aggiungere
      le poche righe specifiche del tuo ambiente (es. <environmentVariables>).

  Verifica DOPO il publish che 'processPath' sia '.\\ICMFatturazioni.Web.exe' e che
  'hostingModel' sia 'inprocess' (default per ASP.NET Core su IIS).
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>

      <!--
        Handler che inoltra le richieste al processo dotnet. NON modificare.
      -->
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>

      <!--
        processPath / arguments: per 'dotnet publish' standard punta all'exe self-contained
        o all'app .dll. Lo genera automaticamente la publish.

        stdoutLogEnabled: METTI 'true' SOLO durante il primo deploy per diagnostica
        startup. Le righe Console.WriteLine / ILogger finiscono in 'stdoutLogFile'.
        Dopo il rodaggio rimettilo a 'false' (lo stdout log non ruota e cresce
        all'infinito).

        requestTimeout: 02:00:00 (2 ore). Per Blazor Server / SignalR non e' il timeout
        della connessione long-lived (gestito da SignalR), e' il timeout di una singola
        richiesta HTTP. Esplicitalo se la generazione dei PDF (fatture di cortesia,
        report) puo' essere lenta e vuoi un margine.

        hostingModel="inprocess" e' il default consigliato per .NET 6+.
      -->
      <aspNetCore processPath=".\ICMFatturazioni.Web.exe"
                  arguments=""
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess"
                  requestTimeout="02:00:00">
        <environmentVariables>
          <!--
            Forza l'environment di hosting. Senza, ASP.NET Core defaulta a "Production"
            ma esplicitarlo evita sorprese.
          -->
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />

          <!--
            ALTERNATIVA all'avere segreti in appsettings.Production.json: puoi passarli
            come env var qui. Doppio underscore '__' = nesting JSON.
            Es. ConnectionStrings:Default -> ConnectionStrings__Default.

            Decommenta SOLO se preferisci questo metodo (NON metterli sia qui che in
            appsettings, l'env var ha precedenza). NB: il DB e' unificato (ICMVerbaliDb,
            condiviso con ICMVerbali). La password admin DEVE rispettare la policy
            (>=10 caratteri, con maiuscola, minuscola e cifra) o il seeder non crea l'utente.
          -->
          <!--
          <environmentVariable name="ConnectionStrings__Default"
                               value="Server=tcp:CHANGE_ME_DBSRV,1433;Database=ICMVerbaliDb;User Id=CHANGE_ME_USER;Password=CHANGE_ME_PWD;Encrypt=True;TrustServerCertificate=True;" />
          <environmentVariable name="Admin__DefaultPassword"
                               value="CHANGE_ME_AL_PRIMO_AVVIO" />
          <environmentVariable name="Superadmin__Password"
                               value="CHANGE_ME_OPPURE_LASCIA_VUOTO" />
          <environmentVariable name="Smtp__Password"
                               value="CHANGE_ME_BREVO_KEY" />
          -->
        </environmentVariables>
      </aspNetCore>

      <!--
        Compressione: utile per Blazor server-rendered HTML e per asset statici.
        IIS la fa di default se i moduli Static/Dynamic Compression sono installati.
        Lascia che sia IIS a gestirla, non aggiungere middleware Response Compression
        nell'app (sarebbe doppio lavoro).
      -->

      <!--
        Security headers minimi consigliati. Non sono nel codice dell'app:
        impostali qui o tramite IIS Manager.
      -->
      <httpProtocol>
        <customHeaders>
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="X-Frame-Options" value="SAMEORIGIN" />
          <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
          <!--
            HSTS: ASP.NET Core lo emette gia' via UseHsts() in non-Development
            (vedi Program.cs:261). Se vuoi forzarlo anche da IIS:
          -->
          <!-- <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" /> -->
        </customHeaders>
      </httpProtocol>

      <!--
        Limite upload: il default IIS e' ~30 MB per richiesta. ICMFatturazioni NON
        gestisce upload di file (niente foto/firme come in ICMVerbali), quindi il
        default va piu' che bene. Volendo lo si puo' ABBASSARE per ridurre la
        superficie d'attacco aggiungendo, dentro <system.webServer>, un blocco:
          <security><requestFiltering>
            <requestLimits maxAllowedContentLength="10485760" />   (10 MB, in byte)
          </requestFiltering></security>
      -->

      <!--
        WebSocket per SignalR / Blazor Server: deve essere abilitato A LIVELLO IIS
        (Server Manager -> WebSocket Protocol). NON serve dichiararlo qui.
        Se il modulo non e' installato l'app cade automaticamente in long-polling.
      -->

    </system.webServer>
  </location>
</configuration>
