@*
    Layout principale dell'app autenticata. Ospita i provider MudBlazor
    (tema, popover, dialog, snackbar) e racchiude il @Body in un
    IcmErrorBoundary per catturare e loggare eventuali eccezioni dei
    componenti senza tirare giù il circuit.

    La gestione del tema light/dark legge la preferenza utente dal claim
    "tema_preferito" valorizzato dall'endpoint /auth/login. Il toggle
    runtime sarà introdotto con la pagina del profilo utente (Fase 3+).
*@
@using System.Security.Claims
@using ICMFatturazioni.Web.Authentication
@using ICMFatturazioni.Web.Components.Shared
@using ICMFatturazioni.Web.Managers.Interfaces
@using ICMFatturazioni.Web.Theme
@inherits LayoutComponentBase
@inject ICurrentUserAccessor CurrentUser
@inject IUtenteManager UtenteManager

<MudThemeProvider Theme="@IcmTheme.Default" IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@* La preferenza di tema (chiaro/scuro) è propagata in cascata così che anche
   il NavMenu possa adattarsi (es. variante del logo Vis Logica). *@
<CascadingValue Value="_isDarkMode" Name="IsDarkMode">
<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Inherit" Style="background-color: #1E2A3B; color: #FFFFFF;">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Ripple="false" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">ICM Fatturazioni</MudText>
        <MudSpacer />
        @* Toggle tema chiaro/scuro: mostra l'icona della modalità in cui si
           passerebbe. La scelta è persistita su fatt.Utenti (TemaPreferito). *@
        <MudTooltip Text="@(_isDarkMode ? "Passa al tema chiaro" : "Passa al tema scuro")">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit" Ripple="false"
                           OnClick="@ToggleTemaAsync"
                           aria-label="Cambia tema chiaro/scuro" />
        </MudTooltip>
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mx-4">@context.User.Identity?.Name</MudText>
                <form method="post" action="/auth/logout" style="display:inline;">
                    <AntiforgeryToken />
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Text"
                               Color="Color.Inherit"
                               Ripple="false"
                               StartIcon="@Icons.Material.Filled.Logout">
                        Esci
                    </MudButton>
                </form>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always"
               Elevation="0" Variant="DrawerVariant.Responsive">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
            <IcmErrorBoundary>
                @Body
            </IcmErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>
</CascadingValue>

<div id="blazor-error-ui" data-nosnippet>
    Si è verificato un errore non gestito.
    <a href="." class="reload">Ricarica</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private Guid? _idUtente;

    protected override async Task OnInitializedAsync()
    {
        // Preferenza tema letta dal DB (non dal claim, che è fissato al login):
        // così il toggle resta coerente anche dopo un refresh della pagina,
        // senza dover rifare il login. Fallback al tema chiaro.
        (_idUtente, _) = await CurrentUser.GetAsync();
        if (_idUtente is Guid id)
        {
            var utente = await UtenteManager.GetByIdAsync(id);
            _isDarkMode = utente?.TemaPreferito == "dark";
        }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    /// <summary>
    /// Commuta tema chiaro/scuro: aggiorna subito la UI e persiste la scelta su
    /// fatt.Utenti. La persistenza è best-effort — se fallisce, il cambio resta
    /// applicato per la sessione corrente (l'errore viene loggato a monte).
    /// </summary>
    private async Task ToggleTemaAsync()
    {
        _isDarkMode = !_isDarkMode;
        if (_idUtente is Guid id)
        {
            await UtenteManager.ImpostaTemaPreferitoAsync(id, _isDarkMode ? "dark" : "light");
        }
    }
}
