@*
    Pagina /gest-attivita-studio — Gestione attività clienti.

    Layout Access-like a tre selettori in colonna + pannello di dettaglio inline:
      [Anagrafica] [Tipo Attività] [Attività esistenti]
      [Pannello inserimento / visualizzazione / modifica testata]

    Flusso:
      1. Selezionare un cliente (col.1) → filtra per tipo (col.2) → carica attività (col.3)
      2. Clic su un'attività → visualizzazione testata nel pannello sotto
      3. "Inserisci nuova Attività" (col.2, condizionale) → form inline inserimento
      4. "Modifica testata" (pannello) → form inline modifica
*@

@page "/gest-attivita-studio"

@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Managers
@using ICMFatturazioni.Web.Managers.Interfaces
@using System.Globalization

@inject IAttivitaManager AttivitaManager
@inject IAnagraficaManager AnagraficaManager
@inject ITipoAttivitaManager TipoAttivitaManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ICMFatturazioni.Web.Managers.Interfaces.ILogManager LogManager
@inject NavigationManager Nav

<PageTitle>Gestione attività clienti · ICM Fatturazioni</PageTitle>

<MudText Typo="Typo.h1" Class="mb-4">Gestione attività clienti</MudText>

@* ═══════════════════════════════════════════════════════════════════
   Riga dei tre selettori
   ═══════════════════════════════════════════════════════════════════ *@
<MudGrid Spacing="2" Class="icm-grid-3col mb-0">

    @* ── Col 1: Anagrafica ──────────────────────────────────────── *@
    <MudItem xs="12" md="4" Style="display:flex;flex-direction:column;">
        <MudPaper Elevation="0" Outlined="true" Class="pa-3"
                  Style="display:flex;flex-direction:column;flex:1;">

            <MudText Typo="Typo.overline" Class="mb-2" Style="font-weight:700;">Anagrafica</MudText>

            @* Filtro per tipo (Enti / Società / Privati / Tutti) *@
            <MudRadioGroup T="FiltroTipo" Value="_filtroTipo" ValueChanged="OnFiltroTipoChanged" Class="mb-1">
                <MudStack Row="true" Spacing="0" Wrap="Wrap.Wrap">
                    <MudRadio T="FiltroTipo" Value="FiltroTipo.Tutti"   Dense="true" Size="Size.Small">Tutti</MudRadio>
                    <MudRadio T="FiltroTipo" Value="FiltroTipo.Enti"    Dense="true" Size="Size.Small">Enti</MudRadio>
                    <MudRadio T="FiltroTipo" Value="FiltroTipo.Societa" Dense="true" Size="Size.Small">Soc.</MudRadio>
                    <MudRadio T="FiltroTipo" Value="FiltroTipo.Privati" Dense="true" Size="Size.Small">Privati</MudRadio>
                </MudStack>
            </MudRadioGroup>

            @* Filtro testo ragione sociale *@
            <MudTextField @bind-Value="_filtroRagioneSociale"
                          Placeholder="Filtra per ragione sociale…"
                          Immediate="true" DebounceInterval="150"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Clear"
                          OnAdornmentClick="@(() => _filtroRagioneSociale = string.Empty)"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Class="mb-2" />

            @* Listbox anagrafiche *@
            <div class="icm-sellist mb-3" style="height:240px;">
                @if (_caricamentoAnagrafica)
                {
                    <div class="icm-sellist-placeholder">Caricamento…</div>
                }
                else if (!AnagraficheFiltrate.Any())
                {
                    <div class="icm-sellist-placeholder">Nessun cliente trovato.</div>
                }
                else
                {
                    @foreach (var a in AnagraficheFiltrate)
                    {
                        <div class="icm-sellist-item @(a.IdAnagrafica == _anagraficaSelezionata?.IdAnagrafica ? "selected" : "")"
                             @onclick="@(() => SelezionaAnagraficaAsync(a))">
                            <span class="icm-tipo-badge">@a.TipoAnagrafica.ToDbCode()</span>@a.RagioneSociale
                        </div>
                    }
                }
            </div>

            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.People" Ripple="false" Size="Size.Small"
                       OnClick="@(() => Nav.NavigateTo("/anagrafiche"))">
                Gestione anagrafiche
            </MudButton>
        </MudPaper>
    </MudItem>

    @* ── Col 2: Tipo Attività ─────────────────────────────────── *@
    <MudItem xs="12" md="4" Style="display:flex;flex-direction:column;">
        <MudPaper Elevation="0" Outlined="true" Class="pa-3"
                  Style="display:flex;flex-direction:column;flex:1;">

            <MudText Typo="Typo.overline" Class="mb-2" Style="font-weight:700;">Tipo Attività</MudText>

            <div class="icm-sellist mb-3" style="height:240px;">
                @if (_caricamentoTipi)
                {
                    <div class="icm-sellist-placeholder">Caricamento…</div>
                }
                else if (!_tipiAttivita.Any())
                {
                    <div class="icm-sellist-placeholder">Nessun tipo attività configurato.</div>
                }
                else
                {
                    @foreach (var t in _tipiAttivita)
                    {
                        <div class="icm-sellist-item @(t.IdTipoAttivita == _tipoSelezionato?.IdTipoAttivita ? "selected" : "")"
                             @onclick="@(() => SelezionaTipoAsync(t))">
                            @t.Descrizione
                        </div>
                    }
                }
            </div>

            @* Il bottone "Inserisci" appare solo se entrambe le selezioni sono attive *@
            @if (_anagraficaSelezionata is not null && _tipoSelezionato is not null)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Add" Ripple="false" Size="Size.Small"
                           OnClick="AvviaInserimento">
                    Inserisci nuova Attività
                </MudButton>
            }
        </MudPaper>
    </MudItem>

    @* ── Col 3: Attività esistenti ────────────────────────────── *@
    <MudItem xs="12" md="4" Style="display:flex;flex-direction:column;">
        <MudPaper Elevation="0" Outlined="true" Class="pa-3"
                  Style="display:flex;flex-direction:column;flex:1;">

            <MudText Typo="Typo.overline" Class="mb-2" Style="font-weight:700;">Attività esistenti</MudText>

            <div class="icm-sellist" style="height:240px;">
                @if (_anagraficaSelezionata is null || _tipoSelezionato is null)
                {
                    <div class="icm-sellist-placeholder">Selezionare un cliente e un tipo.</div>
                }
                else if (_caricamentoAttivita)
                {
                    <div class="icm-sellist-placeholder">Caricamento…</div>
                }
                else if (!_attivitaLista.Any())
                {
                    <div class="icm-sellist-placeholder">Nessuna attività per questa selezione.</div>
                }
                else
                {
                    @foreach (var a in _attivitaLista)
                    {
                        <div class="icm-sellist-item icm-sellist-item-2col @(a.IdAttivita == _attivitaSelezionata?.IdAttivita ? "selected" : "")"
                             @onclick="@(() => SelezionaAttivitaAsync(a))">
                            <span class="icm-nr">@a.Numero</span>
                            <span class="icm-desc">@a.Descrizione</span>
                        </div>
                    }
                }
            </div>
        </MudPaper>
    </MudItem>

</MudGrid>

@* ═══════════════════════════════════════════════════════════════════
   Pannello condizionale — inserimento / visualizzazione / modifica
   ═══════════════════════════════════════════════════════════════════ *@
@if (_modalita != Modalita.Nessuna)
{
    <MudPaper Elevation="0" Outlined="true" Class="pa-4 mt-3">

        @* ── Form Inserimento / Modifica testata ─────────────────── *@
        @if (_modalita is Modalita.Inserimento or Modalita.Modifica)
        {
            <MudText Typo="Typo.overline" Class="mb-3" Style="font-weight:700;">
                @(_modalita == Modalita.Inserimento
                    ? "Nuova attività"
                    : $"Modifica testata — Nr. {_attivitaSelezionata?.Numero}")
            </MudText>

            <MudForm @ref="_form" @bind-IsValid="_formValido">
                <MudGrid Spacing="2">

                    <MudItem xs="12" sm="3" md="2">
                        <MudNumericField T="int" @bind-Value="_fNumero"
                                         Label="Numero *"
                                         Required="true" RequiredError="Il numero è obbligatorio"
                                         Min="1" HideSpinButtons="true"
                                         Variant="Variant.Outlined" Margin="Margin.Dense"
                                         Class="campo-obbligatorio" Immediate="true" />
                    </MudItem>

                    <MudItem xs="12" sm="9" md="10">
                        <MudTextField @bind-Value="_fDescr"
                                      Label="Descrizione *"
                                      Required="true" RequiredError="La descrizione è obbligatoria"
                                      MaxLength="200"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Class="campo-obbligatorio" Immediate="true" />
                    </MudItem>

                    <MudItem xs="12" sm="4">
                        <MudDatePicker Label="Progetto definitivo"
                                       @bind-Date="_fProgettoDefinitivo"
                                       DateFormat="dd/MM/yyyy"
                                       Variant="Variant.Outlined" Margin="Margin.Dense"
                                       Editable="true" Culture="@_itCulture" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Label="Concessione edilizia"
                                       @bind-Date="_fConcessioneEdilizia"
                                       DateFormat="dd/MM/yyyy"
                                       Variant="Variant.Outlined" Margin="Margin.Dense"
                                       Editable="true" Culture="@_itCulture" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Label="Inizio lavori"
                                       @bind-Date="_fInizioLavori"
                                       DateFormat="dd/MM/yyyy"
                                       Variant="Variant.Outlined" Margin="Margin.Dense"
                                       Editable="true" Culture="@_itCulture" />
                    </MudItem>

                    <MudItem xs="12" sm="4">
                        <MudNumericField T="decimal?" @bind-Value="_fImportoOpera"
                                         Label="Importo opera (€)"
                                         Format="N2" Culture="@_itCulture" Min="0"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>

                </MudGrid>

                @if (!string.IsNullOrEmpty(_erroreForm))
                {
                    <MudAlert Severity="MudBlazor.Severity.Error" Dense="true" Class="mt-3">@_erroreForm</MudAlert>
                }
            </MudForm>

            <MudStack Row="true" Class="mt-3" Spacing="2" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Text" Ripple="false" OnClick="AnnullaForm">
                    Esci senza salvare
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Ripple="false"
                           Disabled="@_salvataggio" OnClick="SalvaAsync">
                    @(_salvataggio ? "Salvataggio…" : "Salva")
                </MudButton>
            </MudStack>
        }

        @* ── Visualizzazione testata ──────────────────────────────── *@
        @if (_modalita == Modalita.Visualizzazione && _attivitaSelezionata is not null)
        {
            @* Intestazione: Nr + Descrizione *@
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="3" sm="2" md="1">
                    <div class="icm-field-label">Nr.</div>
                    <div class="icm-field-value" style="font-size:1.4rem;font-weight:700;color:var(--mud-palette-primary);">
                        @_attivitaSelezionata.Numero
                    </div>
                </MudItem>
                <MudItem xs="9" sm="10" md="11">
                    <div class="icm-field-label">Descrizione</div>
                    <div class="icm-field-value" style="font-size:1.05rem;">@_attivitaSelezionata.Descrizione</div>
                </MudItem>
            </MudGrid>

            @* Campi date e importo *@
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="6" sm="3">
                    <div class="icm-field-label">Progetto definitivo</div>
                    <div class="icm-field-value">@FormatoData(_attivitaSelezionata.ProgettoDefinitivo)</div>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <div class="icm-field-label">Concessione edilizia</div>
                    <div class="icm-field-value">@FormatoData(_attivitaSelezionata.ConcessioneEdilizia)</div>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <div class="icm-field-label">Inizio lavori</div>
                    <div class="icm-field-value">@FormatoData(_attivitaSelezionata.InizioLavori)</div>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <div class="icm-field-label">Importo opera</div>
                    <div class="icm-field-value">
                        @if (_attivitaSelezionata.ImportoOpera.HasValue)
                        {
                            @($"{_attivitaSelezionata.ImportoOpera.Value.ToString("N2", _itCulture)} €")
                        }
                        else
                        {
                            <span style="color:var(--mud-palette-text-secondary);">—</span>
                        }
                    </div>
                </MudItem>
            </MudGrid>

            @* Pulsanti azione testata *@
            <MudDivider Class="mb-3" />
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" Class="mb-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Ripple="false"
                           StartIcon="@Icons.Material.Filled.Edit"
                           OnClick="AvviaModifica">
                    Modifica testata
                </MudButton>

                @if (_attivitaSelezionataEliminabile)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Ripple="false"
                               StartIcon="@Icons.Material.Filled.Delete"
                               OnClick="@(() => ConfermaEdEliminaAsync(_attivitaSelezionata))">
                        Elimina
                    </MudButton>
                }
            </MudStack>

            @* Placeholder sezione dettagli (da sviluppare in Tappa 9) *@
            <MudDivider Class="mt-4 mb-2" />
            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                Dettagli attività — in sviluppo (Tappa 9)
            </MudText>
        }

    </MudPaper>
}

@code {
    // ─── Enum interni ────────────────────────────────────────────────────
    private enum Modalita { Nessuna, Inserimento, Visualizzazione, Modifica }

    private enum FiltroTipo { Tutti, Enti, Societa, Privati }

    // ─── Cultura ─────────────────────────────────────────────────────────
    private static readonly CultureInfo _itCulture = CultureInfo.GetCultureInfo("it-IT");

    // ─── Dati caricati ───────────────────────────────────────────────────
    private IReadOnlyList<Anagrafica>   _anagrafiche   = Array.Empty<Anagrafica>();
    private IReadOnlyList<TipoAttivita> _tipiAttivita  = Array.Empty<TipoAttivita>();
    private IReadOnlyList<Attivita>     _attivitaLista = Array.Empty<Attivita>();

    // ─── Selezioni correnti ──────────────────────────────────────────────
    private Anagrafica?   _anagraficaSelezionata;
    private TipoAttivita? _tipoSelezionato;
    private Attivita?     _attivitaSelezionata;
    private bool          _attivitaSelezionataEliminabile;

    // ─── Stato caricamento ───────────────────────────────────────────────
    private bool _caricamentoAnagrafica = true;
    private bool _caricamentoTipi       = true;
    private bool _caricamentoAttivita   = false;

    // ─── Filtro anagrafiche ──────────────────────────────────────────────
    private FiltroTipo _filtroTipo           = FiltroTipo.Tutti;
    private string     _filtroRagioneSociale = string.Empty;

    // ─── Pannello inferiore ──────────────────────────────────────────────
    private Modalita _modalita = Modalita.Nessuna;

    // Campi del form inline
    private MudForm? _form;
    private bool     _formValido;
    private bool     _salvataggio;
    private string   _erroreForm          = string.Empty;
    private int      _fNumero;
    private string   _fDescr              = string.Empty;
    private DateTime? _fProgettoDefinitivo;
    private DateTime? _fConcessioneEdilizia;
    private DateTime? _fInizioLavori;
    private decimal?  _fImportoOpera;

    // ─── Computed: anagrafiche filtrate ─────────────────────────────────
    private IEnumerable<Anagrafica> AnagraficheFiltrate
    {
        get
        {
            var q = _anagrafiche.AsEnumerable();
            q = _filtroTipo switch
            {
                FiltroTipo.Enti    => q.Where(a => a.TipoAnagrafica == TipoAnagrafica.EntePubblico),
                FiltroTipo.Societa => q.Where(a => a.TipoAnagrafica == TipoAnagrafica.Societa),
                FiltroTipo.Privati => q.Where(a => a.TipoAnagrafica == TipoAnagrafica.Privato),
                _                 => q,
            };
            if (!string.IsNullOrWhiteSpace(_filtroRagioneSociale))
                q = q.Where(a => a.RagioneSociale.Contains(
                    _filtroRagioneSociale.Trim(), StringComparison.OrdinalIgnoreCase));
            return q;
        }
    }

    // ─── Inizializzazione ────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var t1 = AnagraficaManager.ElencoAsync();
        var t2 = TipoAttivitaManager.ElencoAsync();
        await Task.WhenAll(t1, t2);
        _anagrafiche  = t1.Result;
        _tipiAttivita = t2.Result;
        _caricamentoAnagrafica = false;
        _caricamentoTipi       = false;
    }

    // ─── Selezione anagrafica ────────────────────────────────────────────
    private async Task SelezionaAnagraficaAsync(Anagrafica a)
    {
        if (_anagraficaSelezionata?.IdAnagrafica == a.IdAnagrafica) return;
        _anagraficaSelezionata = a;
        // Reset a valle: cambiare cliente azzera tipo, attività, pannello.
        _tipoSelezionato                = null;
        _attivitaSelezionata            = null;
        _attivitaSelezionataEliminabile = false;
        _modalita                       = Modalita.Nessuna;
        _attivitaLista                  = Array.Empty<Attivita>();
    }

    // ─── Selezione tipo attività ─────────────────────────────────────────
    private async Task SelezionaTipoAsync(TipoAttivita t)
    {
        if (_tipoSelezionato?.IdTipoAttivita == t.IdTipoAttivita) return;
        _tipoSelezionato                = t;
        _attivitaSelezionata            = null;
        _attivitaSelezionataEliminabile = false;
        _modalita                       = Modalita.Nessuna;
        // Se anche l'anagrafica è selezionata, carica subito le attività.
        if (_anagraficaSelezionata is not null)
            await CaricaAttivitaAsync();
        else
            _attivitaLista = Array.Empty<Attivita>();
    }

    // ─── Carica lista attività per la combo corrente ─────────────────────
    private async Task CaricaAttivitaAsync()
    {
        if (_anagraficaSelezionata is null || _tipoSelezionato is null) return;
        _caricamentoAttivita = true;
        try
        {
            _attivitaLista = await AttivitaManager.ElencoPerAnagraficaTipoAsync(
                _anagraficaSelezionata.IdAnagrafica,
                _tipoSelezionato.IdTipoAttivita);
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex,
                "Caricamento attività fallito.", "GestAttivitaStudio.CaricaAttivitaAsync");
            Snackbar.Add("Errore nel caricamento delle attività.", MudBlazor.Severity.Error);
        }
        finally { _caricamentoAttivita = false; }
    }

    // ─── Selezione attività esistente ────────────────────────────────────
    private async Task SelezionaAttivitaAsync(Attivita a)
    {
        _attivitaSelezionata            = a;
        _attivitaSelezionataEliminabile = await AttivitaManager.EEliminabileAsync(a.IdAttivita);
        _modalita                       = Modalita.Visualizzazione;
        _erroreForm                     = string.Empty;
    }

    // ─── Filtro tipo anagrafica con reset selezione se necessario ────────
    private void OnFiltroTipoChanged(FiltroTipo nuovo)
    {
        _filtroTipo = nuovo;
        // Se l'anagrafica selezionata non è più visibile nel nuovo filtro, deselezionala.
        if (_anagraficaSelezionata is not null
            && !AnagraficheFiltrate.Any(a => a.IdAnagrafica == _anagraficaSelezionata.IdAnagrafica))
        {
            _anagraficaSelezionata          = null;
            _tipoSelezionato                = null;
            _attivitaSelezionata            = null;
            _attivitaSelezionataEliminabile = false;
            _attivitaLista                  = Array.Empty<Attivita>();
            _modalita                       = Modalita.Nessuna;
        }
    }

    // ─── Avvia inserimento nuova attività ────────────────────────────────
    private void AvviaInserimento()
    {
        _attivitaSelezionata            = null;
        _attivitaSelezionataEliminabile = false;
        ResetForm();
        _modalita = Modalita.Inserimento;
    }

    // ─── Avvia modifica testata dell'attività selezionata ────────────────
    private void AvviaModifica()
    {
        if (_attivitaSelezionata is null) return;
        PopolaFormDa(_attivitaSelezionata);
        _modalita = Modalita.Modifica;
    }

    // ─── Annulla e torna allo stato precedente ───────────────────────────
    private void AnnullaForm()
    {
        _erroreForm = string.Empty;
        _modalita   = _attivitaSelezionata is not null
            ? Modalita.Visualizzazione
            : Modalita.Nessuna;
    }

    // ─── Salva (inserimento o modifica) ──────────────────────────────────
    private async Task SalvaAsync()
    {
        if (_form is not null) await _form.ValidateAsync();
        if (!_formValido) return;
        if (_anagraficaSelezionata is null || _tipoSelezionato is null) return;

        _salvataggio = true;
        _erroreForm  = string.Empty;
        try
        {
            var entita = new Attivita
            {
                IdAttivita          = _modalita == Modalita.Modifica ? _attivitaSelezionata!.IdAttivita : Guid.Empty,
                IdAnagrafica        = _anagraficaSelezionata.IdAnagrafica,
                IdTipoAttivita      = _tipoSelezionato.IdTipoAttivita,
                Numero              = _fNumero,
                Descrizione         = _fDescr,
                ProgettoDefinitivo  = ToDateOnly(_fProgettoDefinitivo),
                ConcessioneEdilizia = ToDateOnly(_fConcessioneEdilizia),
                InizioLavori        = ToDateOnly(_fInizioLavori),
                ImportoOpera        = _fImportoOpera,
            };

            Guid idSalvata;
            if (_modalita == Modalita.Inserimento)
            {
                idSalvata = await AttivitaManager.CreaAsync(entita);
                Snackbar.Add("Attività creata.", MudBlazor.Severity.Success);
            }
            else
            {
                await AttivitaManager.AggiornaAsync(entita);
                idSalvata = entita.IdAttivita;
                Snackbar.Add("Attività aggiornata.", MudBlazor.Severity.Success);
            }

            // Ricarica la lista e ri-seleziona l'attività appena salvata.
            await CaricaAttivitaAsync();
            _attivitaSelezionata = _attivitaLista.FirstOrDefault(a => a.IdAttivita == idSalvata);
            _attivitaSelezionataEliminabile = _attivitaSelezionata is not null
                && await AttivitaManager.EEliminabileAsync(idSalvata);
            _modalita = Modalita.Visualizzazione;
        }
        catch (AttivitaInvalidaException ex)
        {
            _erroreForm = ex.Message;
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex,
                "Salvataggio attività fallito.", "GestAttivitaStudio.SalvaAsync");
            _erroreForm = "Errore inatteso durante il salvataggio.";
        }
        finally { _salvataggio = false; }
    }

    // ─── Elimina con conferma ────────────────────────────────────────────
    private async Task ConfermaEdEliminaAsync(Attivita? a)
    {
        if (a is null) return;
        var p = new DialogParameters<ConfermaEliminazioneDialog>
        {
            { x => x.Titolo, "Eliminare attività?" },
            { x => x.NomeElemento, $"Nr.{a.Numero} – {a.Descrizione}" },
            { x => x.Messaggio, "L'attività verrà disattivata e non comparirà più nell'elenco." },
        };
        var o = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseOnEscapeKey = true };
        var d = await DialogService.ShowAsync<ConfermaEliminazioneDialog>(string.Empty, p, o);
        if (await d.Result is not { Canceled: false }) return;

        try
        {
            await AttivitaManager.EliminaAsync(a.IdAttivita);
            Snackbar.Add("Attività eliminata.", MudBlazor.Severity.Success);
            _attivitaSelezionata            = null;
            _attivitaSelezionataEliminabile = false;
            _modalita                       = Modalita.Nessuna;
            await CaricaAttivitaAsync();
        }
        catch (AttivitaConDipendenzeException)
        {
            Snackbar.Add("Impossibile eliminare: l'attività ha dettagli collegati.", MudBlazor.Severity.Warning);
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex,
                "Eliminazione attività fallita.", "GestAttivitaStudio.ConfermaEdEliminaAsync");
            Snackbar.Add("Errore durante l'eliminazione.", MudBlazor.Severity.Error);
        }
    }

    // ─── Helpers ─────────────────────────────────────────────────────────
    private static DateOnly? ToDateOnly(DateTime? dt)
        => dt.HasValue ? DateOnly.FromDateTime(dt.Value) : null;

    private static string FormatoData(DateOnly? d)
        => d.HasValue ? d.Value.ToString("dd/MM/yyyy") : "—";

    private void ResetForm()
    {
        _fNumero              = 0;
        _fDescr               = string.Empty;
        _fProgettoDefinitivo  = null;
        _fConcessioneEdilizia = null;
        _fInizioLavori        = null;
        _fImportoOpera        = null;
        _erroreForm           = string.Empty;
    }

    private void PopolaFormDa(Attivita a)
    {
        _fNumero              = a.Numero;
        _fDescr               = a.Descrizione;
        _fProgettoDefinitivo  = a.ProgettoDefinitivo?.ToDateTime(TimeOnly.MinValue);
        _fConcessioneEdilizia = a.ConcessioneEdilizia?.ToDateTime(TimeOnly.MinValue);
        _fInizioLavori        = a.InizioLavori?.ToDateTime(TimeOnly.MinValue);
        _fImportoOpera        = a.ImportoOpera;
        _erroreForm           = string.Empty;
    }
}
