@*
    Pagina /admin/dati-azienda — "Dati azienda" (gruppo Amministrazione).

    Maschera SINGLETON di configurazione del cedente: NON è un CRUD con lista, è
    un unico form che mostra l'unico record attivo di fatt.Azienda e permette di
    modificarne i dati da interfaccia (invece che a mano nella tabella).

      • Al caricamento legge il cedente attivo; se non esiste, il form parte vuoto.
      • La riga a DB viene creata solo al PRIMO salvataggio (creazione pigra).
      • Salva persiste (get-or-create + audit); l'utente resta in pagina.
    Validazioni di formato riusate da AnagraficaValidator (P.IVA, CF, CAP, email, PEC).
*@

@page "/admin/dati-azienda"
@attribute [Authorize(Policy = ICMFatturazioni.Web.Authentication.AuthorizationPolicies.RequireAdmin)]

@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Managers
@using ICMFatturazioni.Web.Models
@using ICMFatturazioni.Web.Repositories.Interfaces
@using ICMFatturazioni.Web.Validation

@inject IAziendaManager AziendaManager
@inject ILookupRepository LookupRepository
@inject ISnackbar Snackbar
@inject ICMFatturazioni.Web.Managers.Interfaces.ILogManager LogManager

<PageTitle>Dati azienda · ICM Fatturazioni</PageTitle>

<MudText Typo="Typo.h1" Class="mb-2">Dati azienda</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--mud-palette-text-secondary);">
    Dati del cedente usati nell'intestazione dei documenti e nella fatturazione elettronica.
    C'è un solo record: qui lo si configura e perfeziona senza modificare la tabella a mano.
</MudText>

@if (_caricamento)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-6" />
}
else
{
    <MudForm @ref="_form" Model="_model" @bind-IsValid="_isValid">

        @* ── Identità ──────────────────────────────────────────────── *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Identità</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.NomeBreve" Label="Nome breve (alias interno) *"
                                  Required="true" RequiredError="Il nome breve è obbligatorio"
                                  MaxLength="50" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Class="campo-obbligatorio" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.RagioneSociale" Label="Ragione sociale *"
                                  Required="true" RequiredError="La ragione sociale è obbligatoria"
                                  MaxLength="100" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Class="campo-obbligatorio" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.PIVA" Label="Partita IVA"
                                  MaxLength="11" Validation="_validaPiva" Immediate="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.CodiceFiscale" Label="Codice fiscale"
                                  MaxLength="16" Validation="_validaCf" Immediate="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* ── Sede legale ───────────────────────────────────────────── *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Sede legale</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="_model.IndirizzoVia" Label="Via / Indirizzo"
                                  MaxLength="100" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_model.IndirizzoCivico" Label="Civico"
                                  MaxLength="10" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.IndirizzoComune" Label="Comune"
                                  MaxLength="100" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudSelect T="string" Label="Provincia" @bind-Value="_model.IndirizzoProvincia"
                               Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var p in _province)
                        {
                            <MudSelectItem Value="@p.Codice">@p.Codice — @p.Descrizione</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudTextField @bind-Value="_model.IndirizzoCAP" Label="CAP"
                                  MaxLength="5" Validation="_validaCap" Immediate="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" Label="Paese" @bind-Value="_model.IndirizzoPaese"
                               Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var p in _paesi)
                        {
                            <MudSelectItem Value="@p.Codice">@p.Codice — @p.Descrizione</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* ── Recapiti ──────────────────────────────────────────────── *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Recapiti</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Telefono" Label="Telefono"
                                  MaxLength="50" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Telefax" Label="Fax"
                                  MaxLength="50" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Email" Label="Email"
                                  InputType="InputType.Email" MaxLength="100"
                                  Validation="_validaEmail" Immediate="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.PEC" Label="PEC"
                                  InputType="InputType.Email" MaxLength="100"
                                  Validation="_validaPec" Immediate="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* ── Dati Fattura Elettronica ──────────────────────────────── *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">Dati Fattura Elettronica</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Regime fiscale" @bind-Value="_model.RegimeFiscale"
                               Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                               HelperText="Codice AdE che finisce nel tracciato XML">
                        @foreach (var r in RegimiFiscali)
                        {
                            <MudSelectItem Value="@r.Codice">@r.Codice — @r.Descrizione</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Identificativo" Label="Identificativo fiscale (estero)"
                                  MaxLength="10" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.REA" Label="Numero REA"
                                  MaxLength="50" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.CCIAA" Label="CCIAA (provincia REA)"
                                  MaxLength="2" Validation="_validaSiglaProvincia" Immediate="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  HelperText="Sigla provincia dell'ufficio del registro imprese (es. VR)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.CapitaleSociale" Label="Capitale sociale"
                                  MaxLength="50" Validation="_validaImporto" Immediate="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  HelperText="Importo numerico, es. 20000.00" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudSelect T="string" Label="Stato liquidazione" @bind-Value="_model.StatoLiquidazione"
                               Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("LN")">LN — Non in liquidazione</MudSelectItem>
                        <MudSelectItem Value="@("LS")">LS — In liquidazione</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudSelect T="string" Label="Socio unico" @bind-Value="_model.SocioUnico"
                               Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@("SU")">SU — Socio unico</MudSelectItem>
                        <MudSelectItem Value="@("SM")">SM — Più soci</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* ── Profilo fiscale (cassa previdenziale / ritenuta) ──────── *@
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-1">Profilo fiscale del cedente</MudText>
            <MudText Typo="Typo.caption" Class="mb-3" Style="color:var(--mud-palette-text-secondary);">
                Da attivare solo per professionisti iscritti a cassa / soggetti a ritenuta.
                Una S.r.l. commerciale ha entrambi disattivati.
            </MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudSwitch T="bool" @bind-Value="_model.ApplicaCassaPrevidenziale"
                               Color="Color.Primary" Label="Applica cassa previdenziale" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_model.TipoCassaFe" Label="Tipo cassa (codice FE)"
                               Clearable="true" Disabled="@(!_model.ApplicaCassaPrevidenziale)"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var t in _tipiCassa)
                        {
                            <MudSelectItem Value="@t.Codice">@t.Codice — @t.Descrizione</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSwitch T="bool" @bind-Value="_model.SoggettoARitenuta"
                               Color="Color.Primary" Label="Soggetto a ritenuta d'acconto" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="string" @bind-Value="_model.TipoRitenutaFe" Label="Tipo ritenuta (codice FE)"
                               Clearable="true" Disabled="@(!_model.SoggettoARitenuta)"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var t in _tipiRitenuta)
                        {
                            <MudSelectItem Value="@t.Codice">@t.Codice — @t.Descrizione</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="string" @bind-Value="_model.CausalePagamentoRitenutaFe" Label="Causale pagamento"
                               Clearable="true" Disabled="@(!_model.SoggettoARitenuta)"
                               Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var c in _causaliPagamento)
                        {
                            <MudSelectItem Value="@c.Codice">@c.Codice — @c.Descrizione</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (!string.IsNullOrEmpty(_erroreServer))
        {
            <MudAlert Severity="MudBlazor.Severity.Error" Class="mb-3" Variant="Variant.Outlined">
                @_erroreServer
            </MudAlert>
        }

        <div class="d-flex justify-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Ripple="false"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="Salva" Disabled="@(!_isValid || _salvataggio)">
                @if (_salvataggio)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                }
                Salva
            </MudButton>
        </div>
    </MudForm>
}

@code {
    private sealed record CodiceDescrizione(string Codice, string Descrizione);

    private MudForm _form = default!;
    private FormModel _model = new();
    private bool _isValid;
    private bool _caricamento = true;
    private bool _salvataggio;
    private string? _erroreServer;

    private IReadOnlyList<LookupItem> _paesi = Array.Empty<LookupItem>();
    private IReadOnlyList<LookupItem> _province = Array.Empty<LookupItem>();
    private IReadOnlyList<LookupItem> _tipiCassa = Array.Empty<LookupItem>();
    private IReadOnlyList<LookupItem> _tipiRitenuta = Array.Empty<LookupItem>();
    private IReadOnlyList<LookupItem> _causaliPagamento = Array.Empty<LookupItem>();

    // Validatori di formato (feedback immediato + Salva bloccato se invalido).
    private readonly Func<string?, string?> _validaPiva  = AnagraficaValidator.ValidaPartitaIva;
    private readonly Func<string?, string?> _validaCf    = AnagraficaValidator.ValidaCodiceFiscaleAzienda;
    private readonly Func<string?, string?> _validaCap   = AnagraficaValidator.ValidaCap;
    private readonly Func<string?, string?> _validaEmail = AnagraficaValidator.ValidaEmail;
    private readonly Func<string?, string?> _validaPec   = AnagraficaValidator.ValidaPec;
    private readonly Func<string?, string?> _validaImporto = ValidaImporto;
    private readonly Func<string?, string?> _validaSiglaProvincia = ValidaSiglaProvincia;

    // Capitale sociale: importo numerico (va nell'XML come decimal, cultura invariante).
    private static string? ValidaImporto(string? v)
        => string.IsNullOrWhiteSpace(v)
           || decimal.TryParse(v.Trim(), System.Globalization.NumberStyles.Any,
                               System.Globalization.CultureInfo.InvariantCulture, out _)
            ? null
            : "Importo non valido (usa il punto come separatore decimale, es. 20000.00).";

    // Sigla provincia (CCIAA): 2 lettere.
    private static string? ValidaSiglaProvincia(string? v)
        => string.IsNullOrWhiteSpace(v)
           || System.Text.RegularExpressions.Regex.IsMatch(v.Trim(), "^[A-Za-z]{2}$")
            ? null
            : "La sigla provincia deve essere di 2 lettere (es. VR).";

    // Regimi fiscali AdE (RF01–RF19; RF03 non esiste nella codelist).
    private static readonly CodiceDescrizione[] RegimiFiscali =
    [
        new("RF01", "Ordinario"),
        new("RF02", "Contribuenti minimi"),
        new("RF04", "Agricoltura e attività connesse e pesca"),
        new("RF05", "Vendita sali e tabacchi"),
        new("RF06", "Commercio dei fiammiferi"),
        new("RF07", "Editoria"),
        new("RF08", "Gestione servizi di telefonia pubblica"),
        new("RF09", "Rivendita documenti di trasporto e sosta"),
        new("RF10", "Intrattenimenti e giochi"),
        new("RF11", "Agenzie viaggi e turismo"),
        new("RF12", "Agriturismo"),
        new("RF13", "Vendite a domicilio"),
        new("RF14", "Rivendita beni usati, oggetti d'arte/antiquariato"),
        new("RF15", "Agenzie vendite all'asta di oggetti d'arte"),
        new("RF16", "IVA per cassa P.A."),
        new("RF17", "IVA per cassa (art. 32-bis DL 83/2012)"),
        new("RF18", "Altro"),
        new("RF19", "Regime forfettario"),
    ];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var paesiTask = LookupRepository.GetPaesiAsync();
            var provinceTask = LookupRepository.GetProvinceAsync();
            var cassaTask = LookupRepository.GetTipiCassaAsync();
            var ritenutaTask = LookupRepository.GetTipiRitenutaAsync();
            var causaliTask = LookupRepository.GetCausaliPagamentoAsync();
            var aziendaTask = AziendaManager.GetAziendaAsync();
            await Task.WhenAll(paesiTask, provinceTask, cassaTask, ritenutaTask, causaliTask, aziendaTask);
            _paesi = paesiTask.Result;
            _province = provinceTask.Result;
            _tipiCassa = cassaTask.Result;
            _tipiRitenuta = ritenutaTask.Result;
            _causaliPagamento = causaliTask.Result;

            var azienda = aziendaTask.Result;
            _model = azienda is null ? new FormModel() : FormModel.FromEntity(azienda);
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex,
                "Caricamento della maschera Dati azienda fallito.", "DatiAzienda.OnInitializedAsync");
            Snackbar.Add("Errore nel caricamento dei dati azienda.", MudBlazor.Severity.Error);
        }
        finally
        {
            _caricamento = false;
        }
    }

    private async Task Salva()
    {
        _erroreServer = null;
        await _form.ValidateAsync();
        if (!_isValid)
        {
            return;
        }

        _salvataggio = true;
        try
        {
            await AziendaManager.SalvaCedenteAsync(_model.ToEntity());
            Snackbar.Add("Dati azienda salvati.", MudBlazor.Severity.Success);

            // Ricarica per riflettere la normalizzazione lato manager (trim, ecc.).
            var aggiornata = await AziendaManager.GetAziendaAsync();
            if (aggiornata is not null)
            {
                _model = FormModel.FromEntity(aggiornata);
            }
        }
        catch (AziendaInvalidaException ex)
        {
            // Validazione tipizzata → messaggio pronto, non si logga (Regola 6).
            _erroreServer = ex.Message;
        }
        catch (Exception ex)
        {
            _erroreServer = "Errore durante il salvataggio. Riprovare o contattare l'amministratore.";
            await LogManager.LogErroreAsync(ex,
                "Salvataggio dei dati azienda fallito per un errore imprevisto.", "DatiAzienda.Salva");
        }
        finally
        {
            _salvataggio = false;
        }
    }

    /// <summary>View-model mutabile (l'entità Azienda ha proprietà init-only).</summary>
    private sealed class FormModel
    {
        public string? NomeBreve { get; set; }
        public string? RagioneSociale { get; set; }
        public string? PIVA { get; set; }
        public string? CodiceFiscale { get; set; }
        public string? IndirizzoVia { get; set; }
        public string? IndirizzoCivico { get; set; }
        public string? IndirizzoComune { get; set; }
        public string? IndirizzoProvincia { get; set; }
        public string? IndirizzoCAP { get; set; }
        public string? IndirizzoPaese { get; set; }
        public string? Telefono { get; set; }
        public string? Telefax { get; set; }
        public string? Email { get; set; }
        public string? PEC { get; set; }
        public string? REA { get; set; }
        public string? CCIAA { get; set; }
        public string? CapitaleSociale { get; set; }
        // Varianti "Fe" non esposte nel form ma preservate nel round-trip per non
        // azzerarle al salvataggio (non usate oggi dal servizio XML).
        public string? REAFe { get; set; }
        public string? CCIAAFe { get; set; }
        public string? CapitaleSocialeFe { get; set; }
        public string? RegimeFiscale { get; set; }
        public string? StatoLiquidazione { get; set; }
        public string? SocioUnico { get; set; }
        public string? Identificativo { get; set; }
        public bool ApplicaCassaPrevidenziale { get; set; }
        public string? TipoCassaFe { get; set; }
        public bool SoggettoARitenuta { get; set; }
        public string? TipoRitenutaFe { get; set; }
        public string? CausalePagamentoRitenutaFe { get; set; }

        public static FormModel FromEntity(Azienda a) => new()
        {
            NomeBreve                  = a.NomeBreve,
            RagioneSociale             = a.RagioneSociale,
            PIVA                       = a.PIVA,
            CodiceFiscale              = a.CodiceFiscale,
            IndirizzoVia               = a.IndirizzoVia,
            IndirizzoCivico            = a.IndirizzoCivico,
            IndirizzoComune            = a.IndirizzoComune,
            IndirizzoProvincia         = a.IndirizzoProvincia,
            IndirizzoCAP               = a.IndirizzoCAP,
            IndirizzoPaese             = a.IndirizzoPaese,
            Telefono                   = a.Telefono,
            Telefax                    = a.Telefax,
            Email                      = a.Email,
            PEC                        = a.PEC,
            REA                        = a.REA,
            CCIAA                      = a.CCIAA,
            CapitaleSociale            = a.CapitaleSociale,
            REAFe                      = a.REAFe,
            CCIAAFe                    = a.CCIAAFe,
            CapitaleSocialeFe          = a.CapitaleSocialeFe,
            RegimeFiscale              = a.RegimeFiscale,
            StatoLiquidazione          = a.StatoLiquidazione,
            SocioUnico                 = a.SocioUnico,
            Identificativo             = a.Identificativo,
            ApplicaCassaPrevidenziale  = a.ApplicaCassaPrevidenziale,
            TipoCassaFe                = a.TipoCassaFe,
            SoggettoARitenuta          = a.SoggettoARitenuta,
            TipoRitenutaFe             = a.TipoRitenutaFe,
            CausalePagamentoRitenutaFe = a.CausalePagamentoRitenutaFe,
        };

        // NomeBreve/RagioneSociale sono NOT NULL a DB: qui sono garantiti non-vuoti
        // dalla validazione Required del form; il ?? "" è una rete di sicurezza.
        public Azienda ToEntity() => new()
        {
            IdAzienda                  = Guid.Empty,   // risolto dal manager (nuova vs esistente)
            NomeBreve                  = NomeBreve ?? string.Empty,
            RagioneSociale             = RagioneSociale ?? string.Empty,
            PIVA                       = PIVA,
            CodiceFiscale              = CodiceFiscale,
            IndirizzoVia               = IndirizzoVia,
            IndirizzoCivico            = IndirizzoCivico,
            IndirizzoComune            = IndirizzoComune,
            IndirizzoProvincia         = IndirizzoProvincia,
            IndirizzoCAP               = IndirizzoCAP,
            IndirizzoPaese             = IndirizzoPaese,
            Telefono                   = Telefono,
            Telefax                    = Telefax,
            Email                      = Email,
            PEC                        = PEC,
            REA                        = REA,
            CCIAA                      = CCIAA,
            CapitaleSociale            = CapitaleSociale,
            REAFe                      = REAFe,
            CCIAAFe                    = CCIAAFe,
            CapitaleSocialeFe          = CapitaleSocialeFe,
            RegimeFiscale              = RegimeFiscale,
            StatoLiquidazione          = StatoLiquidazione,
            SocioUnico                 = SocioUnico,
            Identificativo             = Identificativo,
            ApplicaCassaPrevidenziale  = ApplicaCassaPrevidenziale,
            TipoCassaFe                = TipoCassaFe,
            SoggettoARitenuta          = SoggettoARitenuta,
            TipoRitenutaFe             = TipoRitenutaFe,
            CausalePagamentoRitenutaFe = CausalePagamentoRitenutaFe,
        };
    }
}
