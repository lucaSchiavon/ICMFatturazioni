@*
    Pagina /admin/audit — consultazione dell'audit "chi-ha-fatto-cosa" (fatt.Audit).

    Accesso: policy RequireAdmin (Admin + Superadmin). La voce di menu sta nel
    gruppo Amministrazione (SoloAdmin).
*@
@page "/admin/audit"
@attribute [Authorize(Policy = ICMFatturazioni.Web.Authentication.AuthorizationPolicies.RequireAdmin)]

@using ICMFatturazioni.Web.Auditing
@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Export
@using ICMFatturazioni.Web.Managers.Interfaces
@using ICMFatturazioni.Web.Manutenzione
@using ICMFatturazioni.Web.Models
@using ICMFatturazioni.Web.Presentation
@using Microsoft.Extensions.Options
@inject IAuditManager AuditManager
@inject IAuditManutenzione AuditManutenzione
@inject IOptions<AuditRetentionOptions> RetentionOptions
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Audit · ICM Fatturazioni</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h1">Audit operazioni</MudText>
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.FileDownload"
                   OnClick="EsportaAsync" Disabled="_esportazioneInCorso">
            Esporta CSV
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.DeleteSweep" OnClick="PurgaAsync">
            Purga &gt; @MesiConservazione mesi
        </MudButton>
    </MudStack>
</MudStack>

@* Sentinella dimensione DB: avviso visibile quando i file dati superano la
   soglia (tetto 10 GB di SQL Express). Stesso evento persistito in fatt.Log. *@
@if (_stato is { Allarme: true })
{
    <MudAlert Severity="MudBlazor.Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
        Il database occupa <b>@_stato.DimensioneDatiMb MB</b>, oltre la soglia di allarme di
        <b>@_stato.SogliaGb GB</b> (tetto SQL Server Express 10 GB). Valuta una retention più
        stretta (riduci i mesi di conservazione) o l'archiviazione dei dati storici di audit/log.
    </MudAlert>
}

<MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="6" md="3">
            <MudDatePicker @bind-Date="_da" Label="Dal" Clearable="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudDatePicker @bind-Date="_a" Label="Al (incluso)" Clearable="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudSelect T="AuditOperazione?" @bind-Value="_operazione" Label="Operazione" Clearable="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                <MudSelectItem T="AuditOperazione?" Value="@(AuditOperazione.Creazione)">Creazione</MudSelectItem>
                <MudSelectItem T="AuditOperazione?" Value="@(AuditOperazione.Modifica)">Modifica</MudSelectItem>
                <MudSelectItem T="AuditOperazione?" Value="@(AuditOperazione.Eliminazione)">Eliminazione</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudSelect T="string" @bind-Value="_entityType" Label="Tipo entità" Clearable="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                @foreach (var t in _entityTypes)
                {
                    <MudSelectItem T="string" Value="@t">@t</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="8" md="2">
            <MudTextField @bind-Value="_testo" Label="Testo (utente/descrizione)" Clearable="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
        </MudItem>
    </MudGrid>
    <MudStack Row="true" Spacing="2" Class="mt-3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" OnClick="CercaAsync">Cerca</MudButton>
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.FilterAltOff" OnClick="PulisciAsync">Pulisci</MudButton>
    </MudStack>
</MudPaper>

<MudDataGrid @ref="_grid" T="Audit" ServerData="CaricaAsync" Dense="true" Hover="true" Striped="true"
             Elevation="0" Class="border">
    <Columns>
        <HierarchyColumn T="Audit" />
        <TemplateColumn Title="Data/ora" Sortable="false">
            <CellTemplate>@DataOra.Italiana(context.Item.TimestampUtc)</CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.UtenteNome" Title="Utente" />
        <TemplateColumn Title="Operazione" Sortable="false">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="@ColoreOperazione(context.Item.Operazione)" Variant="Variant.Filled">
                    @context.Item.Operazione
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.EntityType" Title="Tipo entità" />
        <PropertyColumn Property="x => x.Descrizione" Title="Descrizione" />
    </Columns>
    <ChildRowContent>
        <MudCard Elevation="0" Class="pa-3 ma-2" Outlined="true">
            <MudText Typo="Typo.subtitle2">Dettaglio</MudText>
            @if (string.IsNullOrWhiteSpace(context.Item.Dati))
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    Nessun dettaglio strutturato per questa operazione.
                </MudText>
            }
            else
            {
                <MudText Typo="Typo.caption" Style="white-space:pre-wrap;font-family:monospace;">@AuditDettaglio.Pretty(context.Item.Dati)</MudText>
            }
            <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary">
                EntityType: @context.Item.EntityType · EntityId: @(context.Item.EntityId?.ToString() ?? "—")
            </MudText>
        </MudCard>
    </ChildRowContent>
    <PagerContent>
        <MudDataGridPager T="Audit" PageSizeOptions="@(new[] { 25, 50, 100 })" />
    </PagerContent>
    <NoRecordsContent>
        <MudText Class="pa-4">Nessuna operazione corrispondente ai filtri.</MudText>
    </NoRecordsContent>
</MudDataGrid>

@code {
    private MudDataGrid<Audit> _grid = default!;
    private IReadOnlyList<string> _entityTypes = Array.Empty<string>();

    private DateTime? _da;
    private DateTime? _a;
    private AuditOperazione? _operazione;
    private string? _entityType;
    private string? _testo;

    // Finestra di retention configurata (appsettings: AuditRetention:MesiConservazione).
    private int MesiConservazione => RetentionOptions.Value.MesiConservazione;

    // Stato dimensione DB vs soglia (per il banner di avviso). Sola lettura.
    private StatoDimensione? _stato;

    protected override async Task OnInitializedAsync()
    {
        _entityTypes = await AuditManager.GetEntityTypesAsync();
        _stato = await AuditManutenzione.ValutaDimensioneAsync();
    }

    private async Task PurgaAsync()
    {
        var mesi = MesiConservazione;
        var parameters = new DialogParameters<ConfermaEliminazioneDialog>
        {
            { x => x.Titolo, "Purga audit?" },
            { x => x.NomeElemento, $"Operazioni più vecchie di {mesi} mesi" },
            { x => x.Messaggio, "Verranno eliminate definitivamente dalla tabella fatt.Audit." },
            { x => x.TestoConferma, "Elimina" },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<ConfermaEliminazioneDialog>(string.Empty, parameters, options);
        var result = await dialog.Result;
        if (result is not { Canceled: false })
        {
            return;
        }

        var eliminate = await AuditManager.PurgaPrecedentiAsync(mesi);
        Snackbar.Add($"Eliminate {eliminate} righe di audit.", MudBlazor.Severity.Success);
        _stato = await AuditManutenzione.ValutaDimensioneAsync();
        await _grid.ReloadServerData();
    }

    // Tetto di righe esportabili in un colpo: protegge da OOM/timeout su tabelle
    // grandi. Oltre questa soglia l'export è troncato e l'utente viene avvisato.
    private const int MaxExport = 50_000;
    private bool _esportazioneInCorso;

    private async Task<GridData<Audit>> CaricaAsync(GridState<Audit> state, CancellationToken ct)
    {
        var filtro = CostruisciFiltro(state.Page + 1, state.PageSize);
        var risultato = await AuditManager.CercaAsync(filtro, ct);
        return new GridData<Audit> { Items = risultato.Righe, TotalItems = risultato.TotaleRighe };
    }

    // Filtro condiviso fra griglia ed export: garantisce che il CSV rispecchi
    // ESATTAMENTE i filtri applicati alla griglia.
    private AuditFiltro CostruisciFiltro(int pagina, int dimensione) => new()
    {
        DaUtc = _da?.Date,
        AUtc = _a?.Date.AddDays(1),     // "Al" incluso
        Operazione = _operazione,
        EntityType = _entityType,
        Testo = _testo,
        Pagina = pagina,
        Dimensione = dimensione,
    };

    // Export CSV di TUTTE le righe che soddisfano i filtri correnti (non solo la
    // pagina visibile). Read-only: fuori dal perimetro dell'audit (Regola 7).
    private async Task EsportaAsync()
    {
        _esportazioneInCorso = true;
        try
        {
            var dati = await AuditManager.EsportaAsync(CostruisciFiltro(1, MaxExport), MaxExport);
            if (dati.Count == 0)
            {
                Snackbar.Add("Nessuna riga da esportare per i filtri correnti.", MudBlazor.Severity.Info);
                return;
            }

            var intestazioni = new[] { "Data/ora", "Utente", "Operazione", "Tipo entità", "Descrizione", "EntityId" };
            var righe = dati.Select(r => (IReadOnlyList<string?>)new string?[]
            {
                DataOra.Italiana(r.TimestampUtc),
                r.UtenteNome,
                r.Operazione.ToString(),
                r.EntityType,
                r.Descrizione,
                r.EntityId?.ToString(),
            });

            var bytes = CsvExport.Genera(intestazioni, righe);
            var nomeFile = $"Audit_{DateTime.Now:yyyyMMdd_HHmm}.csv";
            await JS.InvokeVoidAsync("icmDownloadFile", nomeFile, Convert.ToBase64String(bytes), "text/csv");

            // Raggiunto il tetto → probabile troncamento: avvisa di restringere i filtri.
            if (dati.Count >= MaxExport)
                Snackbar.Add($"Esportate {MaxExport} righe (limite massimo): il risultato potrebbe essere " +
                             "troncato. Restringi i filtri per un export completo.", MudBlazor.Severity.Warning);
            else
                Snackbar.Add($"Esportate {dati.Count} righe.", MudBlazor.Severity.Success);
        }
        finally
        {
            _esportazioneInCorso = false;
        }
    }

    private Task CercaAsync() => _grid.ReloadServerData();

    private Task PulisciAsync()
    {
        _da = _a = null;
        _operazione = null;
        _entityType = _testo = null;
        return _grid.ReloadServerData();
    }

    private static Color ColoreOperazione(AuditOperazione op) => op switch
    {
        AuditOperazione.Creazione => Color.Success,
        AuditOperazione.Modifica => Color.Info,
        AuditOperazione.Eliminazione => Color.Error,
        _ => Color.Default,
    };
}
