@*
    Pagina /tabelle-amministrative — entry-point della Fase 1.
    Mostra le 5 sezioni come MudTabs ancora vuote. Ogni tab verrà
    popolato nelle fasi successive del porting (Fase 2: Anagrafica,
    Fase 3: lookup specifiche).
*@

@page "/tabelle-amministrative"

<PageTitle>Tabelle amministrative · ICM Fatturazioni</PageTitle>

<MudText Typo="Typo.h1" Class="mb-4">Tabelle amministrative</MudText>

<MudTabs Elevation="0" Rounded="true" KeepPanelsAlive="false">
    <MudTabPanel Text="Anagrafiche" Icon="@Icons.Material.Outlined.PeopleAlt">
        <MudStack Spacing="3">
            <MudText>
                La gestione delle anagrafiche clienti è disponibile come pagina dedicata.
            </MudText>
            <div>
                <MudButton Href="/anagrafiche"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.OpenInNew"
                           Ripple="false">
                    Apri elenco anagrafiche
                </MudButton>
            </div>
        </MudStack>
    </MudTabPanel>
    <MudTabPanel Text="Codici IVA" Icon="@Icons.Material.Outlined.Percent">
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            La sezione Codici IVA verrà attivata in Fase 3.
        </MudAlert>
    </MudTabPanel>
    <MudTabPanel Text="Banche" Icon="@Icons.Material.Outlined.AccountBalance">
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            La sezione Banche verrà attivata in Fase 3.
        </MudAlert>
    </MudTabPanel>
    <MudTabPanel Text="Pagamenti" Icon="@Icons.Material.Outlined.Payments">
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            La sezione Pagamenti verrà attivata in Fase 3.
        </MudAlert>
    </MudTabPanel>
    <MudTabPanel Text="Tipologie clientela" Icon="@Icons.Material.Outlined.Category">
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            La sezione Tipologie clientela verrà attivata in Fase 3.
        </MudAlert>
    </MudTabPanel>
</MudTabs>
