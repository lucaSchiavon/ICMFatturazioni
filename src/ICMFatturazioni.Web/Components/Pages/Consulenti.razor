@* Pagina /consulenti — anagrafica consulenti esterni (Modulo Attività Consulenti). *@

@page "/consulenti"

@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Managers
@using ICMFatturazioni.Web.Managers.Interfaces
@inject IConsulenteManager ConsulenteManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ICMFatturazioni.Web.Managers.Interfaces.ILogManager LogManager

<PageTitle>Consulenti · ICM Fatturazioni</PageTitle>

<MudText Typo="Typo.h1" Class="mb-4">Consulenti</MudText>

<MudPaper Elevation="0" Class="pa-4 mb-4" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
        <MudTextField @bind-Value="_filtro"
                      Placeholder="Cerca per nome…"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Immediate="true" DebounceInterval="200"
                      Style="min-width: 260px; flex: 1;" />

        <MudSpacer />

        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" Ripple="false"
                   OnClick="ApriDialogAggiungi">
            Aggiungi
        </MudButton>

        @if (_selezionato is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Edit" Ripple="false"
                       OnClick="@(() => ApriDialogModifica(_selezionato))">
                Modifica
            </MudButton>

            @if (_selezionatoEliminabile)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Delete" Ripple="false"
                           OnClick="@(() => ConfermaEdElimina(_selezionato))">
                    Elimina
                </MudButton>
            }
        }
    </MudStack>
</MudPaper>

<MudDataGrid T="Consulente"
             Items="@ConsulentiFiltrati"
             Dense="true" Hover="true" Striped="false" Bordered="false"
             FixedHeader="true" Height="calc(100vh - 320px)"
             Virtualize="true" ItemSize="40"
             SelectedItem="_selezionato"
             SelectedItemChanged="OnSelezionatoChanged"
             RowClick="@OnRowClick"
             RowClassFunc="@RigaClass"
             Loading="@_caricamento">
    <Columns>
        <PropertyColumn Property="x => x.Descrizione" Title="Consulente" StickyLeft="true" />
        <TemplateColumn Title="" Sortable="false" Filterable="false" StickyRight="true">
            <CellTemplate>
                <MudTooltip Text="Elimina">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                   Size="Size.Small" Ripple="false"
                                   OnClick="@(() => ConfermaEdElimina(context.Item))" />
                </MudTooltip>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <NoRecordsContent><MudText>Nessun consulente trovato.</MudText></NoRecordsContent>
    <LoadingContent><MudText>Caricamento in corso…</MudText></LoadingContent>
</MudDataGrid>

@code {
    private IReadOnlyList<Consulente> _consulenti = Array.Empty<Consulente>();
    private Consulente? _selezionato;
    private bool _selezionatoEliminabile;
    private string _filtro = string.Empty;
    private bool _caricamento = true;

    protected override async Task OnInitializedAsync() => await RicaricaAsync();

    private async Task RicaricaAsync()
    {
        _caricamento = true;
        try
        {
            _consulenti = await ConsulenteManager.ElencoAsync();
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex, "Caricamento consulenti fallito.", "Consulenti.RicaricaAsync");
            Snackbar.Add("Errore nel caricamento dell'elenco.", MudBlazor.Severity.Error);
        }
        finally { _caricamento = false; }
    }

    private IEnumerable<Consulente> ConsulentiFiltrati => string.IsNullOrWhiteSpace(_filtro)
        ? _consulenti
        : _consulenti.Where(c => c.Descrizione.Contains(_filtro.Trim(), StringComparison.OrdinalIgnoreCase));

    private async Task OnSelezionatoChanged(Consulente? c)
    {
        _selezionato = c;
        _selezionatoEliminabile = c is not null && await ConsulenteManager.EEliminabileAsync(c.IdConsulente);
    }

    private string RigaClass(Consulente c, int _) =>
        _selezionato?.IdConsulente == c.IdConsulente ? "anagrafica-riga-selezionata" : string.Empty;

    private async Task OnRowClick(DataGridRowClickEventArgs<Consulente> args)
    {
        if (args.MouseEventArgs.Detail >= 2) await ApriDialogModifica(args.Item);
    }

    private async Task ApriDialogAggiungi()
    {
        var p = new DialogParameters<ConsulenteFormDialog> { { x => x.Iniziale, null } };
        var o = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var d = await DialogService.ShowAsync<ConsulenteFormDialog>("Aggiungi consulente", p, o);
        if (await d.Result is { Canceled: false })
        {
            Snackbar.Add("Consulente creato.", MudBlazor.Severity.Success);
            await RicaricaAsync();
        }
    }

    private async Task ApriDialogModifica(Consulente? c)
    {
        if (c is null) return;
        var p = new DialogParameters<ConsulenteFormDialog> { { x => x.Iniziale, c } };
        var o = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var d = await DialogService.ShowAsync<ConsulenteFormDialog>("Modifica consulente", p, o);
        if (await d.Result is { Canceled: false })
        {
            Snackbar.Add("Consulente aggiornato.", MudBlazor.Severity.Success);
            await RicaricaAsync();
        }
    }

    private async Task ConfermaEdElimina(Consulente? c)
    {
        if (c is null) return;
        var p = new DialogParameters<ConfermaEliminazioneDialog>
        {
            { x => x.Titolo, "Eliminare consulente?" },
            { x => x.NomeElemento, c.Descrizione },
            { x => x.Messaggio, "Verrà disattivato e non comparirà più nell'elenco." },
        };
        var o = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseOnEscapeKey = true };
        var d = await DialogService.ShowAsync<ConfermaEliminazioneDialog>(string.Empty, p, o);
        if (await d.Result is not { Canceled: false }) return;

        try
        {
            await ConsulenteManager.EliminaAsync(c.IdConsulente);
            Snackbar.Add("Consulente eliminato.", MudBlazor.Severity.Success);
            if (_selezionato?.IdConsulente == c.IdConsulente) _selezionato = null;
            await RicaricaAsync();
        }
        catch (ConsulenteConDipendenzeException)
        {
            Snackbar.Add("Impossibile eliminare: il consulente è usato da una o più attività consulenti.", MudBlazor.Severity.Warning);
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex, "Eliminazione consulente fallita.", "Consulenti.ConfermaEdElimina");
            Snackbar.Add("Errore durante l'eliminazione.", MudBlazor.Severity.Error);
        }
    }
}
