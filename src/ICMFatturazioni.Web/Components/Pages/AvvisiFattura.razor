@*
    Pagina /avvisi-fattura — Emissione di un Avviso di fattura (dispensa cap. 5-7).

    Flusso a 2 fasi (documento "Avviso fattura nel dettaglio"):
      • FASE 1 (testata): stessi filtri Access-like di GestAttivitaStudio/SpeseAnticipate
        [Anagrafica] [Tipo Attività] [Attività]. Scelta l'attività si compilano i campi
        obbligatori di testata (data + nota sintetica + IVA); "Conferma testata e procedi".
      • FASE 2 (righe): si attiva l'area righe. La griglia è guidata dalle SCADENZE ancora
        fatturabili, raggruppate per dettaglio, con le grandezze live (Totale / In avvisi
        incl. corrente / Residuo). Si allegano le spese (art. 15) e righe descrittive; a
        video l'anteprima della cascata fiscale. "Termina inserimento" emette l'avviso.

    La rata si fattura INTERA (memoria avviso-fattura-design): niente importo parziale.
*@

@page "/avvisi-fattura"

@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Managers
@using ICMFatturazioni.Web.Managers.Interfaces
@using ICMFatturazioni.Web.Models
@using ICMFatturazioni.Web.Services
@using System.Globalization

@inject IAvvisoFatturaManager AvvisoManager
@inject IAttivitaManager AttivitaManager
@inject IAnagraficaManager AnagraficaManager
@inject ITipoAttivitaManager TipoAttivitaManager
@inject ISpesaAnticipataManager SpesaAnticipataManager
@inject IAliquotaManager AliquotaManager
@inject ICodiceIVAManager CodiceIVAManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ICMFatturazioni.Web.Managers.Interfaces.ILogManager LogManager
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Avvisi di fattura · ICM Fatturazioni</PageTitle>

<MudText Typo="Typo.h1" Class="mb-4">Avvisi di fattura</MudText>

@* ═══════════════════════════════════════════════════════════════════
   Riga dei tre selettori (identica a Spese anticipate / Gestione attività)
   ═══════════════════════════════════════════════════════════════════ *@
<MudGrid Spacing="2" Class="icm-grid-3col mb-0">

    @* ── Col 1: Anagrafica ──────────────────────────────────────── *@
    <MudItem xs="12" md="4" Style="display:flex;flex-direction:column;">
        <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="display:flex;flex-direction:column;flex:1;">
            <MudText Typo="Typo.overline" Class="mb-2" Style="font-weight:700;">Anagrafica</MudText>

            <MudRadioGroup T="FiltroTipo" Value="_filtroTipo" ValueChanged="OnFiltroTipoChanged" Class="mb-1">
                <MudStack Row="true" Spacing="0" Wrap="Wrap.Wrap">
                    <MudRadio T="FiltroTipo" Value="FiltroTipo.Tutti"   Dense="true" Size="Size.Small">Tutti</MudRadio>
                    <MudRadio T="FiltroTipo" Value="FiltroTipo.Enti"    Dense="true" Size="Size.Small">Enti</MudRadio>
                    <MudRadio T="FiltroTipo" Value="FiltroTipo.Societa" Dense="true" Size="Size.Small">Soc.</MudRadio>
                    <MudRadio T="FiltroTipo" Value="FiltroTipo.Privati" Dense="true" Size="Size.Small">Privati</MudRadio>
                </MudStack>
            </MudRadioGroup>

            <MudTextField @bind-Value="_filtroRagioneSociale"
                          Placeholder="Filtra per ragione sociale…"
                          Immediate="true" DebounceInterval="150"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Clear"
                          OnAdornmentClick="@(() => _filtroRagioneSociale = string.Empty)"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Class="mb-2" />

            <div class="icm-sellist mb-3" style="height:240px;">
                @if (_caricamentoAnagrafica)
                {
                    <div class="icm-sellist-placeholder">Caricamento…</div>
                }
                else if (!AnagraficheFiltrate.Any())
                {
                    <div class="icm-sellist-placeholder">Nessun cliente trovato.</div>
                }
                else
                {
                    @foreach (var a in AnagraficheFiltrate)
                    {
                        <div class="icm-sellist-item @(a.IdAnagrafica == _anagraficaSelezionata?.IdAnagrafica ? "selected" : "")"
                             @onclick="@(() => SelezionaAnagraficaAsync(a))">
                            <span class="icm-tipo-badge">@a.TipoAnagrafica.ToDbCode()</span>@a.RagioneSociale
                        </div>
                    }
                }
            </div>

            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.People" Ripple="false" Size="Size.Small"
                       OnClick="@(() => Nav.NavigateTo("/anagrafiche"))">
                Gestione anagrafiche
            </MudButton>
        </MudPaper>
    </MudItem>

    @* ── Col 2: Tipo Attività ─────────────────────────────────── *@
    <MudItem xs="12" md="4" Style="display:flex;flex-direction:column;">
        <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="display:flex;flex-direction:column;flex:1;">
            <MudText Typo="Typo.overline" Class="mb-2" Style="font-weight:700;">Tipo Attività</MudText>

            <div class="icm-sellist" style="height:240px;">
                @if (_caricamentoTipi)
                {
                    <div class="icm-sellist-placeholder">Caricamento…</div>
                }
                else if (!_tipiAttivita.Any())
                {
                    <div class="icm-sellist-placeholder">Nessun tipo attività configurato.</div>
                }
                else
                {
                    @foreach (var t in _tipiAttivita)
                    {
                        <div class="icm-sellist-item @(t.IdTipoAttivita == _tipoSelezionato?.IdTipoAttivita ? "selected" : "")"
                             @onclick="@(() => SelezionaTipoAsync(t))">
                            @t.Descrizione
                        </div>
                    }
                }
            </div>
        </MudPaper>
    </MudItem>

    @* ── Col 3: Attività esistenti ────────────────────────────── *@
    <MudItem xs="12" md="4" Style="display:flex;flex-direction:column;">
        <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="display:flex;flex-direction:column;flex:1;">
            <MudText Typo="Typo.overline" Class="mb-2" Style="font-weight:700;">Attività esistenti</MudText>

            <div class="icm-sellist" style="height:240px;">
                @if (_anagraficaSelezionata is null || _tipoSelezionato is null)
                {
                    <div class="icm-sellist-placeholder">Selezionare un cliente e un tipo.</div>
                }
                else if (_caricamentoAttivita)
                {
                    <div class="icm-sellist-placeholder">Caricamento…</div>
                }
                else if (!AttivitaFiltrate.Any())
                {
                    <div class="icm-sellist-placeholder">Nessuna attività fatturabile per questa selezione.</div>
                }
                else
                {
                    @foreach (var a in AttivitaFiltrate)
                    {
                        <div class="icm-sellist-item icm-sellist-item-2col @(a.IdAttivita == _attivitaSelezionata?.IdAttivita ? "selected" : "")"
                             @onclick="@(() => SelezionaAttivitaAsync(a))">
                            <span class="icm-nr">@a.Numero</span>
                            <span class="icm-desc">@a.Descrizione</span>
                        </div>
                    }
                }
            </div>
        </MudPaper>
    </MudItem>

</MudGrid>

@* ═══════════════════════════════════════════════════════════════════
   Corpo — visibile quando un'attività è selezionata
   ═══════════════════════════════════════════════════════════════════ *@
@if (_attivitaSelezionata is not null)
{
    @* Testata attività (sola lettura) *@
    <MudPaper Elevation="0" Outlined="true" Class="pa-4 mt-3">
        <div class="d-flex align-center flex-wrap gap-2 mb-1">
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Size="Size.Small" Class="ma-0">
                @_attivitaSelezionata.Numero
            </MudChip>
            <MudText Typo="Typo.h6" Class="ma-0">@_attivitaSelezionata.Descrizione</MudText>
        </div>
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
            Cliente: @_anagraficaSelezionata?.RagioneSociale
            @if (_anagraficaSelezionata is not null)
            {
                <text> · </text>@(_anagraficaSelezionata.SostitutoImposta ? "sostituto d'imposta (ritenuta applicata)" : "non sostituto d'imposta (nessuna ritenuta)")
            }
        </MudText>

        @* ── Avvisi già emessi per questa attività ─────────────────── *@
        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle1" Class="mb-2" Style="font-weight:700;">Avvisi già emessi</MudText>

        @if (_caricamentoAvvisi)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
        }
        else if (_avvisiEmessi.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="py-2">
                Nessun avviso emesso finora per questa attività.
            </MudText>
        }
        else
        {
            <div style="overflow-x:auto;">
                <MudTable Items="_avvisiEmessi" Dense="true" Hover="true" Striped="true" Style="min-width:520px;">
                    <HeaderContent>
                        <MudTh>Data</MudTh>
                        <MudTh>Oggetto</MudTh>
                        <MudTh Style="text-align:right;">Imponibile €</MudTh>
                        <MudTh Style="width:96px;"></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Data">@context.DataAvviso.ToString("dd/MM/yyyy")</MudTd>
                        <MudTd DataLabel="Oggetto">@(string.IsNullOrWhiteSpace(context.Oggetto) ? "—" : context.Oggetto)</MudTd>
                        <MudTd DataLabel="Imponibile" Style="text-align:right;font-weight:600;">@context.TotaleRighe.ToString("N2", _itCulture)</MudTd>
                        <MudTd Style="padding:2px 4px;white-space:nowrap;">
                            <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf"
                                           Size="Size.Small" Ripple="false" Color="Color.Primary"
                                           aria-label="Anteprima PDF"
                                           OnClick="@(() => AnteprimaPdfAsync(context))" />
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                                           Size="Size.Small" Ripple="false" Color="Color.Error"
                                           aria-label="Annulla avviso"
                                           OnClick="@(() => AnnullaAvvisoAsync(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </div>
        }
    </MudPaper>

    @* ═══════════════ Wizard nuovo avviso ═══════════════ *@
    <MudPaper Elevation="0" Outlined="true" Class="pa-4 mt-3">

        <div class="d-flex align-center gap-2 mb-3">
            <MudIcon Icon="@Icons.Material.Filled.RequestQuote" Color="Color.Primary" />
            <MudText Typo="Typo.subtitle1" Style="font-weight:700;">Nuovo avviso di fattura</MudText>
            @if (_wizardFase == WizardFase.Righe)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="ma-0">
                    Testata confermata
                </MudChip>
            }
        </div>

        @* ─────────────── FASE 1: testata ─────────────── *@
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4" md="3">
                <MudDatePicker Label="Data avviso *"
                               Date="_tData" DateChanged="@(d => _tData = d)"
                               DateFormat="dd/MM/yyyy" Culture="_itCulture" Editable="true"
                               Disabled="_wizardFase == WizardFase.Righe"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Class="campo-obbligatorio" />
            </MudItem>
            <MudItem xs="12" sm="8" md="5">
                <MudTextField @bind-Value="_tNotaSintetica" Label="Nota sintetica *"
                              MaxLength="200" Immediate="true"
                              Disabled="_wizardFase == WizardFase.Righe"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Class="campo-obbligatorio" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="Guid?" Label="Codice IVA *" @bind-Value="_idCodiceIvaSelezionato"
                           Disabled="_wizardFase == WizardFase.Righe"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Class="campo-obbligatorio">
                    @foreach (var c in _codiciIva)
                    {
                        <MudSelectItem T="Guid?" Value="@c.IdCodiceIVA">@c.Descrizione (@c.Aliquota.ToString("0.##", _itCulture)%)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_tOggetto" Label="Oggetto" MaxLength="200"
                              Disabled="_wizardFase == WizardFase.Righe"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_tNotaTestata" Label="Nota di testata" MaxLength="500"
                              Lines="2"
                              Disabled="_wizardFase == WizardFase.Righe"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>

        @if (_wizardFase == WizardFase.Testata)
        {
            @if (!string.IsNullOrWhiteSpace(_erroreTestata))
            {
                <MudAlert Severity="MudBlazor.Severity.Warning" Dense="true" Class="mt-2">@_erroreTestata</MudAlert>
            }
            <div class="d-flex justify-end mt-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Ripple="false"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           OnClick="ConfermaTestata">
                    Conferma testata e procedi
                </MudButton>
            </div>
        }
        else
        {
            @* ─────────────── FASE 2: righe ─────────────── *@
            <div class="d-flex justify-end mt-2 mb-3">
                <MudButton Size="Size.Small" Ripple="false" StartIcon="@Icons.Material.Filled.Edit"
                           OnClick="@(() => _wizardFase = WizardFase.Testata)">
                    Modifica testata
                </MudButton>
            </div>

            <MudDivider Class="my-2" />
            <div class="d-flex align-center justify-space-between flex-wrap gap-2 mb-1">
                <MudText Typo="Typo.subtitle2" Style="font-weight:700;">Scadenze da fatturare</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Ripple="false"
                           StartIcon="@Icons.Material.Filled.PlaylistAdd"
                           Disabled="_scadenzeSelezionate.Count == 0"
                           OnClick="AggiungiRigheSelezionate">
                    Aggiungi le righe selezionate@(_scadenzeSelezionate.Count > 0 ? $" ({_scadenzeSelezionate.Count})" : "")
                </MudButton>
            </div>
            <MudText Typo="Typo.caption" Class="mb-2" Style="color:var(--mud-palette-text-secondary);">
                Spunta le rate e premi «Aggiungi»: diventeranno righe dell'avviso qui sotto. La rata si fattura
                intera: per cambiare la suddivisione usa Gestione scadenze nella maschera Attività.
            </MudText>

            @* Segnalazione "buchi": dettagli con importo non ancora schedulato in scadenze,
               quindi non fatturabili da qui finché non si pianificano le rate. *@
            @if (_dettagliDaSchedulare.Count > 0)
            {
                <MudAlert Severity="MudBlazor.Severity.Warning" Dense="true" Class="mb-3">
                    <div class="mb-1">
                        Alcuni dettagli non hanno scadenze schedulate e <strong>non sono fatturabili</strong>
                        finché non pianifichi le rate in Gestione Attività:
                    </div>
                    <ul class="mb-1" style="margin:0;padding-left:1.2rem;">
                        @foreach (var d in _dettagliDaSchedulare)
                        {
                            <li>@d.Descrizione (@d.ImportoNonSchedulato.ToString("N2", _itCulture) €)</li>
                        }
                    </ul>
                    <MudButton Size="Size.Small" Ripple="false" Variant="Variant.Text"
                               StartIcon="@Icons.Material.Filled.EditCalendar"
                               OnClick="@(() => Nav.NavigateTo("/gest-attivita-studio"))">
                        Vai a Gestione Attività
                    </MudButton>
                </MudAlert>
            }

            @if (_caricamentoScadenze)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
            }
            else if (!ScadenzeDisponibili.Any())
            {
                <MudAlert Severity="MudBlazor.Severity.Info" Dense="true" Class="mb-2">
                    @if (_scadenzeFatturabili.Count == 0)
                    {
                        <text>Nessuna scadenza fatturabile: tutte le rate risultano già in avviso, oppure l'attività non ha ancora scadenze schedulate.</text>
                    }
                    else
                    {
                        <text>Tutte le rate disponibili sono già nelle righe dell'avviso qui sotto.</text>
                    }
                </MudAlert>
            }
            else
            {
                @* ── Tabella (tablet/desktop ≥ 600px) ── *@
                <div class="icm-solo-desktop" style="overflow-x:auto;">
                    <table class="icm-scad-table">
                        <thead>
                            <tr>
                                <th style="width:34px;"></th>
                                <th>Tipo</th>
                                <th>Descrizione</th>
                                <th class="icm-num">Totale €</th>
                                <th class="icm-num">In avvisi<br/>(incl. corr.)</th>
                                <th class="icm-num">Residuo €</th>
                                <th>Scadenza</th>
                                <th class="icm-num">Importo €</th>
                                <th>Nota</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var blocco = 0; }
                            @foreach (var gruppo in ScadenzeRaggruppate)
                            {
                                var primaScad = gruppo.First();
                                var giaLive   = GiaAllocatoLive(gruppo);
                                var residuo   = primaScad.ImportoDettaglio - giaLive;
                                var cssBlocco = $"icm-scad-blocco-{blocco % 2}";
                                var idx       = 0;
                                @foreach (var s in gruppo)
                                {
                                    var sel = _scadenzeSelezionate.Contains(s.IdScadenza);
                                    var primaRiga = idx == 0;
                                    <tr class="@cssBlocco @(sel ? "icm-scad-sel" : "")">
                                        <td>
                                            <MudCheckBox T="bool" Value="sel" Dense="true" Size="Size.Small"
                                                         ValueChanged="@(v => ToggleScadenza(s))" />
                                        </td>
                                        <td>@(primaRiga ? primaScad.TipoDettaglioDescrizione : "")</td>
                                        <td class="icm-scad-desc">@(primaRiga ? primaScad.DescrizioneDettaglio : "")</td>
                                        <td class="icm-num">@(primaRiga ? primaScad.ImportoDettaglio.ToString("N2", _itCulture) : "")</td>
                                        <td class="icm-num">@(primaRiga ? giaLive.ToString("N2", _itCulture) : "")</td>
                                        <td class="icm-num @(primaRiga && residuo == 0 ? "icm-scad-residuo-zero" : "")">@(primaRiga ? residuo.ToString("N2", _itCulture) : "")</td>
                                        <td>@s.DataScadenza.ToString("dd/MM/yyyy")</td>
                                        <td class="icm-num">@s.Importo.ToString("N2", _itCulture)</td>
                                        <td>@s.Nota</td>
                                    </tr>
                                    idx++;
                                }
                                blocco++;
                            }
                        </tbody>
                    </table>
                </div>

                @* ── Card (smartphone < 600px) ── *@
                <div class="icm-solo-mobile">
                    @foreach (var gruppo in ScadenzeRaggruppate)
                    {
                        var primaScad = gruppo.First();
                        var giaLive   = GiaAllocatoLive(gruppo);
                        var residuo   = primaScad.ImportoDettaglio - giaLive;
                        <MudText Typo="Typo.subtitle2" Class="mt-2" Style="font-weight:700;">@primaScad.DescrizioneDettaglio</MudText>
                        <MudText Typo="Typo.caption" Class="mb-1" Style="color:var(--mud-palette-text-secondary);">
                            Totale @primaScad.ImportoDettaglio.ToString("N2", _itCulture) € ·
                            In avvisi @giaLive.ToString("N2", _itCulture) € ·
                            Residuo <strong>@residuo.ToString("N2", _itCulture) €</strong>
                        </MudText>
                        @foreach (var s in gruppo)
                        {
                            var sel = _scadenzeSelezionate.Contains(s.IdScadenza);
                            <div class="icm-scad-card @(sel ? "icm-scad-sel" : "")">
                                <div class="d-flex align-center justify-space-between">
                                    <MudCheckBox T="bool" Value="sel" Dense="true" Size="Size.Small"
                                                 ValueChanged="@(v => ToggleScadenza(s))"
                                                 Label="@s.DataScadenza.ToString("dd/MM/yyyy")" />
                                    <MudText Typo="Typo.subtitle2" Style="font-weight:700;">@s.Importo.ToString("N2", _itCulture) €</MudText>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(s.Nota))
                                {
                                    <MudText Typo="Typo.caption">@s.Nota</MudText>
                                }
                            </div>
                        }
                    }
                </div>
            }

            @* ── Spese anticipate (art. 15) ── *@
            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2" Class="mb-1" Style="font-weight:700;">Spese anticipate da riaddebitare (art. 15)</MudText>
            @if (_speseAttivita.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="py-1">
                    Nessuna spesa anticipata registrata per questa attività.
                </MudText>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2 mb-2">
                    <MudButton Size="Size.Small" Ripple="false" StartIcon="@Icons.Material.Filled.DoneAll"
                               OnClick="SelezionaTutteSpese">Tutte</MudButton>
                    <MudButton Size="Size.Small" Ripple="false" StartIcon="@Icons.Material.Filled.RemoveDone"
                               OnClick="@(() => _speseSelezionate.Clear())">Nessuna</MudButton>
                </div>
                @foreach (var sp in _speseAttivita)
                {
                    var sel = _speseSelezionate.Contains(sp.IdSpesaAnticipata);
                    <div class="d-flex align-center gap-2">
                        <MudCheckBox T="bool" Value="sel" Dense="true" Size="Size.Small"
                                     ValueChanged="@(v => ToggleSpesa(sp))" />
                        <MudText Typo="Typo.body2" Style="flex:1;">
                            @sp.Data.ToString("dd/MM/yyyy") — @sp.Descrizione
                        </MudText>
                        <MudText Typo="Typo.body2" Style="font-weight:600;">@sp.Importo.ToString("N2", _itCulture) €</MudText>
                    </div>
                }
                @if (_speseSelezionate.Count > 0)
                {
                    <MudTextField @bind-Value="_descrizioneSpese" Label="Descrizione spese in avviso *"
                                  MaxLength="500" Lines="2" Immediate="true"
                                  HelperText="Testo art. 15 D.P.R. 633/72, obbligatorio quando si allegano spese."
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="campo-obbligatorio mt-2" />
                }
            }

            @* ══════════ Righe dell'avviso (bozza): diventeranno i dettagli della fattura ══════════ *@
            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2" Class="mb-1" Style="font-weight:700;">Righe dell'avviso</MudText>
            <MudText Typo="Typo.caption" Class="mb-2" Style="color:var(--mud-palette-text-secondary);">
                Queste righe diventeranno i dettagli della fattura, nell'ordine mostrato. Usa le frecce per riordinarle.
            </MudText>

            @* Aggiunta di una riga puramente descrittiva (solo testo, senza importo). *@
            <div class="d-flex gap-2 align-center mb-3">
                <MudTextField @bind-Value="_nuovaDescrittiva" Placeholder="Testo di una riga descrittiva…"
                              MaxLength="200" Immediate="true"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-1" />
                <MudButton Size="Size.Small" Ripple="false" Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Notes" OnClick="AggiungiDescrittiva"
                           Disabled="string.IsNullOrWhiteSpace(_nuovaDescrittiva)">
                    Aggiungi riga descrittiva
                </MudButton>
            </div>

            @if (_righeBozza.Count == 0)
            {
                <MudAlert Severity="MudBlazor.Severity.Info" Dense="true" Class="mb-2">
                    Nessuna riga: spunta le scadenze qui sopra e premi «Aggiungi», oppure aggiungi una riga descrittiva.
                </MudAlert>
            }
            else
            {
                @for (var i = 0; i < _righeBozza.Count; i++)
                {
                    var idx  = i;   // cattura per le lambda
                    var riga = _righeBozza[idx];
                    <MudPaper Elevation="0" Outlined="true" Class="pa-2 mb-1">
                        <div class="d-flex align-center gap-2">
                            <div class="d-flex flex-column">
                                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" Ripple="false"
                                               Disabled="idx == 0" aria-label="Sposta su"
                                               OnClick="@(() => SpostaRiga(idx, -1))" />
                                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Ripple="false"
                                               Disabled="idx == _righeBozza.Count - 1" aria-label="Sposta giù"
                                               OnClick="@(() => SpostaRiga(idx, +1))" />
                            </div>
                            <div style="flex:1;min-width:0;">
                                @if (riga.IsDescrittiva)
                                {
                                    <MudText Typo="Typo.body2" Style="font-style:italic;">@riga.Descrizione</MudText>
                                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">Riga descrittiva</MudText>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2" Style="font-weight:600;">
                                        @(string.IsNullOrWhiteSpace(riga.Tipo) ? "" : $"{riga.Tipo} — ")@riga.Descrizione
                                    </MudText>
                                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                        Rata del @riga.DataScadenza?.ToString("dd/MM/yyyy")
                                    </MudText>
                                }
                            </div>
                            <MudText Typo="Typo.body2" Style="font-weight:600;font-variant-numeric:tabular-nums;white-space:nowrap;">
                                @(riga.Importo is { } imp ? $"{imp.ToString("N2", _itCulture)} €" : "—")
                            </MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Ripple="false" Color="Color.Error"
                                           aria-label="Rimuovi riga" OnClick="@(() => RimuoviRigaBozza(idx))" />
                        </div>
                    </MudPaper>
                }
                <div class="d-flex justify-end mt-1">
                    <MudText Typo="Typo.body2">
                        Imponibile righe: <strong>@_righeBozza.Where(r => !r.IsDescrittiva).Sum(r => r.Importo ?? 0m).ToString("N2", _itCulture) €</strong>
                    </MudText>
                </div>
            }

            @* ── Anteprima cascata fiscale ── *@
            <MudDivider Class="my-3" />
            <MudPaper Elevation="0" Class="mud-background-gray rounded pa-3">
                <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:700;">Anteprima importi</MudText>
                @{ var calc = CalcolaAnteprima(); }
                <div class="d-flex flex-column gap-1" style="max-width:360px;">
                    @RigaImporto("Imponibile", calc.Imponibile, false, false)
                    @RigaImporto($"C.N.P.A.I.A. {_aliquoteFiscali.Cnpaia.ToString("0.##", _itCulture)}%", calc.Cassa, false, false)
                    @RigaImporto($"IVA {_aliquotaIvaCorrente.ToString("0.##", _itCulture)}%", calc.Iva, false, false)
                    <MudDivider Class="my-1" />
                    @RigaImporto("Totale", calc.Totale, true, false)
                    @if (calc.Ritenuta > 0)
                    {
                        @RigaImporto($"− Ritenuta {_aliquoteFiscali.Ritenuta.ToString("0.##", _itCulture)}%", -calc.Ritenuta, false, false)
                    }
                    @if (calc.SpeseArt15 > 0)
                    {
                        @RigaImporto("+ Spese art. 15", calc.SpeseArt15, false, false)
                    }
                    <MudDivider Class="my-1" />
                    @RigaImporto("Totale nostro avere", calc.TotaleNostroAvere, true, true)
                </div>
            </MudPaper>

            @if (!string.IsNullOrWhiteSpace(_erroreEmissione))
            {
                <MudAlert Severity="MudBlazor.Severity.Error" Dense="true" Class="mt-3">@_erroreEmissione</MudAlert>
            }

            <div class="d-flex justify-end gap-2 mt-3 flex-wrap">
                <MudButton Ripple="false" StartIcon="@Icons.Material.Filled.Cancel" OnClick="ResetWizard">
                    Annulla bozza
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Ripple="false"
                           StartIcon="@Icons.Material.Filled.Check"
                           Disabled="_emissioneInCorso || !_righeBozza.Any(r => !r.IsDescrittiva)"
                           OnClick="TerminaInserimentoAsync">
                    @(_emissioneInCorso ? "Emissione…" : "Termina inserimento")
                </MudButton>
            </div>
        }
    </MudPaper>
}

@code {
    private enum FiltroTipo { Tutti, Enti, Societa, Privati }
    private enum WizardFase { Testata, Righe }

    private static readonly CultureInfo _itCulture = CultureInfo.GetCultureInfo("it-IT");

    // ── Dati caricati ────────────────────────────────────────────────────
    private IReadOnlyList<Anagrafica>   _anagrafiche   = Array.Empty<Anagrafica>();
    private IReadOnlyList<TipoAttivita> _tipiAttivita  = Array.Empty<TipoAttivita>();
    private IReadOnlyList<Attivita>     _attivitaLista = Array.Empty<Attivita>();
    private IReadOnlyList<CodiceIVA>    _codiciIva     = Array.Empty<CodiceIVA>();
    private AliquoteFiscali             _aliquoteFiscali = new(0m, 0m);

    // Contesto dell'attività selezionata
    private List<AvvisoFattura>          _avvisiEmessi       = new();
    private List<ScadenzaFatturabile>    _scadenzeFatturabili = new();
    private List<SpesaAnticipata>        _speseAttivita      = new();
    private List<DettaglioDaSchedulare>  _dettagliDaSchedulare = new();

    // Universo "fatturabile" (per i filtri): attività con ≥1 scadenza non ancora
    // in avviso; i clienti/attività coperti spariscono dai selettori.
    private HashSet<Guid> _anagraficheFatturabili = new();
    private HashSet<Guid> _attivitaFatturabili    = new();

    // ── Selezioni correnti ───────────────────────────────────────────────
    private Anagrafica?   _anagraficaSelezionata;
    private TipoAttivita? _tipoSelezionato;
    private Attivita?     _attivitaSelezionata;

    // ── Stato caricamento ────────────────────────────────────────────────
    private bool _caricamentoAnagrafica = true;
    private bool _caricamentoTipi       = true;
    private bool _caricamentoAttivita;
    private bool _caricamentoAvvisi;
    private bool _caricamentoScadenze;

    // ── Filtro anagrafiche ───────────────────────────────────────────────
    private FiltroTipo _filtroTipo           = FiltroTipo.Tutti;
    private string     _filtroRagioneSociale = string.Empty;

    // ── Wizard nuovo avviso ──────────────────────────────────────────────
    private WizardFase _wizardFase = WizardFase.Testata;

    // Testata (fase 1)
    private DateTime? _tData = DateTime.Today;
    private string    _tNotaSintetica = string.Empty;
    private string    _tOggetto       = string.Empty;
    private string    _tNotaTestata   = string.Empty;
    private Guid?     _idCodiceIvaSelezionato;
    private string    _erroreTestata  = string.Empty;

    // Righe (fase 2)
    private readonly HashSet<Guid> _scadenzeSelezionate = new();   // checkbox nella griglia sorgente (pre-aggiunta)
    private readonly HashSet<Guid> _speseSelezionate    = new();
    private string        _descrizioneSpese = string.Empty;
    private readonly List<RigaBozza> _righeBozza = new();          // righe dell'avviso, in ordine
    private string        _nuovaDescrittiva = string.Empty;
    private string        _erroreEmissione  = string.Empty;
    private bool          _emissioneInCorso;

    // Riga della bozza avviso: reale (da una scadenza) o descrittiva (solo testo).
    private sealed class RigaBozza
    {
        public Guid?     IdScadenza          { get; init; }   // null = descrittiva
        public Guid?     IdAttivitaDettaglio { get; init; }
        public string?   Tipo                { get; init; }
        public string    Descrizione         { get; init; } = string.Empty;
        public decimal?  Importo             { get; init; }   // null = descrittiva
        public DateOnly? DataScadenza        { get; init; }
        public bool      IsDescrittiva => IdScadenza is null;
    }

    // Aliquota IVA risolta dal codice selezionato (0 se nessuno)
    private decimal _aliquotaIvaCorrente
        => _codiciIva.FirstOrDefault(c => c.IdCodiceIVA == _idCodiceIvaSelezionato)?.Aliquota ?? 0m;

    // ── Computed ─────────────────────────────────────────────────────────
    private IEnumerable<Anagrafica> AnagraficheFiltrate
    {
        get
        {
            var q = _anagrafiche.AsEnumerable();
            q = _filtroTipo switch
            {
                FiltroTipo.Enti    => q.Where(a => a.TipoAnagrafica == TipoAnagrafica.EntePubblico),
                FiltroTipo.Societa => q.Where(a => a.TipoAnagrafica == TipoAnagrafica.Societa),
                FiltroTipo.Privati => q.Where(a => a.TipoAnagrafica == TipoAnagrafica.Privato),
                _                  => q,
            };
            // Solo clienti con almeno un'attività ancora fatturabile.
            q = q.Where(a => _anagraficheFatturabili.Contains(a.IdAnagrafica));
            if (!string.IsNullOrWhiteSpace(_filtroRagioneSociale))
                q = q.Where(a => a.RagioneSociale.Contains(
                    _filtroRagioneSociale.Trim(), StringComparison.OrdinalIgnoreCase));
            return q;
        }
    }

    // Attività della selezione (anagrafica+tipo) ancora fatturabili.
    private IEnumerable<Attivita> AttivitaFiltrate
        => _attivitaLista.Where(a => _attivitaFatturabili.Contains(a.IdAttivita));

    // Scadenze ancora disponibili nella griglia sorgente: fatturabili non ancora
    // spostate nelle righe dell'avviso (bozza).
    private IEnumerable<ScadenzaFatturabile> ScadenzeDisponibili
        => _scadenzeFatturabili.Where(s => !_righeBozza.Any(r => r.IdScadenza == s.IdScadenza));

    // Scadenze disponibili raggruppate per dettaglio (ordine dettaglio, poi data).
    private IEnumerable<IGrouping<Guid, ScadenzaFatturabile>> ScadenzeRaggruppate
        => ScadenzeDisponibili
            .OrderBy(s => s.OrdineDettaglio).ThenBy(s => s.DataScadenza)
            .GroupBy(s => s.IdAttivitaDettaglio);

    // "Già allocato" live per un dettaglio = avvisi precedenti + rate di questo
    // dettaglio già messe nelle righe dell'avviso in bozza (opzione Y, avviso-fattura-design).
    private decimal GiaAllocatoLive(IGrouping<Guid, ScadenzaFatturabile> gruppo)
        => gruppo.First().GiaAllocatoAvvisiPrecedenti
         + _righeBozza.Where(r => !r.IsDescrittiva && r.IdAttivitaDettaglio == gruppo.Key)
                      .Sum(r => r.Importo ?? 0m);

    // ── Init ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var t1 = AnagraficaManager.ElencoAsync();
        var t2 = TipoAttivitaManager.ElencoAsync();
        var t3 = CodiceIVAManager.ElencoAsync();
        var t4 = AliquotaManager.GetAliquoteAvvisoAsync();
        var t5 = AvvisoManager.AttivitaFatturabiliAsync();
        await Task.WhenAll(t1, t2, t3, t4, t5);
        _anagrafiche     = t1.Result;
        _tipiAttivita    = t2.Result;
        _codiciIva       = t3.Result;
        _aliquoteFiscali = t4.Result;
        AggiornaUniversoFatturabile(t5.Result);
        _caricamentoAnagrafica = false;
        _caricamentoTipi       = false;
    }

    // Ricalcola gli insiemi di clienti/attività ancora fatturabili.
    private void AggiornaUniversoFatturabile(IReadOnlyList<AttivitaFatturabile> fatturabili)
    {
        _anagraficheFatturabili = fatturabili.Select(f => f.IdAnagrafica).ToHashSet();
        _attivitaFatturabili    = fatturabili.Select(f => f.IdAttivita).ToHashSet();
    }

    // ── Selezione filtri ─────────────────────────────────────────────────
    private void SelezionaAnagraficaAsync(Anagrafica a)
    {
        if (_anagraficaSelezionata?.IdAnagrafica == a.IdAnagrafica) return;
        _anagraficaSelezionata = a;
        _tipoSelezionato       = null;
        _attivitaLista         = Array.Empty<Attivita>();
        ResetContestoAttivita();
    }

    private async Task SelezionaTipoAsync(TipoAttivita t)
    {
        if (_tipoSelezionato?.IdTipoAttivita == t.IdTipoAttivita) return;
        _tipoSelezionato = t;
        ResetContestoAttivita();
        if (_anagraficaSelezionata is not null)
            await CaricaAttivitaAsync();
        else
            _attivitaLista = Array.Empty<Attivita>();
    }

    private async Task CaricaAttivitaAsync()
    {
        if (_anagraficaSelezionata is null || _tipoSelezionato is null) return;
        _caricamentoAttivita = true;
        try
        {
            _attivitaLista = await AttivitaManager.ElencoPerAnagraficaTipoAsync(
                _anagraficaSelezionata.IdAnagrafica, _tipoSelezionato.IdTipoAttivita);
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex, "Caricamento attività fallito.", "AvvisiFattura.CaricaAttivitaAsync");
            Snackbar.Add("Errore nel caricamento delle attività.", MudBlazor.Severity.Error);
        }
        finally { _caricamentoAttivita = false; }
    }

    private async Task SelezionaAttivitaAsync(Attivita a)
    {
        _attivitaSelezionata = a;
        ResetWizard();
        await CaricaContestoAttivitaAsync();
    }

    private void OnFiltroTipoChanged(FiltroTipo nuovo)
    {
        _filtroTipo = nuovo;
        if (_anagraficaSelezionata is not null
            && !AnagraficheFiltrate.Any(a => a.IdAnagrafica == _anagraficaSelezionata.IdAnagrafica))
        {
            _anagraficaSelezionata = null;
            _tipoSelezionato       = null;
            _attivitaLista         = Array.Empty<Attivita>();
            ResetContestoAttivita();
        }
    }

    // ── Contesto attività (avvisi + scadenze + spese) ─────────────────────
    private void ResetContestoAttivita()
    {
        _attivitaSelezionata = null;
        _avvisiEmessi         = new();
        _scadenzeFatturabili  = new();
        _speseAttivita        = new();
        _dettagliDaSchedulare = new();
        ResetWizard();
    }

    private async Task CaricaContestoAttivitaAsync()
    {
        if (_attivitaSelezionata is null) return;
        _caricamentoAvvisi   = true;
        _caricamentoScadenze = true;
        try
        {
            var idAtt = _attivitaSelezionata.IdAttivita;
            var tAvvisi   = AvvisoManager.ElencoPerAttivitaAsync(idAtt);
            var tScadenze = AvvisoManager.ScadenzeFatturabiliAsync(idAtt);
            var tSpese    = SpesaAnticipataManager.ElencoFatturabiliPerAttivitaAsync(idAtt);  // solo spese non già in avviso
            var tFatt     = AvvisoManager.AttivitaFatturabiliAsync();                         // coperture aggiornate
            var tDaSched  = AvvisoManager.DettagliDaSchedulareAsync(idAtt);                   // dettagli senza scadenze complete
            await Task.WhenAll(tAvvisi, tScadenze, tSpese, tFatt, tDaSched);
            _avvisiEmessi         = tAvvisi.Result.ToList();
            _scadenzeFatturabili  = tScadenze.Result.ToList();
            _speseAttivita        = tSpese.Result.ToList();
            _dettagliDaSchedulare = tDaSched.Result.ToList();
            AggiornaUniversoFatturabile(tFatt.Result);

            // Default IVA dal codice del cliente (può essere null su anagrafica minimale).
            _idCodiceIvaSelezionato = _anagraficaSelezionata?.IdCodiciIVA;
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex, "Caricamento contesto avviso fallito.", "AvvisiFattura.CaricaContestoAttivitaAsync");
            Snackbar.Add("Errore nel caricamento dei dati dell'attività.", MudBlazor.Severity.Error);
        }
        finally
        {
            _caricamentoAvvisi   = false;
            _caricamentoScadenze = false;
        }
    }

    // ── Wizard ───────────────────────────────────────────────────────────
    private void ResetWizard()
    {
        _wizardFase = WizardFase.Testata;
        _tData          = DateTime.Today;
        _tNotaSintetica = string.Empty;
        _tOggetto       = string.Empty;
        _tNotaTestata   = string.Empty;
        _idCodiceIvaSelezionato = _anagraficaSelezionata?.IdCodiciIVA;
        _erroreTestata  = string.Empty;
        _scadenzeSelezionate.Clear();
        _speseSelezionate.Clear();
        _descrizioneSpese = string.Empty;
        _righeBozza.Clear();
        _nuovaDescrittiva = string.Empty;
        _erroreEmissione  = string.Empty;
    }

    private void ConfermaTestata()
    {
        _erroreTestata = string.Empty;
        if (!_tData.HasValue)
        {
            _erroreTestata = "La data dell'avviso è obbligatoria.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_tNotaSintetica))
        {
            _erroreTestata = "La nota sintetica è obbligatoria.";
            return;
        }
        if (_idCodiceIvaSelezionato is null)
        {
            _erroreTestata = "Seleziona il codice IVA da applicare all'avviso.";
            return;
        }
        _wizardFase = WizardFase.Righe;
    }

    private void ToggleScadenza(ScadenzaFatturabile s)
    {
        if (!_scadenzeSelezionate.Add(s.IdScadenza))
            _scadenzeSelezionate.Remove(s.IdScadenza);
    }

    private void ToggleSpesa(SpesaAnticipata sp)
    {
        if (!_speseSelezionate.Add(sp.IdSpesaAnticipata))
            _speseSelezionate.Remove(sp.IdSpesaAnticipata);
    }

    private void SelezionaTutteSpese()
    {
        foreach (var sp in _speseAttivita)
            _speseSelezionate.Add(sp.IdSpesaAnticipata);
    }

    // Sposta nelle righe dell'avviso (bozza) le scadenze spuntate nella sorgente.
    private void AggiungiRigheSelezionate()
    {
        foreach (var s in ScadenzeDisponibili
                     .Where(s => _scadenzeSelezionate.Contains(s.IdScadenza))
                     .OrderBy(s => s.OrdineDettaglio).ThenBy(s => s.DataScadenza)
                     .ToList())
        {
            _righeBozza.Add(new RigaBozza
            {
                IdScadenza          = s.IdScadenza,
                IdAttivitaDettaglio = s.IdAttivitaDettaglio,
                Tipo                = s.TipoDettaglioDescrizione,
                Descrizione         = s.DescrizioneDettaglio,
                Importo             = s.Importo,
                DataScadenza        = s.DataScadenza,
            });
        }
        _scadenzeSelezionate.Clear();
    }

    private void AggiungiDescrittiva()
    {
        if (string.IsNullOrWhiteSpace(_nuovaDescrittiva)) return;
        _righeBozza.Add(new RigaBozza { Descrizione = _nuovaDescrittiva.Trim() });
        _nuovaDescrittiva = string.Empty;
    }

    private void RimuoviRigaBozza(int index)
    {
        if (index >= 0 && index < _righeBozza.Count)
            _righeBozza.RemoveAt(index);
    }

    // Sposta una riga di uno step su (-1) o giù (+1) nell'ordine dell'avviso.
    private void SpostaRiga(int index, int delta)
    {
        var nuovo = index + delta;
        if (index < 0 || index >= _righeBozza.Count || nuovo < 0 || nuovo >= _righeBozza.Count) return;
        (_righeBozza[index], _righeBozza[nuovo]) = (_righeBozza[nuovo], _righeBozza[index]);
    }

    // Anteprima cascata: costruisce un avviso "provvisorio" con gli snapshot
    // correnti e delega al calcolo puro del manager (stesso usato in emissione).
    private CalcoloFiscaleRisultato CalcolaAnteprima()
    {
        var imponibile = _righeBozza.Where(r => !r.IsDescrittiva).Sum(r => r.Importo ?? 0m);
        var speseArt15 = _speseAttivita
            .Where(sp => _speseSelezionate.Contains(sp.IdSpesaAnticipata)).Sum(sp => sp.Importo);

        var preview = new AvvisoFattura
        {
            AliquotaIva      = _aliquotaIvaCorrente,
            AliquotaCnpaia   = _aliquoteFiscali.Cnpaia,
            AliquotaRitenuta = _aliquoteFiscali.Ritenuta,
            ApplicaRitenuta  = _anagraficaSelezionata?.SostitutoImposta ?? false,
        };
        return AvvisoManager.Calcola(preview, imponibile, speseArt15);
    }

    private async Task TerminaInserimentoAsync()
    {
        _erroreEmissione = string.Empty;
        if (!_righeBozza.Any(r => !r.IsDescrittiva))
        {
            _erroreEmissione = "Aggiungi almeno una rata alle righe dell'avviso.";
            return;
        }
        if (_speseSelezionate.Count > 0 && string.IsNullOrWhiteSpace(_descrizioneSpese))
        {
            _erroreEmissione = "Compila la descrizione spese in avviso (obbligatoria quando si allegano spese).";
            return;
        }
        if (_attivitaSelezionata is null || _anagraficaSelezionata is null) return;

        // Righe nell'ordine della bozza (scadenze e descrittive interlacciate).
        var righe = _righeBozza
            .Select(r => new RigaAvvisoInput(r.IdScadenza, r.IsDescrittiva ? r.Descrizione : null))
            .ToList();

        var request = new EmissioneAvvisoRequest(
            IdAttivita:               _attivitaSelezionata.IdAttivita,
            IdAnagrafica:             _anagraficaSelezionata.IdAnagrafica,
            DataAvviso:               DateOnly.FromDateTime(_tData!.Value),
            AliquotaIva:              _aliquotaIvaCorrente,
            Righe:                    righe,
            IdSpeseSelezionate:       _speseSelezionate.ToList(),
            Oggetto:                  string.IsNullOrWhiteSpace(_tOggetto) ? null : _tOggetto.Trim(),
            NotaSintetica:            string.IsNullOrWhiteSpace(_tNotaSintetica) ? null : _tNotaSintetica.Trim(),
            NotaTestata:              string.IsNullOrWhiteSpace(_tNotaTestata) ? null : _tNotaTestata.Trim(),
            DescrizioneSpeseInAvviso: string.IsNullOrWhiteSpace(_descrizioneSpese) ? null : _descrizioneSpese.Trim());

        _emissioneInCorso = true;
        try
        {
            await AvvisoManager.EmettiAsync(request);
            Snackbar.Add("Avviso di fattura emesso.", MudBlazor.Severity.Success);
            ResetWizard();
            await CaricaContestoAttivitaAsync();  // le rate consumate spariscono
        }
        catch (AvvisoFatturaInvalidaException ex)
        {
            _erroreEmissione = ex.Message;
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex, "Emissione avviso fallita.", "AvvisiFattura.TerminaInserimentoAsync");
            _erroreEmissione = "Errore durante l'emissione dell'avviso. Riprovare.";
        }
        finally { _emissioneInCorso = false; }
    }

    // Apre il PDF di cortesia dell'avviso in una nuova scheda (anteprima inline).
    // Il file è servito dall'endpoint /api/avvisi/{id}/pdf.
    private async Task AnteprimaPdfAsync(AvvisoFattura a)
    {
        try
        {
            await JS.InvokeVoidAsync("open", $"/api/avvisi/{a.IdAvviso}/pdf", "_blank");
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex, "Apertura anteprima PDF fallita.", "AvvisiFattura.AnteprimaPdfAsync");
            Snackbar.Add("Impossibile aprire l'anteprima PDF.", MudBlazor.Severity.Error);
        }
    }

    private async Task AnnullaAvvisoAsync(AvvisoFattura a)
    {
        var parameters = new DialogParameters<ConfermaEliminazioneDialog>
        {
            { x => x.Titolo, "Annullare l'avviso?" },
            { x => x.NomeElemento, string.IsNullOrWhiteSpace(a.Oggetto) ? $"Avviso del {a.DataAvviso:dd/MM/yyyy}" : a.Oggetto! },
            { x => x.Messaggio, "Le rate torneranno fatturabili e le spese collegate verranno scollegate." },
            { x => x.TestoConferma, "Annulla avviso" },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<ConfermaEliminazioneDialog>(string.Empty, parameters, options);
        var risultato = await dialog.Result;
        if (risultato is not { Canceled: false }) return;

        try
        {
            await AvvisoManager.AnnullaAsync(a.IdAvviso);
            Snackbar.Add("Avviso annullato.", MudBlazor.Severity.Success);
            await CaricaContestoAttivitaAsync();
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex, "Annullamento avviso fallito.", "AvvisiFattura.AnnullaAvvisoAsync");
            Snackbar.Add("Errore durante l'annullamento.", MudBlazor.Severity.Error);
        }
    }

    // Riga dell'anteprima importi: etichetta a sinistra, importo € a destra.
    private RenderFragment RigaImporto(string etichetta, decimal valore, bool bold, bool primary) => __builder =>
    {
        <div class="d-flex justify-space-between align-center"
             style="@(primary ? "color:var(--mud-palette-primary);" : "")">
            <span style="@(bold ? "font-weight:700;" : "")">@etichetta</span>
            <span style="@(bold ? "font-weight:700;" : "")font-variant-numeric:tabular-nums;">@valore.ToString("N2", _itCulture) €</span>
        </div>
    };
}
