@*
    Pagina /anagrafiche — elenco master delle anagrafiche cliente.

    Pattern:
    - MudDataGrid con virtualization e filtro testo libero (RagioneSociale,
      PIVA, Email, City).
    - Toolbar con "Aggiungi" sempre attivo; "Modifica"/"Elimina" visibili
      solo quando c'è una riga selezionata (pattern visibility-driven da
      CLAUDE.md).
    - Responsive: scroll orizzontale + sticky della prima colonna
      (RagioneSociale, "chiave umana" — vedi ADR D15).
    - Aggiungi/Modifica aprono lo stesso dialog (AnagraficaFormDialog),
      che gestisce entrambi i flussi via parametro IsModifica.
    - Elimina chiede conferma con MudMessageBox.
*@

@page "/anagrafiche"

@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Managers
@using ICMFatturazioni.Web.Export
@inject IAnagraficaManager AnagraficaManager
@inject ICodicePagamentoManager CodicePagamentoManager
@inject IBancaAppoggioManager BancaAppoggioManager
@inject ICodiceIVAManager CodiceIVAManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject ICMFatturazioni.Web.Managers.Interfaces.ILogManager LogManager

<PageTitle>Anagrafiche · ICM Fatturazioni</PageTitle>

<MudText Typo="Typo.h1" Class="mb-4">Anagrafiche clienti</MudText>

<MudPaper Elevation="0" Class="pa-4 mb-4" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
        <MudTextField @bind-Value="_filtro"
                      Placeholder="Cerca per ragione sociale, P.IVA, email…"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      DebounceInterval="200"
                      Style="min-width: 280px; flex: 1;" />

        <MudSelect T="TipoAnagrafica?"
                   @bind-Value="_filtroTipo"
                   Label="Tipologia"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Clearable="true"
                   Style="min-width: 180px;">
            <MudSelectItem T="TipoAnagrafica?" Value="@((TipoAnagrafica?)TipoAnagrafica.Societa)">Società</MudSelectItem>
            <MudSelectItem T="TipoAnagrafica?" Value="@((TipoAnagrafica?)TipoAnagrafica.Privato)">Privato</MudSelectItem>
            <MudSelectItem T="TipoAnagrafica?" Value="@((TipoAnagrafica?)TipoAnagrafica.EntePubblico)">Ente pubblico</MudSelectItem>
        </MudSelect>

        <MudSpacer />

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Download"
                   Ripple="false"
                   Disabled="@(_esportazioneInCorso || !AnagraficheFiltrate.Any())"
                   OnClick="EsportaCsvAsync">
            Esporta CSV
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Ripple="false"
                   OnClick="ApriDialogAggiungi">
            Aggiungi
        </MudButton>

        @if (_selezionata is not null)
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Edit"
                       Ripple="false"
                       OnClick="@(() => ApriDialogModifica(_selezionata))">
                Modifica
            </MudButton>

            @if (_selezionataEliminabile)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Delete"
                           Ripple="false"
                           OnClick="@(() => ConfermaEdElimina(_selezionata))">
                    Elimina
                </MudButton>
            }
        }
    </MudStack>
</MudPaper>

<MudDataGrid T="Anagrafica"
             Items="@AnagraficheFiltrate"
             Dense="true"
             Hover="true"
             Striped="false"
             Bordered="false"
             FixedHeader="true"
             Height="calc(100vh - 280px)"
             Virtualize="true"
             ItemSize="40"
             SelectedItem="_selezionata"
             SelectedItemChanged="OnSelezionataChanged"
             RowClick="@OnRowClick"
             RowClassFunc="@RigaClass"
             Loading="@_caricamento">
    <Columns>
        @* Prima colonna "sticky" su mobile: la ragione sociale è la
           chiave umana che permette di non perdere il contesto durante
           lo scroll orizzontale (ADR D15). *@
        <PropertyColumn Property="x => x.RagioneSociale"
                        Title="Ragione sociale"
                        StickyLeft="true" />
        <TemplateColumn Title="Tipo">
            <CellTemplate>
                <MudChip T="string"
                         Color="@TipoColor(context.Item.TipoAnagrafica)"
                         Size="Size.Small"
                         Variant="Variant.Text">
                    @context.Item.TipoAnagrafica.Descrizione()
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.PIVA"        Title="P.IVA / CF" />
        <PropertyColumn Property="x => x.City"        Title="Città" />
        <PropertyColumn Property="x => x.Provincia"   Title="Prov." />
        <PropertyColumn Property="x => x.SiglaPaese"  Title="Paese" />
        <PropertyColumn Property="x => x.Email"       Title="Email" />
        <PropertyColumn Property="x => x.Telefono"    Title="Telefono" />
        @* Riferimenti amministrativi risolti (Tappa 6): mostrano la descrizione
           leggibile invece del GUID. "—" quando non associati. *@
        <TemplateColumn Title="Pagamento" Sortable="false">
            <CellTemplate>@RisolviPagamento(context.Item.IdPag)</CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Banca" Sortable="false">
            <CellTemplate>@RisolviBanca(context.Item.IdBancaAppoggio)</CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Cod. IVA" Sortable="false">
            <CellTemplate>@RisolviIva(context.Item.IdCodiciIVA)</CellTemplate>
        </TemplateColumn>
        @* Azione rapida per riga: elimina (disattiva) la singola anagrafica
           senza doverla prima selezionare in toolbar. *@
        <TemplateColumn Title="" Sortable="false" Filterable="false" StickyRight="true">
            <CellTemplate>
                <MudTooltip Text="Elimina">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   Ripple="false"
                                   OnClick="@(() => ConfermaEdElimina(context.Item))" />
                </MudTooltip>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <NoRecordsContent>
        <MudText>Nessuna anagrafica trovata.</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Caricamento in corso…</MudText>
    </LoadingContent>
</MudDataGrid>

@code {
    private IReadOnlyList<Anagrafica> _anagrafiche = Array.Empty<Anagrafica>();
    private Anagrafica? _selezionata;
    private bool _selezionataEliminabile;
    private string _filtro = string.Empty;
    private TipoAnagrafica? _filtroTipo;
    private bool _caricamento = true;
    private bool _esportazioneInCorso;

    // Mappe Id→descrizione per risolvere i riferimenti amministrativi in griglia.
    // Ricaricate insieme alle anagrafiche (i cataloghi sono piccoli e possono
    // cambiare se l'utente ne aggiunge "al volo" dal dialog).
    private Dictionary<Guid, string> _pagamentoDesc = new();
    private Dictionary<Guid, string> _bancaDesc = new();
    private Dictionary<Guid, string> _ivaDesc = new();

    protected override async Task OnInitializedAsync()
    {
        await RicaricaAsync();
    }

    private async Task RicaricaAsync()
    {
        _caricamento = true;
        try
        {
            var anagTask = AnagraficaManager.ElencoAsync();
            var pagTask = CodicePagamentoManager.ElencoAsync();
            var bancaTask = BancaAppoggioManager.ElencoAsync();
            var ivaTask = CodiceIVAManager.ElencoAsync();
            await Task.WhenAll(anagTask, pagTask, bancaTask, ivaTask);

            _anagrafiche = anagTask.Result;
            _pagamentoDesc = pagTask.Result.ToDictionary(p => p.IdCodicePagamento, p => p.DescrPag);
            _bancaDesc = bancaTask.Result.ToDictionary(
                b => b.IdBancaAppoggio,
                b => string.IsNullOrWhiteSpace(b.AgenziaNome) ? b.BancaNome : $"{b.BancaNome} — {b.AgenziaNome}");
            _ivaDesc = ivaTask.Result.ToDictionary(i => i.IdCodiceIVA, i => i.Descrizione);
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex,
                "Caricamento dell'elenco anagrafiche fallito.", "Anagrafiche.RicaricaAsync");
            Snackbar.Add("Errore nel caricamento dell'elenco.", MudBlazor.Severity.Error);
        }
        finally
        {
            _caricamento = false;
        }
    }

    private IEnumerable<Anagrafica> AnagraficheFiltrate
    {
        get
        {
            IEnumerable<Anagrafica> q = _anagrafiche;
            if (_filtroTipo is not null)
            {
                q = q.Where(a => a.TipoAnagrafica == _filtroTipo);
            }
            if (!string.IsNullOrWhiteSpace(_filtro))
            {
                var f = _filtro.Trim();
                q = q.Where(a =>
                    (a.RagioneSociale?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (a.PIVA?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (a.Email?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (a.City?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false));
            }
            return q;
        }
    }

    private async Task OnSelezionataChanged(Anagrafica? a)
    {
        _selezionata = a;
        if (a is null)
        {
            _selezionataEliminabile = false;
        }
        else
        {
            _selezionataEliminabile = await AnagraficaManager.EEliminabileAsync(a.IdAnagrafica);
        }
    }

    // Classe applicata alla riga selezionata: la colora di giallo tenue
    // (vedi app.css → .anagrafica-riga-selezionata) per dare un feedback
    // visivo immediato di "riga attiva".
    private string RigaClass(Anagrafica a, int _) =>
        _selezionata is not null && _selezionata.IdAnagrafica == a.IdAnagrafica
            ? "anagrafica-riga-selezionata"
            : string.Empty;

    // Doppio click su una riga (Detail >= 2) → apre il dettaglio in modifica.
    // Il primo click ha già impostato la selezione via SelectedItemChanged.
    private async Task OnRowClick(DataGridRowClickEventArgs<Anagrafica> args)
    {
        if (args.MouseEventArgs.Detail >= 2)
        {
            await ApriDialogModifica(args.Item);
        }
    }

    private static Color TipoColor(TipoAnagrafica tipo) => tipo switch
    {
        TipoAnagrafica.Societa      => Color.Primary,
        TipoAnagrafica.Privato      => Color.Default,
        TipoAnagrafica.EntePubblico => Color.Secondary,
        _ => Color.Default,
    };

    // Risoluzione Id→descrizione per le colonne amministrative ("—" se assente
    // o non più presente nel catalogo).
    private string RisolviPagamento(Guid? id) => id is Guid g && _pagamentoDesc.TryGetValue(g, out var v) ? v : "—";
    private string RisolviBanca(Guid? id) => id is Guid g && _bancaDesc.TryGetValue(g, out var v) ? v : "—";
    private string RisolviIva(Guid? id) => id is Guid g && _ivaDesc.TryGetValue(g, out var v) ? v : "—";

    // Export CSV della vista filtrata corrente (stesse colonne visibili in griglia,
    // esclusa quella delle azioni). Riusa CsvExport (BOM + anti-injection) e il JS
    // globale icmDownloadFile. Tutti i record sono già in memoria: esporta l'intero
    // risultato del filtro, non solo la parte renderizzata.
    private async Task EsportaCsvAsync()
    {
        var dati = AnagraficheFiltrate.ToList();
        if (dati.Count == 0)
        {
            Snackbar.Add("Nessuna anagrafica da esportare.", MudBlazor.Severity.Info);
            return;
        }

        _esportazioneInCorso = true;
        try
        {
            var intestazioni = new[]
            {
                "Ragione sociale", "Tipo", "P.IVA / CF", "Città", "Prov.", "Paese",
                "Email", "Telefono", "Pagamento", "Banca", "Cod. IVA",
            };
            var righe = dati.Select(a => (IReadOnlyList<string?>)new string?[]
            {
                a.RagioneSociale,
                a.TipoAnagrafica.Descrizione(),
                a.PIVA,
                a.City,
                a.Provincia,
                a.SiglaPaese,
                a.Email,
                a.Telefono,
                RisolviPagamento(a.IdPag),
                RisolviBanca(a.IdBancaAppoggio),
                RisolviIva(a.IdCodiciIVA),
            });

            var bytes = CsvExport.Genera(intestazioni, righe);
            var nomeFile = $"Anagrafiche_{DateTime.Now:yyyyMMdd_HHmm}.csv";
            await JS.InvokeVoidAsync("icmDownloadFile", nomeFile, Convert.ToBase64String(bytes), "text/csv");
            Snackbar.Add($"Esportate {dati.Count} anagrafiche.", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex, "Esportazione CSV anagrafiche fallita.", "Anagrafiche.EsportaCsvAsync");
            Snackbar.Add("Errore durante l'esportazione CSV.", MudBlazor.Severity.Error);
        }
        finally { _esportazioneInCorso = false; }
    }

    private async Task ApriDialogAggiungi()
    {
        var parameters = new DialogParameters<AnagraficaFormDialog>
        {
            { x => x.Iniziale, null },
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true,
        };
        var dialog = await DialogService.ShowAsync<AnagraficaFormDialog>("Aggiungi anagrafica", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            Snackbar.Add("Anagrafica creata.", MudBlazor.Severity.Success);
            await RicaricaAsync();
        }
    }

    private async Task ApriDialogModifica(Anagrafica? a)
    {
        if (a is null) return;
        var parameters = new DialogParameters<AnagraficaFormDialog>
        {
            { x => x.Iniziale, a },
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true,
        };
        var dialog = await DialogService.ShowAsync<AnagraficaFormDialog>("Modifica anagrafica", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            Snackbar.Add("Anagrafica aggiornata.", MudBlazor.Severity.Success);
            await RicaricaAsync();
        }
    }

    private async Task ConfermaEdElimina(Anagrafica? a)
    {
        if (a is null) return;
        var parameters = new DialogParameters<ConfermaEliminazioneDialog>
        {
            { x => x.Titolo, "Eliminare anagrafica?" },
            { x => x.NomeElemento, a.RagioneSociale },
            { x => x.Messaggio, "Verrà disattivata e non comparirà più nell'elenco. L'operazione è reversibile dall'amministratore." },
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
            CloseOnEscapeKey = true,
        };
        var dialog = await DialogService.ShowAsync<ConfermaEliminazioneDialog>(string.Empty, parameters, options);
        var risultato = await dialog.Result;
        if (risultato is not { Canceled: false }) return;

        try
        {
            await AnagraficaManager.EliminaAsync(a.IdAnagrafica);
            Snackbar.Add("Anagrafica eliminata.", MudBlazor.Severity.Success);
            if (_selezionata is not null && _selezionata.IdAnagrafica == a.IdAnagrafica)
            {
                _selezionata = null;
            }
            await RicaricaAsync();
        }
        catch (AnagraficaConDipendenzeException)
        {
            Snackbar.Add("Impossibile eliminare: esistono entità collegate.", MudBlazor.Severity.Warning);
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex,
                "Eliminazione/disattivazione dell'anagrafica fallita.", "Anagrafiche.ConfermaEdElimina");
            Snackbar.Add("Errore durante l'eliminazione.", MudBlazor.Severity.Error);
        }
    }
}
