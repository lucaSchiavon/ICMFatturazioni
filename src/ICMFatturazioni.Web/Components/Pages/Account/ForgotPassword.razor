@*
    Pagina /forgot-password — "password dimenticata": l'utente inserisce
    l'email e, se corrisponde a un account attivo, riceve un link di reset.
    Static-rendered: il form POSTa a /auth/forgot-password (rate-limited). La
    risposta è sempre neutra (niente enumeration degli account).
*@

@page "/forgot-password"
@layout EmptyLayout
@attribute [AllowAnonymous]

@using Microsoft.AspNetCore.Authorization
@using ICMFatturazioni.Web.Components.Account
@using ICMFatturazioni.Web.Components.Layout

<PageTitle>Password dimenticata · ICM Fatturazioni</PageTitle>

<AuthShell Sottotitolo="Recupera l'accesso al tuo account">
    @if (Inviato == 1)
    {
        <div class="auth-info" role="status">
            Se l'indirizzo è associato a un account attivo, ti abbiamo inviato
            un'email con il link per reimpostare la password. Controlla anche lo spam.
        </div>
        <p class="auth-foot"><a href="/login">Torna al login</a></p>
    }
    else
    {
        <form method="post" action="/auth/forgot-password">
            <AntiforgeryToken />

            <label class="auth-label" for="email">Email</label>
            <input id="email" name="Email" type="email" autocomplete="email"
                   class="auth-input" required autofocus />

            <p class="auth-hint">
                Ti invieremo un link per scegliere una nuova password.
            </p>

            <button type="submit" class="auth-button">Invia il link di reset</button>
        </form>
        <p class="auth-foot"><a href="/login">Torna al login</a></p>
    }
</AuthShell>

@code {
    /// <summary><c>1</c> dopo un POST: mostra il messaggio neutro di conferma.</summary>
    [SupplyParameterFromQuery]
    public int Inviato { get; set; }
}
