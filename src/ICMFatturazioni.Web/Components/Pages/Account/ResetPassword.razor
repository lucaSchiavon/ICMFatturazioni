@*
    Pagina /reset-password/{Token} — l'utente sceglie una nuova password dopo
    aver richiesto il reset. Static-rendered: il form POSTa a /auth/reset-password.
*@

@page "/reset-password/{Token}"
@layout EmptyLayout
@attribute [AllowAnonymous]

@using Microsoft.AspNetCore.Authorization
@using ICMFatturazioni.Web.Components.Account
@using ICMFatturazioni.Web.Components.Layout
@using ICMFatturazioni.Web.Authentication
@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Managers
@using ICMFatturazioni.Web.Managers.Interfaces

@inject IUtenteTokenManager TokenManager

<PageTitle>Reimposta password · ICM Fatturazioni</PageTitle>

<AuthShell Sottotitolo="Scegli una nuova password">
    @if (_tokenValido)
    {
        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="auth-error" role="alert">@Error</div>
        }

        <form method="post" action="/auth/reset-password">
            <AntiforgeryToken />
            <input type="hidden" name="Token" value="@Token" />

            <label class="auth-label" for="password">Nuova password</label>
            <input id="password" name="Password" type="password" autocomplete="new-password"
                   class="auth-input" required autofocus />

            <label class="auth-label" for="passwordConfirm">Conferma password</label>
            <input id="passwordConfirm" name="PasswordConfirm" type="password" autocomplete="new-password"
                   class="auth-input" required />

            <p class="auth-hint">@PasswordPolicy.Requisiti</p>

            <button type="submit" class="auth-button">Reimposta la password e accedi</button>
        </form>
    }
    else
    {
        <div class="auth-error" role="alert">@_errore</div>
        <p class="auth-foot"><a href="/forgot-password">Richiedi un nuovo link</a></p>
    }
</AuthShell>

@code {
    [Parameter] public string Token { get; set; } = string.Empty;

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private bool _tokenValido;
    private string? _errore;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await TokenManager.ValidaAsync(Token, UtenteTokenTipo.Reset);
            _tokenValido = true;
        }
        catch (UtenteTokenInvalidoException ex)
        {
            _errore = UtenteTokenMessaggi.Messaggio(ex.Motivo);
        }
    }
}
