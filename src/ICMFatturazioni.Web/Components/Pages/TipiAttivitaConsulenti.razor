@* Pagina /tipi-attivita-consulenti — catalogo tipi attività consulenti (Modulo Attività Consulenti). *@

@page "/tipi-attivita-consulenti"

@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Managers
@using ICMFatturazioni.Web.Managers.Interfaces
@inject ITipoAttivitaConsulenteManager TipoAttivitaConsulenteManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ICMFatturazioni.Web.Managers.Interfaces.ILogManager LogManager

<PageTitle>Tipi attività consulenti · ICM Fatturazioni</PageTitle>

<MudText Typo="Typo.h1" Class="mb-4">Tipi attività consulenti</MudText>

<MudPaper Elevation="0" Class="pa-4 mb-4" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
        <MudTextField @bind-Value="_filtro"
                      Placeholder="Cerca per descrizione…"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Immediate="true" DebounceInterval="200"
                      Style="min-width: 260px; flex: 1;" />

        <MudSpacer />

        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" Ripple="false"
                   OnClick="ApriDialogAggiungi">
            Aggiungi
        </MudButton>

        @if (_selezionato is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Edit" Ripple="false"
                       OnClick="@(() => ApriDialogModifica(_selezionato))">
                Modifica
            </MudButton>

            @if (_selezionatoEliminabile)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Delete" Ripple="false"
                           OnClick="@(() => ConfermaEdElimina(_selezionato))">
                    Elimina
                </MudButton>
            }
        }
    </MudStack>
</MudPaper>

<MudDataGrid T="TipoAttivitaConsulente"
             Items="@TipiFiltrati"
             Dense="true" Hover="true" Striped="false" Bordered="false"
             FixedHeader="true" Height="calc(100vh - 320px)"
             Virtualize="true" ItemSize="40"
             SelectedItem="_selezionato"
             SelectedItemChanged="OnSelezionatoChanged"
             RowClick="@OnRowClick"
             RowClassFunc="@RigaClass"
             Loading="@_caricamento">
    <Columns>
        <PropertyColumn Property="x => x.Descrizione" Title="Descrizione" StickyLeft="true" />
        <TemplateColumn Title="" Sortable="false" Filterable="false" StickyRight="true">
            <CellTemplate>
                <MudTooltip Text="Elimina">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                   Size="Size.Small" Ripple="false"
                                   OnClick="@(() => ConfermaEdElimina(context.Item))" />
                </MudTooltip>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <NoRecordsContent><MudText>Nessun tipo attività consulente trovato.</MudText></NoRecordsContent>
    <LoadingContent><MudText>Caricamento in corso…</MudText></LoadingContent>
</MudDataGrid>

@code {
    private IReadOnlyList<TipoAttivitaConsulente> _tipi = Array.Empty<TipoAttivitaConsulente>();
    private TipoAttivitaConsulente? _selezionato;
    private bool _selezionatoEliminabile;
    private string _filtro = string.Empty;
    private bool _caricamento = true;

    protected override async Task OnInitializedAsync() => await RicaricaAsync();

    private async Task RicaricaAsync()
    {
        _caricamento = true;
        try
        {
            _tipi = await TipoAttivitaConsulenteManager.ElencoAsync();
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex, "Caricamento tipi attività consulenti fallito.", "TipiAttivitaConsulenti.RicaricaAsync");
            Snackbar.Add("Errore nel caricamento dell'elenco.", MudBlazor.Severity.Error);
        }
        finally { _caricamento = false; }
    }

    private IEnumerable<TipoAttivitaConsulente> TipiFiltrati => string.IsNullOrWhiteSpace(_filtro)
        ? _tipi
        : _tipi.Where(t => t.Descrizione.Contains(_filtro.Trim(), StringComparison.OrdinalIgnoreCase));

    private async Task OnSelezionatoChanged(TipoAttivitaConsulente? t)
    {
        _selezionato = t;
        _selezionatoEliminabile = t is not null && await TipoAttivitaConsulenteManager.EEliminabileAsync(t.IdTipoAttivitaConsulente);
    }

    private string RigaClass(TipoAttivitaConsulente t, int _) =>
        _selezionato?.IdTipoAttivitaConsulente == t.IdTipoAttivitaConsulente ? "anagrafica-riga-selezionata" : string.Empty;

    private async Task OnRowClick(DataGridRowClickEventArgs<TipoAttivitaConsulente> args)
    {
        if (args.MouseEventArgs.Detail >= 2) await ApriDialogModifica(args.Item);
    }

    private async Task ApriDialogAggiungi()
    {
        var p = new DialogParameters<TipoAttivitaConsulenteFormDialog> { { x => x.Iniziale, null } };
        var o = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var d = await DialogService.ShowAsync<TipoAttivitaConsulenteFormDialog>("Aggiungi tipo attività consulente", p, o);
        if (await d.Result is { Canceled: false })
        {
            Snackbar.Add("Tipo attività consulente creato.", MudBlazor.Severity.Success);
            await RicaricaAsync();
        }
    }

    private async Task ApriDialogModifica(TipoAttivitaConsulente? t)
    {
        if (t is null) return;
        var p = new DialogParameters<TipoAttivitaConsulenteFormDialog> { { x => x.Iniziale, t } };
        var o = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var d = await DialogService.ShowAsync<TipoAttivitaConsulenteFormDialog>("Modifica tipo attività consulente", p, o);
        if (await d.Result is { Canceled: false })
        {
            Snackbar.Add("Tipo attività consulente aggiornato.", MudBlazor.Severity.Success);
            await RicaricaAsync();
        }
    }

    private async Task ConfermaEdElimina(TipoAttivitaConsulente? t)
    {
        if (t is null) return;
        var p = new DialogParameters<ConfermaEliminazioneDialog>
        {
            { x => x.Titolo, "Eliminare tipo attività consulente?" },
            { x => x.NomeElemento, t.Descrizione },
            { x => x.Messaggio, "Verrà disattivato e non comparirà più nell'elenco." },
        };
        var o = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseOnEscapeKey = true };
        var d = await DialogService.ShowAsync<ConfermaEliminazioneDialog>(string.Empty, p, o);
        if (await d.Result is not { Canceled: false }) return;

        try
        {
            await TipoAttivitaConsulenteManager.EliminaAsync(t.IdTipoAttivitaConsulente);
            Snackbar.Add("Tipo attività consulente eliminato.", MudBlazor.Severity.Success);
            if (_selezionato?.IdTipoAttivitaConsulente == t.IdTipoAttivitaConsulente) _selezionato = null;
            await RicaricaAsync();
        }
        catch (TipoAttivitaConsulenteConDipendenzeException)
        {
            Snackbar.Add("Impossibile eliminare: il tipo è usato da una o più attività consulenti.", MudBlazor.Severity.Warning);
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex, "Eliminazione tipo attività consulente fallita.", "TipiAttivitaConsulenti.ConfermaEdElimina");
            Snackbar.Add("Errore durante l'eliminazione.", MudBlazor.Severity.Error);
        }
    }
}
