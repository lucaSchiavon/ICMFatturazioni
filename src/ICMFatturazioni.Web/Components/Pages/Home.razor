@*
    Landing autenticata. Reindirizza alla dashboard di sintesi (/dashboard),
    che è il nuovo entry-point dell'app dopo il login.
*@
@page "/"
@inject NavigationManager Nav

<PageTitle>ICM Fatturazioni</PageTitle>

@code {
    protected override void OnInitialized()
    {
        Nav.NavigateTo("/dashboard", replace: true);
    }
}
