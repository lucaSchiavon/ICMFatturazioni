@*
    Landing autenticata. Per la Fase 1 reindirizza all'unica sezione
    attiva (/tabelle-amministrative). In fasi successive evolverà in una
    dashboard di sintesi.
*@
@page "/"
@inject NavigationManager Nav

<PageTitle>ICM Fatturazioni</PageTitle>

@code {
    protected override void OnInitialized()
    {
        Nav.NavigateTo("/tabelle-amministrative", replace: true);
    }
}
