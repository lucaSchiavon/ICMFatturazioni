@*
    Pagina /spese-anticipate — Gestione spese anticipate clienti (dispensa cap. 2).

    Stesso layout Access-like a tre selettori di GestAttivitaStudio:
      [Anagrafica] [Tipo Attività] [Attività esistenti]
    Selezionata un'attività si carica la sua testata (read-only) e l'elenco delle
    spese sostenute (Data, Descrizione, Importo), con inserimento/modifica/elimina.
    Le spese verranno poi recuperate in fase di Avviso di fattura (art. 15 D.P.R. 633).
*@

@page "/spese-anticipate"

@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Managers
@using ICMFatturazioni.Web.Managers.Interfaces
@using System.Globalization

@inject ISpesaAnticipataManager SpesaAnticipataManager
@inject IAttivitaManager AttivitaManager
@inject IAnagraficaManager AnagraficaManager
@inject ITipoAttivitaManager TipoAttivitaManager
@inject ISnackbar Snackbar
@inject ICMFatturazioni.Web.Managers.Interfaces.ILogManager LogManager
@inject NavigationManager Nav

<PageTitle>Gestione spese anticipate · ICM Fatturazioni</PageTitle>

<MudText Typo="Typo.h1" Class="mb-4">Gestione spese anticipate clienti</MudText>

@* ═══════════════════════════════════════════════════════════════════
   Riga dei tre selettori
   ═══════════════════════════════════════════════════════════════════ *@
<MudGrid Spacing="2" Class="icm-grid-3col mb-0">

    @* ── Col 1: Anagrafica ──────────────────────────────────────── *@
    <MudItem xs="12" md="4" Style="display:flex;flex-direction:column;">
        <MudPaper Elevation="0" Outlined="true" Class="pa-3"
                  Style="display:flex;flex-direction:column;flex:1;">

            <MudText Typo="Typo.overline" Class="mb-2" Style="font-weight:700;">Anagrafica</MudText>

            <MudRadioGroup T="FiltroTipo" Value="_filtroTipo" ValueChanged="OnFiltroTipoChanged" Class="mb-1">
                <MudStack Row="true" Spacing="0" Wrap="Wrap.Wrap">
                    <MudRadio T="FiltroTipo" Value="FiltroTipo.Tutti"   Dense="true" Size="Size.Small">Tutti</MudRadio>
                    <MudRadio T="FiltroTipo" Value="FiltroTipo.Enti"    Dense="true" Size="Size.Small">Enti</MudRadio>
                    <MudRadio T="FiltroTipo" Value="FiltroTipo.Societa" Dense="true" Size="Size.Small">Soc.</MudRadio>
                    <MudRadio T="FiltroTipo" Value="FiltroTipo.Privati" Dense="true" Size="Size.Small">Privati</MudRadio>
                </MudStack>
            </MudRadioGroup>

            <MudTextField @bind-Value="_filtroRagioneSociale"
                          Placeholder="Filtra per ragione sociale…"
                          Immediate="true" DebounceInterval="150"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Clear"
                          OnAdornmentClick="@(() => _filtroRagioneSociale = string.Empty)"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Class="mb-2" />

            <div class="icm-sellist mb-3" style="height:240px;">
                @if (_caricamentoAnagrafica)
                {
                    <div class="icm-sellist-placeholder">Caricamento…</div>
                }
                else if (!AnagraficheFiltrate.Any())
                {
                    <div class="icm-sellist-placeholder">Nessun cliente trovato.</div>
                }
                else
                {
                    @foreach (var a in AnagraficheFiltrate)
                    {
                        <div class="icm-sellist-item @(a.IdAnagrafica == _anagraficaSelezionata?.IdAnagrafica ? "selected" : "")"
                             @onclick="@(() => SelezionaAnagraficaAsync(a))">
                            <span class="icm-tipo-badge">@a.TipoAnagrafica.ToDbCode()</span>@a.RagioneSociale
                        </div>
                    }
                }
            </div>

            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.People" Ripple="false" Size="Size.Small"
                       OnClick="@(() => Nav.NavigateTo("/anagrafiche"))">
                Gestione anagrafiche
            </MudButton>
        </MudPaper>
    </MudItem>

    @* ── Col 2: Tipo Attività ─────────────────────────────────── *@
    <MudItem xs="12" md="4" Style="display:flex;flex-direction:column;">
        <MudPaper Elevation="0" Outlined="true" Class="pa-3"
                  Style="display:flex;flex-direction:column;flex:1;">

            <MudText Typo="Typo.overline" Class="mb-2" Style="font-weight:700;">Tipo Attività</MudText>

            <div class="icm-sellist" style="height:240px;">
                @if (_caricamentoTipi)
                {
                    <div class="icm-sellist-placeholder">Caricamento…</div>
                }
                else if (!_tipiAttivita.Any())
                {
                    <div class="icm-sellist-placeholder">Nessun tipo attività configurato.</div>
                }
                else
                {
                    @foreach (var t in _tipiAttivita)
                    {
                        <div class="icm-sellist-item @(t.IdTipoAttivita == _tipoSelezionato?.IdTipoAttivita ? "selected" : "")"
                             @onclick="@(() => SelezionaTipoAsync(t))">
                            @t.Descrizione
                        </div>
                    }
                }
            </div>
        </MudPaper>
    </MudItem>

    @* ── Col 3: Attività esistenti ────────────────────────────── *@
    <MudItem xs="12" md="4" Style="display:flex;flex-direction:column;">
        <MudPaper Elevation="0" Outlined="true" Class="pa-3"
                  Style="display:flex;flex-direction:column;flex:1;">

            <MudText Typo="Typo.overline" Class="mb-2" Style="font-weight:700;">Attività esistenti</MudText>

            <div class="icm-sellist" style="height:240px;">
                @if (_anagraficaSelezionata is null || _tipoSelezionato is null)
                {
                    <div class="icm-sellist-placeholder">Selezionare un cliente e un tipo.</div>
                }
                else if (_caricamentoAttivita)
                {
                    <div class="icm-sellist-placeholder">Caricamento…</div>
                }
                else if (!_attivitaLista.Any())
                {
                    <div class="icm-sellist-placeholder">Nessuna attività per questa selezione.</div>
                }
                else
                {
                    @foreach (var a in _attivitaLista)
                    {
                        <div class="icm-sellist-item icm-sellist-item-2col @(a.IdAttivita == _attivitaSelezionata?.IdAttivita ? "selected" : "")"
                             @onclick="@(() => SelezionaAttivitaAsync(a))">
                            <span class="icm-nr">@a.Numero</span>
                            <span class="icm-desc">@a.Descrizione</span>
                        </div>
                    }
                }
            </div>
        </MudPaper>
    </MudItem>

</MudGrid>

@* ═══════════════════════════════════════════════════════════════════
   Pannello spese — visibile quando un'attività è selezionata
   ═══════════════════════════════════════════════════════════════════ *@
@if (_attivitaSelezionata is not null)
{
    <MudPaper Elevation="0" Outlined="true" Class="pa-4 mt-3">

        @* Testata attività (sola lettura) *@
        <div class="d-flex align-center flex-wrap gap-2 mb-1">
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Size="Size.Small" Class="ma-0">
                @_attivitaSelezionata.Numero
            </MudChip>
            <MudText Typo="Typo.h6" Class="ma-0">@_attivitaSelezionata.Descrizione</MudText>
        </div>
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
            Cliente: @_anagraficaSelezionata?.RagioneSociale
        </MudText>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle1" Class="mb-2" Style="font-weight:700;">Spese anticipate</MudText>

        @* Form inserimento/modifica spesa *@
        <MudPaper Elevation="0" Class="mud-background-gray rounded pa-3 mb-3">
            <MudText Typo="Typo.caption" Class="mb-2">
                @(_spesaInModifica is null ? "Nuova spesa" : "Modifica spesa")
            </MudText>
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="3">
                    <MudDatePicker Label="Data *"
                                   Date="_fData"
                                   DateChanged="@(d => _fData = d)"
                                   DateFormat="dd/MM/yyyy"
                                   Culture="_itCulture"
                                   Editable="true"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_fDescrizione"
                                  Label="Descrizione *"
                                  MaxLength="200"
                                  Immediate="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudNumericField T="decimal" @bind-Value="_fImporto"
                                     Label="Importo € *"
                                     Min="0.01m" Format="N2" Culture="_itCulture"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>
            @if (!string.IsNullOrWhiteSpace(_erroreFormSpesa))
            {
                <MudAlert Severity="MudBlazor.Severity.Error" Dense="true" Class="mt-2">@_erroreFormSpesa</MudAlert>
            }
            <div class="d-flex justify-end gap-2 mt-2">
                @if (_spesaInModifica is not null)
                {
                    <MudButton Size="Size.Small" Ripple="false"
                               StartIcon="@Icons.Material.Filled.Cancel"
                               OnClick="ResetFormSpesa">
                        Annulla modifica
                    </MudButton>
                }
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Ripple="false"
                           StartIcon="@(_spesaInModifica is null ? Icons.Material.Filled.Add : Icons.Material.Filled.Save)"
                           Disabled="_salvataggioSpesa"
                           OnClick="SalvaSpesaAsync">
                    @(_salvataggioSpesa ? "Salvataggio…"
                      : _spesaInModifica is null ? "Aggiungi spesa" : "Salva")
                </MudButton>
            </div>
        </MudPaper>

        @* Griglia spese *@
        @if (_caricamentoSpese)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
        }
        else if (_spese.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="py-3 text-center">
                Nessuna spesa anticipata per questa attività.
            </MudText>
        }
        else
        {
            @* ── Vista tabella: tablet e desktop (≥ 600px) ──────────── *@
            <div class="icm-solo-desktop" style="overflow-x:auto;">
                <MudTable Items="_spese" Dense="true" Striped="true" Hover="true" Style="min-width:520px;">
                    <HeaderContent>
                        <MudTh>Data</MudTh>
                        <MudTh>Descrizione</MudTh>
                        <MudTh Style="text-align:right;">Importo €</MudTh>
                        <MudTh Style="width:80px;"></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Data.ToString("dd/MM/yyyy")</MudTd>
                        <MudTd>@context.Descrizione</MudTd>
                        <MudTd Style="text-align:right;font-weight:600;">@context.Importo.ToString("N2", _itCulture)</MudTd>
                        <MudTd Style="padding:2px 4px;">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small" Ripple="false"
                                           OnClick="@(() => AvviaModificaSpesa(context))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small" Ripple="false" Color="Color.Error"
                                           OnClick="@(() => EliminaSpesaAsync(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </div>

            @* ── Vista card: solo smartphone (< 600px) ──────────────── *@
            <div class="icm-solo-mobile">
                @foreach (var item in _spese)
                {
                    <MudPaper Elevation="0" Outlined="true" Class="pa-2 mb-2">
                        <div class="d-flex justify-space-between align-center mb-1">
                            <MudText Typo="Typo.caption">@item.Data.ToString("dd/MM/yyyy")</MudText>
                            <MudText Typo="Typo.subtitle2" Style="font-weight:700;">
                                @item.Importo.ToString("N2", _itCulture) €
                            </MudText>
                        </div>
                        <MudText Typo="Typo.body2" Style="font-weight:600;" Class="mb-1">@item.Descrizione</MudText>
                        <div class="d-flex justify-end">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small" Ripple="false"
                                           OnClick="@(() => AvviaModificaSpesa(item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small" Ripple="false" Color="Color.Error"
                                           OnClick="@(() => EliminaSpesaAsync(item))" />
                        </div>
                    </MudPaper>
                }
            </div>

            <div class="d-flex justify-end mt-2">
                <MudText Typo="Typo.subtitle2">
                    Totale:
                    <strong>@_spese.Sum(s => s.Importo).ToString("N2", _itCulture) €</strong>
                </MudText>
            </div>
        }
    </MudPaper>
}

@code {
    private enum FiltroTipo { Tutti, Enti, Societa, Privati }

    private static readonly CultureInfo _itCulture = CultureInfo.GetCultureInfo("it-IT");

    // Dati caricati
    private IReadOnlyList<Anagrafica>   _anagrafiche   = Array.Empty<Anagrafica>();
    private IReadOnlyList<TipoAttivita> _tipiAttivita  = Array.Empty<TipoAttivita>();
    private IReadOnlyList<Attivita>     _attivitaLista = Array.Empty<Attivita>();
    private IReadOnlyList<SpesaAnticipata> _spese      = Array.Empty<SpesaAnticipata>();

    // Selezioni correnti
    private Anagrafica?   _anagraficaSelezionata;
    private TipoAttivita? _tipoSelezionato;
    private Attivita?     _attivitaSelezionata;

    // Stato caricamento
    private bool _caricamentoAnagrafica = true;
    private bool _caricamentoTipi       = true;
    private bool _caricamentoAttivita   = false;
    private bool _caricamentoSpese       = false;

    // Filtro anagrafiche
    private FiltroTipo _filtroTipo           = FiltroTipo.Tutti;
    private string     _filtroRagioneSociale = string.Empty;

    // Form spesa
    private DateTime?       _fData;
    private string          _fDescrizione   = string.Empty;
    private decimal         _fImporto;
    private SpesaAnticipata? _spesaInModifica;
    private bool            _salvataggioSpesa;
    private string          _erroreFormSpesa = string.Empty;

    // Computed: anagrafiche filtrate
    private IEnumerable<Anagrafica> AnagraficheFiltrate
    {
        get
        {
            var q = _anagrafiche.AsEnumerable();
            q = _filtroTipo switch
            {
                FiltroTipo.Enti    => q.Where(a => a.TipoAnagrafica == TipoAnagrafica.EntePubblico),
                FiltroTipo.Societa => q.Where(a => a.TipoAnagrafica == TipoAnagrafica.Societa),
                FiltroTipo.Privati => q.Where(a => a.TipoAnagrafica == TipoAnagrafica.Privato),
                _                 => q,
            };
            if (!string.IsNullOrWhiteSpace(_filtroRagioneSociale))
                q = q.Where(a => a.RagioneSociale.Contains(
                    _filtroRagioneSociale.Trim(), StringComparison.OrdinalIgnoreCase));
            return q;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var t1 = AnagraficaManager.ElencoAsync();
        var t2 = TipoAttivitaManager.ElencoAsync();
        await Task.WhenAll(t1, t2);
        _anagrafiche  = t1.Result;
        _tipiAttivita = t2.Result;
        _caricamentoAnagrafica = false;
        _caricamentoTipi       = false;
    }

    private Task SelezionaAnagraficaAsync(Anagrafica a)
    {
        if (_anagraficaSelezionata?.IdAnagrafica == a.IdAnagrafica) return Task.CompletedTask;
        _anagraficaSelezionata = a;
        _tipoSelezionato       = null;
        _attivitaSelezionata   = null;
        _attivitaLista         = Array.Empty<Attivita>();
        _spese                 = Array.Empty<SpesaAnticipata>();
        ResetFormSpesa();
        return Task.CompletedTask;
    }

    private async Task SelezionaTipoAsync(TipoAttivita t)
    {
        if (_tipoSelezionato?.IdTipoAttivita == t.IdTipoAttivita) return;
        _tipoSelezionato     = t;
        _attivitaSelezionata = null;
        _spese               = Array.Empty<SpesaAnticipata>();
        ResetFormSpesa();
        if (_anagraficaSelezionata is not null)
            await CaricaAttivitaAsync();
        else
            _attivitaLista = Array.Empty<Attivita>();
    }

    private async Task CaricaAttivitaAsync()
    {
        if (_anagraficaSelezionata is null || _tipoSelezionato is null) return;
        _caricamentoAttivita = true;
        try
        {
            _attivitaLista = await AttivitaManager.ElencoPerAnagraficaTipoAsync(
                _anagraficaSelezionata.IdAnagrafica,
                _tipoSelezionato.IdTipoAttivita);
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex,
                "Caricamento attività fallito.", "SpeseAnticipate.CaricaAttivitaAsync");
            Snackbar.Add("Errore nel caricamento delle attività.", MudBlazor.Severity.Error);
        }
        finally { _caricamentoAttivita = false; }
    }

    private async Task SelezionaAttivitaAsync(Attivita a)
    {
        _attivitaSelezionata = a;
        ResetFormSpesa();
        await CaricaSpeseAsync();
    }

    private async Task CaricaSpeseAsync()
    {
        if (_attivitaSelezionata is null) return;
        _caricamentoSpese = true;
        try
        {
            _spese = await SpesaAnticipataManager.ElencoPerAttivitaAsync(_attivitaSelezionata.IdAttivita);
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex,
                "Caricamento spese anticipate fallito.", "SpeseAnticipate.CaricaSpeseAsync");
            Snackbar.Add("Errore nel caricamento delle spese.", MudBlazor.Severity.Error);
        }
        finally { _caricamentoSpese = false; }
    }

    private void OnFiltroTipoChanged(FiltroTipo nuovo)
    {
        _filtroTipo = nuovo;
        if (_anagraficaSelezionata is not null
            && !AnagraficheFiltrate.Any(a => a.IdAnagrafica == _anagraficaSelezionata.IdAnagrafica))
        {
            _anagraficaSelezionata = null;
            _tipoSelezionato       = null;
            _attivitaSelezionata   = null;
            _attivitaLista         = Array.Empty<Attivita>();
            _spese                 = Array.Empty<SpesaAnticipata>();
            ResetFormSpesa();
        }
    }

    // ─── Form spesa ──────────────────────────────────────────────────────
    private void AvviaModificaSpesa(SpesaAnticipata s)
    {
        _spesaInModifica = s;
        _fData           = s.Data.ToDateTime(TimeOnly.MinValue);
        _fDescrizione    = s.Descrizione;
        _fImporto        = s.Importo;
        _erroreFormSpesa = string.Empty;
    }

    private void ResetFormSpesa()
    {
        _spesaInModifica = null;
        _fData           = DateTime.Today;
        _fDescrizione    = string.Empty;
        _fImporto        = 0m;
        _erroreFormSpesa = string.Empty;
    }

    private async Task SalvaSpesaAsync()
    {
        if (_attivitaSelezionata is null) return;
        _erroreFormSpesa = string.Empty;

        if (!_fData.HasValue)
        {
            _erroreFormSpesa = "La data della spesa è obbligatoria.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_fDescrizione))
        {
            _erroreFormSpesa = "La descrizione è obbligatoria.";
            return;
        }
        if (_fImporto <= 0)
        {
            _erroreFormSpesa = "L'importo deve essere maggiore di zero.";
            return;
        }

        _salvataggioSpesa = true;
        try
        {
            if (_spesaInModifica is null)
            {
                var nuova = new SpesaAnticipata
                {
                    IdAttivita  = _attivitaSelezionata.IdAttivita,
                    Data        = DateOnly.FromDateTime(_fData.Value),
                    Descrizione = _fDescrizione.Trim(),
                    Importo     = _fImporto,
                };
                await SpesaAnticipataManager.CreaAsync(nuova);
                Snackbar.Add("Spesa aggiunta.", MudBlazor.Severity.Success);
            }
            else
            {
                var aggiornata = new SpesaAnticipata
                {
                    IdSpesaAnticipata = _spesaInModifica.IdSpesaAnticipata,
                    IdAttivita        = _spesaInModifica.IdAttivita,
                    Data              = DateOnly.FromDateTime(_fData.Value),
                    Descrizione       = _fDescrizione.Trim(),
                    Importo           = _fImporto,
                    IsAttivo          = true,
                };
                await SpesaAnticipataManager.AggiornaAsync(aggiornata);
                Snackbar.Add("Spesa aggiornata.", MudBlazor.Severity.Success);
            }

            ResetFormSpesa();
            await CaricaSpeseAsync();
        }
        catch (SpesaAnticipataInvalidaException ex)
        {
            _erroreFormSpesa = ex.Message;
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex,
                "Salvataggio spesa anticipata fallito.", "SpeseAnticipate.SalvaSpesaAsync");
            _erroreFormSpesa = "Errore durante il salvataggio. Riprovare.";
        }
        finally { _salvataggioSpesa = false; }
    }

    private async Task EliminaSpesaAsync(SpesaAnticipata s)
    {
        try
        {
            await SpesaAnticipataManager.EliminaAsync(s.IdSpesaAnticipata);
            Snackbar.Add("Spesa eliminata.", MudBlazor.Severity.Success);
            if (_spesaInModifica?.IdSpesaAnticipata == s.IdSpesaAnticipata)
                ResetFormSpesa();
            await CaricaSpeseAsync();
        }
        catch (Exception ex)
        {
            await LogManager.LogErroreAsync(ex,
                "Eliminazione spesa anticipata fallita.", "SpeseAnticipate.EliminaSpesaAsync");
            Snackbar.Add("Errore durante l'eliminazione.", MudBlazor.Severity.Error);
        }
    }
}
