@page "/not-found"
@attribute [AllowAnonymous]

<PageTitle>Pagina non trovata</PageTitle>

<MudPaper Elevation="0" Class="pa-8 mt-8" Style="max-width: 480px; margin: 0 auto;">
    <MudText Typo="Typo.h1" Class="mb-2">404</MudText>
    <MudText Typo="Typo.h2" Class="mb-4">Pagina non trovata</MudText>
    <MudText Typo="Typo.body1" Class="mb-4">
        La risorsa richiesta non esiste o è stata spostata.
    </MudText>
    <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Ripple="false">
        Torna alla home
    </MudButton>
</MudPaper>
