@*
    Component: IcmErrorBoundary
    ---------------------------
    Estende il comportamento dello standard <ErrorBoundary> di Blazor:
    cattura le eccezioni dei componenti figli, le logga via ILogManager
    e mostra un fallback discreto in chiave brand (alert MudBlazor).

    Va innestato nel MainLayout intorno al @Body, in modo che ogni
    pagina lo erediti. Per casi specifici (es. dialog isolato) è
    possibile annidare un secondo IcmErrorBoundary più stretto.
*@

@inherits ErrorBoundary
@inject ICMFatturazioni.Web.Managers.Interfaces.ILogManager LogManager

@if (CurrentException is null)
{
    @ChildContent
}
else
{
    <MudAlert Severity="MudBlazor.Severity.Error" Variant="Variant.Outlined" Class="my-4">
        Si è verificato un errore durante la visualizzazione di questa sezione.
        L'errore è stato registrato; riprovare ricaricando la pagina o
        contattare l'amministratore di sistema.
    </MudAlert>
}

@code {
    // Hook ufficiale di ErrorBoundary: viene invocato per ogni eccezione
    // catturata dai componenti discendenti. La registriamo esplicitamente via
    // ILogManager (path "ricco"): l'ErrorBoundary intercetta l'errore prima che
    // raggiunga il logging del framework, quindi senza questa chiamata non
    // finirebbe in fatt.Log.
    protected override async Task OnErrorAsync(Exception exception)
    {
        await LogManager.LogErroreAsync(
            exception,
            "Eccezione catturata dall'ErrorBoundary durante il rendering di un componente. " +
            "All'utente è stata mostrata la UI di fallback.",
            "Blazor.IcmErrorBoundary");
    }
}
