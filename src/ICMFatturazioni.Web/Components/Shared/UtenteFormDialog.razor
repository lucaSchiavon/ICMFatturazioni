@*
    Dialog Utente — usato per "Nuovo" e "Modifica" (allineato a ICMVerbali).
    - Nuovo (Iniziale null): Username, Email (OBBLIGATORIA) e Ruolo. NESSUNA
      password: l'utente nasce sempre "invitato" (senza password) e riceve via
      email un link di attivazione con cui sceglie LUI la propria password. Così
      nessun altro — admin compreso — conosce mai la password dell'utente.
    - Modifica: Username, Email, Ruolo, Attivo. La password non si tocca: per
      cambiarla si usa l'azione "Invia link" (reset via email) dalla lista.
    Il dropdown ruoli è già filtrato dal chiamante (es. niente Superadmin per
    un Admin).
*@
@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Managers
@using ICMFatturazioni.Web.Managers.Interfaces
@using ICMFatturazioni.Web.Models
@inject IUtenteManager UtenteManager
@inject ICMFatturazioni.Web.Managers.Interfaces.ILogManager LogManager

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_model" @bind-IsValid="_isValid">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Username"
                                  Label="Username *"
                                  Required="true"
                                  RequiredError="Username obbligatorio"
                                  MaxLength="80"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Class="campo-obbligatorio" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid"
                               Label="Ruolo *"
                               @bind-Value="_model.IdRuolo"
                               Required="true"
                               RequiredError="Ruolo obbligatorio"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="campo-obbligatorio">
                        @foreach (var r in Ruoli)
                        {
                            <MudSelectItem Value="@r.IdRuolo">@r.Nome</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="@(IsModifica ? 6 : 12)">
                    @* Email obbligatoria in creazione: è il canale per il link di
                       attivazione. In modifica resta facoltativa (non si reinvita). *@
                    <MudTextField @bind-Value="_model.Email"
                                  Label="@(IsModifica ? "Email" : "Email *")"
                                  InputType="InputType.Email"
                                  Required="@(!IsModifica)"
                                  RequiredError="Email obbligatoria"
                                  MaxLength="256"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Class="@(IsModifica ? null : "campo-obbligatorio")"
                                  HelperText="Serve per l'attivazione dell'account e per il reset password" />
                </MudItem>

                @if (IsModifica)
                {
                    <MudItem xs="12" sm="6" Class="d-flex align-center">
                        <MudCheckBox @bind-Value="_model.Attivo" Label="Attivo" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudAlert Severity="MudBlazor.Severity.Info" Dense="true" Variant="Variant.Outlined">
                            Per cambiare la password usa «Invia link» dalla lista utenti:
                            la reimposta l'utente stesso tramite email.
                        </MudAlert>
                    </MudItem>
                }
                else
                {
                    <MudItem xs="12">
                        <MudAlert Severity="MudBlazor.Severity.Info" Dense="true" Variant="Variant.Outlined">
                            Non serve impostare una password: l'utente riceverà via email un
                            link per attivare l'account e scegliere la propria password.
                        </MudAlert>
                    </MudItem>
                }
            </MudGrid>

            @if (!string.IsNullOrEmpty(_erroreServer))
            {
                <MudAlert Severity="MudBlazor.Severity.Error" Class="mt-3" Variant="Variant.Outlined">
                    @_erroreServer
                </MudAlert>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Annulla" Ripple="false">Annulla</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="Salva" Disabled="@(!_isValid || _salvataggio)" Ripple="false">
            @if (_salvataggio)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            @(IsModifica ? "Salva" : "Crea e invia link")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    /// <summary>Utente da modificare; null = creazione.</summary>
    [Parameter] public UtenteConRuolo? Iniziale { get; set; }

    /// <summary>Ruoli selezionabili (già filtrati dal chiamante).</summary>
    [Parameter] public IReadOnlyList<Ruolo> Ruoli { get; set; } = Array.Empty<Ruolo>();

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm _form = default!;
    private FormModel _model = new();
    private bool _isValid;
    private bool _salvataggio;
    private string? _erroreServer;

    private bool IsModifica => Iniziale is not null;

    protected override void OnInitialized()
    {
        if (Iniziale is not null)
        {
            _model = new FormModel
            {
                Username = Iniziale.Username,
                Email = Iniziale.Email,
                IdRuolo = Iniziale.IdRuolo,
                Attivo = Iniziale.Attivo,
            };
        }
        else if (Ruoli.Count > 0)
        {
            _model.IdRuolo = Ruoli[0].IdRuolo;
        }
    }

    private void Annulla() => MudDialog.Cancel();

    private async Task Salva()
    {
        _erroreServer = null;
        await _form.ValidateAsync();
        if (!_isValid) return;

        _salvataggio = true;
        try
        {
            if (IsModifica)
            {
                await UtenteManager.AggiornaAsync(Iniziale!.IdUtente, _model.Username, _model.Email, _model.IdRuolo, _model.Attivo);
                MudDialog.Close(DialogResult.Ok<Guid?>(null));
            }
            else
            {
                // Crea SEMPRE invitato (password null): la sceglierà l'utente dal
                // link. Ritorna l'IdUtente così il chiamante invia subito il link.
                var idNuovo = await UtenteManager.CreaAsync(_model.Username, password: null, _model.Email, _model.IdRuolo);
                MudDialog.Close(DialogResult.Ok<Guid?>(idNuovo));
            }
        }
        catch (UtenteDuplicatoException ex)
        {
            _erroreServer = ex.Message;
        }
        catch (ArgumentException ex)
        {
            _erroreServer = ex.Message;
        }
        catch (Exception ex)
        {
            _erroreServer = "Errore durante il salvataggio. Riprovare o contattare l'amministratore.";
            await LogManager.LogErroreAsync(ex,
                "Salvataggio dell'utente fallito per un errore imprevisto.", "UtenteFormDialog.Salva");
        }
        finally
        {
            _salvataggio = false;
        }
    }

    private sealed class FormModel
    {
        public string Username { get; set; } = string.Empty;
        public string? Email { get; set; }
        public Guid IdRuolo { get; set; }
        public bool Attivo { get; set; } = true;
    }
}
