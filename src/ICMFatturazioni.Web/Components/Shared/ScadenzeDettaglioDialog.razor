@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Managers
@using ICMFatturazioni.Web.Managers.Interfaces
@using System.Globalization
@inject IScadenzaPagamentoManager ScadenzaPagamentoManager
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.EventNote" Class="mr-2" />
            Scadenze — @Dettaglio.DescrizioneDettaglio
        </MudText>
    </TitleContent>
    <DialogContent>
        @* Avviso riga fatturata *@
        @if (Dettaglio.HasFattura)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-3">
                Questa riga è collegata a una fattura emessa. Le scadenze sono in sola lettura.
            </MudAlert>
        }

        @* Riepilogo importo riga vs totale schedulato *@
        <div class="d-flex align-center justify-space-between mb-3">
            <div>
                <MudText Typo="Typo.caption">Importo riga</MudText>
                <MudText Typo="Typo.subtitle1">
                    <strong>@Dettaglio.Importo.ToString("N2", _itCulture) €</strong>
                </MudText>
            </div>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Default" />
            <div>
                <MudText Typo="Typo.caption">Schedulato</MudText>
                <MudText Typo="Typo.subtitle1" Color="@(_sbilanciato ? Color.Warning : Color.Success)">
                    <strong>@_totaleScadenzato.ToString("N2", _itCulture) €</strong>
                </MudText>
            </div>
            @if (_sbilanciato)
            {
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
                <MudText Typo="Typo.caption" Color="Color.Warning">
                    Differenza: @Math.Abs(Dettaglio.Importo - _totaleScadenzato).ToString("N2", _itCulture) €
                </MudText>
            }
        </div>

        <MudDivider Class="mb-3" />

        @* Le scadenze dovrebbero ripartire l'intero importo del dettaglio, ma la
           ripartizione parziale è ammessa: il residuo resta gestito a valle (avviso). *@
        @if (!Dettaglio.HasFattura && _sbilanciato)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                Schedula l'intero importo del dettaglio (@Dettaglio.Importo.ToString("N2", _itCulture) €)
                con una o più scadenze. Residuo da schedulare:
                <strong>@_residuo.ToString("N2", _itCulture) €</strong>.
                Puoi comunque chiudere: le scadenze già inserite <strong>restano salvate</strong>.
            </MudAlert>
        }

        @* Form inserimento/modifica scadenza — nascosto quando l'importo è già
           interamente schedulato e non si sta modificando una scadenza esistente. *@
        @if (!Dettaglio.HasFattura && (_sbilanciato || _scadenzaInModifica is not null))
        {
            <MudPaper Elevation="0" Class="mud-background-gray rounded pa-3 mb-3">
                <MudText Typo="Typo.caption" Class="mb-2">
                    @(_scadenzaInModifica is null ? "Nuova scadenza" : "Modifica scadenza")
                </MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4">
                        <MudDatePicker Label="Data scadenza *"
                                       Date="_fData"
                                       DateChanged="@(d => _fData = d)"
                                       DateFormat="dd/MM/yyyy"
                                       Culture="_itCulture"
                                       Editable="true"
                                       Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="decimal"
                                         Label="Importo € *"
                                         @bind-Value="_fImporto"
                                         Min="0.01m"
                                         Max="_maxImportoForm"
                                         Format="N2"
                                         Culture="_itCulture"
                                         Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField Label="Nota (opzionale)"
                                      @bind-Value="_fNota"
                                      MaxLength="200"
                                      Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
                @if (!string.IsNullOrWhiteSpace(_erroreForm))
                {
                    <MudText Color="Color.Error" Typo="Typo.caption" Class="mt-1">@_erroreForm</MudText>
                }
                <div class="d-flex justify-end gap-2 mt-2">
                    @if (_scadenzaInModifica is not null)
                    {
                        <MudButton Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Cancel"
                                   OnClick="ResetForm">
                            Annulla
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@(_scadenzaInModifica is null ? Icons.Material.Filled.Add : Icons.Material.Filled.Save)"
                               Disabled="_salvataggio"
                               OnClick="SalvaScadenzaAsync">
                        @(_scadenzaInModifica is null ? "Aggiungi" : "Salva")
                    </MudButton>
                </div>
            </MudPaper>
        }

        @* Importo interamente schedulato: la maschera può essere chiusa. *@
        @if (!Dettaglio.HasFattura && _bilanciato && _scadenzaInModifica is null)
        {
            <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                Importo interamente schedulato (@Dettaglio.Importo.ToString("N2", _itCulture) €).
                Puoi chiudere la maschera.
            </MudAlert>
        }

        @* Griglia scadenze *@
        @if (_caricamento)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_scadenze.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="text-center py-4">
                Nessuna scadenza inserita.
            </MudText>
        }
        else
        {
            <MudTable Items="_scadenze" Dense="true" Striped="true" Hover="true">
                <HeaderContent>
                    <MudTh>Data scadenza</MudTh>
                    <MudTh Style="text-align:right;">Importo €</MudTh>
                    <MudTh>Nota</MudTh>
                    @if (!Dettaglio.HasFattura)
                    {
                        <MudTh Style="width:80px;"></MudTh>
                    }
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        @if (context.IsEvasa)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small"
                                     Color="Color.Warning" Class="mr-1" />
                        }
                        @context.DataScadenza.ToString("dd/MM/yyyy")
                    </MudTd>
                    <MudTd Style="text-align:right;">@context.Importo.ToString("N2", _itCulture)</MudTd>
                    <MudTd>
                        @context.Nota
                        @if (context.IsEvasa)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning" Class="d-block">
                                Evasa nell'avviso del @(context.AvvisoDataEvasione?.ToString("dd/MM/yyyy"))@(!string.IsNullOrWhiteSpace(context.AvvisoOggettoEvasione) ? $" — {context.AvvisoOggettoEvasione}" : "")
                            </MudText>
                        }
                    </MudTd>
                    @if (!Dettaglio.HasFattura)
                    {
                        <MudTd>
                            @if (context.IsEvasa)
                            {
                                @* Rata congelata: si sblocca solo annullando l'avviso che la consuma. *@
                                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Default" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               OnClick="@(() => AvviaModifica(context))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => EliminaAsync(context))" />
                            }
                        </MudTd>
                    }
                </RowTemplate>
            </MudTable>
        }
    </DialogContent>
    <DialogActions>
        @* Chiusura sempre NON distruttiva: le scadenze sono già persistite a ogni azione
           e restano salvate anche se la ripartizione è parziale. Una somma < importo del
           dettaglio è uno stato ammesso (il residuo è gestito a valle in fase di avviso):
           in uscita non si cancella nulla, così non si perde il pregresso. *@
        @if (!Dettaglio.HasFattura && _sbilanciato)
        {
            <MudText Typo="Typo.caption" Color="Color.Warning" Class="mr-2 my-2">
                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" />
                Dettaglio parzialmente schedulato — residuo @_residuo.ToString("N2", _itCulture) €.
                Le scadenze restano salvate.
            </MudText>
        }
        <MudButton OnClick="Chiudi" Variant="Variant.Text">Chiudi</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public AttivitaDettaglio Dettaglio { get; set; } = null!;

    private static readonly CultureInfo _itCulture = new("it-IT");

    private IReadOnlyList<ScadenzaPagamento> _scadenze = [];
    private bool     _caricamento;
    private bool     _salvataggio;
    private string   _erroreForm  = string.Empty;

    // Form fields
    private DateTime? _fData;
    private decimal   _fImporto;
    private string    _fNota = string.Empty;

    private ScadenzaPagamento? _scadenzaInModifica;

    private decimal _totaleScadenzato => _scadenze.Sum(s => s.Importo);
    private decimal _residuo          => Dettaglio.Importo - _totaleScadenzato;
    // Bilanciato = la somma delle scadenze copre ESATTAMENTE l'importo del dettaglio.
    private bool    _bilanciato       => Math.Abs(_residuo) <= 0.005m;
    private bool    _sbilanciato      => !_bilanciato;
    // Importo massimo consentito nel form: in inserimento = residuo; in modifica =
    // residuo + l'importo della scadenza che si sta riscrivendo.
    private decimal _maxImportoForm   => _scadenzaInModifica is null
        ? _residuo
        : _residuo + _scadenzaInModifica.Importo;

    protected override async Task OnInitializedAsync()
    {
        await CaricaAsync();
        ResetForm();
    }

    private async Task CaricaAsync()
    {
        _caricamento = true;
        try
        {
            _scadenze = await ScadenzaPagamentoManager.ElencoPerDettaglioAsync(Dettaglio.IdAttivitaDettaglio);
        }
        finally
        {
            _caricamento = false;
        }
    }

    private void AvviaModifica(ScadenzaPagamento s)
    {
        _scadenzaInModifica = s;
        _fData    = s.DataScadenza.ToDateTime(TimeOnly.MinValue);
        _fImporto = s.Importo;
        _fNota    = s.Nota ?? string.Empty;
        _erroreForm = string.Empty;
    }

    private void ResetForm()
    {
        _scadenzaInModifica = null;
        // Default per una nuova scadenza: data = termine previsto del dettaglio,
        // importo = residuo ancora da schedulare (sulla PRIMA scadenza coincide
        // con l'intero importo del dettaglio).
        _fData    = Dettaglio.TerminePrevisto?.ToDateTime(TimeOnly.MinValue);
        _fImporto = _residuo > 0m ? _residuo : 0m;
        _fNota    = string.Empty;
        _erroreForm = string.Empty;
    }

    private async Task SalvaScadenzaAsync()
    {
        _erroreForm = string.Empty;

        if (!_fData.HasValue)
        {
            _erroreForm = "La data di scadenza è obbligatoria.";
            return;
        }
        if (_fImporto <= 0)
        {
            _erroreForm = "L'importo deve essere maggiore di zero.";
            return;
        }
        // Cap: la somma delle scadenze non può eccedere l'importo del dettaglio.
        if (_fImporto > _maxImportoForm + 0.005m)
        {
            _erroreForm = $"L'importo non può superare il residuo disponibile " +
                          $"({_maxImportoForm.ToString("N2", _itCulture)} €): la somma delle scadenze " +
                          $"non può eccedere l'importo del dettaglio ({Dettaglio.Importo.ToString("N2", _itCulture)} €).";
            return;
        }

        _salvataggio = true;
        try
        {
            if (_scadenzaInModifica is null)
            {
                // Nuova scadenza
                var nuova = new ScadenzaPagamento
                {
                    IdAttivitaDettaglio = Dettaglio.IdAttivitaDettaglio,
                    DataScadenza        = DateOnly.FromDateTime(_fData.Value),
                    Importo             = _fImporto,
                    Nota                = string.IsNullOrWhiteSpace(_fNota) ? null : _fNota.Trim(),
                };
                await ScadenzaPagamentoManager.CreaAsync(nuova);
                Snackbar.Add("Scadenza aggiunta.", Severity.Success);
            }
            else
            {
                // Modifica scadenza esistente
                var aggiornata = new ScadenzaPagamento
                {
                    IdScadenza          = _scadenzaInModifica.IdScadenza,
                    IdAttivitaDettaglio = _scadenzaInModifica.IdAttivitaDettaglio,
                    DataScadenza        = DateOnly.FromDateTime(_fData.Value),
                    Importo             = _fImporto,
                    Nota                = string.IsNullOrWhiteSpace(_fNota) ? null : _fNota.Trim(),
                    IsAttivo            = true,
                };
                await ScadenzaPagamentoManager.AggiornaAsync(aggiornata);
                Snackbar.Add("Scadenza aggiornata.", Severity.Success);
            }

            await CaricaAsync();
            ResetForm();
        }
        catch (ScadenzaPagamentoInvalidaException ex)
        {
            _erroreForm = ex.Message;
        }
        catch (Exception)
        {
            _erroreForm = "Errore durante il salvataggio. Riprovare.";
        }
        finally
        {
            _salvataggio = false;
        }
    }

    private async Task EliminaAsync(ScadenzaPagamento s)
    {
        try
        {
            await ScadenzaPagamentoManager.EliminaAsync(s.IdScadenza);
            Snackbar.Add("Scadenza eliminata.", Severity.Success);
            await CaricaAsync();
            ResetForm();
        }
        catch (ScadenzaPagamentoInvalidaException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch (Exception)
        {
            Snackbar.Add("Errore durante l'eliminazione.", Severity.Error);
        }
    }

    private void Chiudi() => MudDialog.Close();
}
