@*
    Dialog "Reimposta password": l'admin imposta direttamente una nuova
    password per un utente (T3). Il reset self-service via email/token è T4.
*@
@using ICMFatturazioni.Web.Managers.Interfaces
@inject IUtenteManager UtenteManager
@inject ICMFatturazioni.Web.Diagnostics.IErrorLogger ErrorLogger

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">
            Imposta una nuova password per <b>@Username</b>.
        </MudText>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_password"
                          Label="Nuova password *"
                          InputType="InputType.Password"
                          Required="true"
                          RequiredError="Password obbligatoria"
                          Validation="@(new Func<string, string?>(Valida))"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          Class="campo-obbligatorio" />
        </MudForm>
        @if (!string.IsNullOrEmpty(_errore))
        {
            <MudAlert Severity="MudBlazor.Severity.Error" Class="mt-3" Variant="Variant.Outlined">@_errore</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="@(() => MudDialog.Cancel())" Ripple="false">Annulla</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="Salva" Disabled="@(!_isValid || _salvataggio)" Ripple="false">
            Imposta
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid IdUtente { get; set; }
    [Parameter] public string Username { get; set; } = string.Empty;
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm _form = default!;
    private string _password = string.Empty;
    private bool _isValid;
    private bool _salvataggio;
    private string? _errore;

    private static string? Valida(string? p)
        => string.IsNullOrEmpty(p) || p.Length >= 8 ? null : "Almeno 8 caratteri";

    private async Task Salva()
    {
        _errore = null;
        await _form.ValidateAsync();
        if (!_isValid) return;
        _salvataggio = true;
        try
        {
            await UtenteManager.ImpostaPasswordAsync(IdUtente, _password);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (ArgumentException ex)
        {
            _errore = ex.Message;
        }
        catch (Exception ex)
        {
            _errore = "Errore durante l'impostazione della password.";
            await ErrorLogger.LogAsync(ex, contesto: "ImpostaPasswordDialog.Salva");
        }
        finally
        {
            _salvataggio = false;
        }
    }
}
