@* Dialog di creazione/modifica di un tipo attività consulente (Modulo Attività Consulenti). *@

@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Managers
@using ICMFatturazioni.Web.Managers.Interfaces
@inject ITipoAttivitaConsulenteManager TipoAttivitaConsulenteManager
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isModifica ? "Modifica tipo attività consulente" : "Aggiungi tipo attività consulente")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_descrizione"
                              Label="Descrizione"
                              Required="true" RequiredError="Campo obbligatorio."
                              HelperText="Es. CALCOLI STRUTTURALI"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="100" Counter="100"
                              Immediate="true"
                              Class="campo-obbligatorio" />
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Annulla" Ripple="false">Annulla</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Ripple="false" OnClick="Salva" Disabled="!_formValido">
            Salva
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public TipoAttivitaConsulente? Iniziale { get; set; }

    private MudForm _form = default!;
    private bool _formValido;
    private bool _isModifica;

    private string _descrizione = string.Empty;

    protected override void OnParametersSet()
    {
        _isModifica = Iniziale is not null;
        if (Iniziale is not null)
            _descrizione = Iniziale.Descrizione;
    }

    private void Annulla() => MudDialog.Cancel();

    private async Task Salva()
    {
        await _form.Validate();
        if (!_formValido) return;

        var entity = new TipoAttivitaConsulente
        {
            IdTipoAttivitaConsulente = Iniziale?.IdTipoAttivitaConsulente ?? Guid.Empty,
            Descrizione              = _descrizione,
        };

        try
        {
            if (_isModifica)
                await TipoAttivitaConsulenteManager.AggiornaAsync(entity);
            else
                await TipoAttivitaConsulenteManager.CreaAsync(entity);

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (TipoAttivitaConsulenteInvalidoException ex)
        {
            Snackbar.Add(ex.Message, MudBlazor.Severity.Warning);
        }
    }
}
