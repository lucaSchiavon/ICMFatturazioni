@*
    Dialog Anagrafica — usato sia per "Aggiungi" che per "Modifica".

    Decisioni di design:
    - Un solo componente per i due flussi: il parametro Iniziale
      discrimina (null → create, valorizzato → edit). Riduce codice
      duplicato e garantisce comportamento omogeneo per le validazioni.
    - Layout a 2 colonne su desktop (≥ Sm), 1 colonna su mobile.
    - Tutti i campi obbligatori sono evidenziati come Required="true"
      sul MudTextField/MudSelect, in modo che il MudForm imposti
      l'IsValid quando vengono compilati.
    - Salva è abilitato solo se il form è valido (CLAUDE.md "Pulsante
      Salva contestuale"). Non viene nascosto perché MudBlazor non
      supporta nativamente la "comparsa" alla validità — disabilitarlo
      con tooltip è preferibile per evitare layout-shift.
    - Paese e Provincia sono dropdown da fatt.Paesi/fatt.Province via
      ILookupRepository: l'utente non può inserire valori inesistenti.
    - Tema default Paese = IT (decisione applicativa D14).
*@

@using ICMFatturazioni.Web.Entities
@using ICMFatturazioni.Web.Managers
@using ICMFatturazioni.Web.Models
@using ICMFatturazioni.Web.Repositories.Interfaces
@inject IAnagraficaManager AnagraficaManager
@inject ICodicePagamentoManager CodicePagamentoManager
@inject IBancaAppoggioManager BancaAppoggioManager
@inject ICodiceIVAManager CodiceIVAManager
@inject ILookupRepository LookupRepository
@inject IDialogService DialogService
@inject ICMFatturazioni.Web.Managers.Interfaces.ILogManager LogManager

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_model" @bind-IsValid="_isValid">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudSelect T="TipoAnagrafica"
                               Label="Tipologia *"
                               Value="_model.TipoAnagrafica"
                               ValueChanged="OnTipoAnagraficaChanged"
                               Required="true"
                               RequiredError="Tipologia obbligatoria"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="campo-obbligatorio">
                        <MudSelectItem Value="TipoAnagrafica.Societa">Società</MudSelectItem>
                        <MudSelectItem Value="TipoAnagrafica.Privato">Privato</MudSelectItem>
                        <MudSelectItem Value="TipoAnagrafica.EntePubblico">Ente pubblico</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.RagioneSociale"
                                  Label="Ragione sociale *"
                                  Required="true"
                                  RequiredError="La ragione sociale è obbligatoria"
                                  MaxLength="200"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Class="campo-obbligatorio" />
                </MudItem>

                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="_model.Indirizzo"
                                  Label="Indirizzo"
                                  MaxLength="200"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="6" sm="4">
                    <MudTextField @bind-Value="_model.CAP"
                                  Label="CAP"
                                  MaxLength="10"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.City"
                                  Label="Città"
                                  MaxLength="100"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudSelect T="string"
                               Label="Provincia"
                               @bind-Value="_model.Provincia"
                               Clearable="true"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense">
                        @foreach (var p in _province)
                        {
                            <MudSelectItem Value="@p.Codice">@p.Codice — @p.Descrizione</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudSelect T="string"
                               Label="Paese *"
                               @bind-Value="_model.SiglaPaese"
                               Required="true"
                               RequiredError="Paese obbligatorio"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="campo-obbligatorio">
                        @foreach (var p in _paesi)
                        {
                            <MudSelectItem Value="@p.Codice">@p.Codice — @p.Descrizione</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.PIVA"
                                  Label="P.IVA / Codice fiscale"
                                  MaxLength="20"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Contatto"
                                  Label="Contatto"
                                  MaxLength="200"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Email"
                                  Label="Email"
                                  InputType="InputType.Email"
                                  MaxLength="200"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Telefono"
                                  Label="Telefono"
                                  MaxLength="40"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Cellulare"
                                  Label="Cellulare"
                                  MaxLength="40"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Fax"
                                  Label="Fax"
                                  MaxLength="40"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Dati amministrativi</MudText>
                </MudItem>

                @* Pagamento: la sua scelta determina quali banche sono
                   selezionabili (flag Azienda/Cliente del tipo di pagamento). *@
                <MudItem xs="12" sm="6">
                    <div class="d-flex align-center gap-2">
                        <MudSelect T="Guid?"
                                   Label="Pagamento"
                                   Value="_model.IdPag"
                                   ValueChanged="OnPagamentoChangedAsync"
                                   Clearable="true"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="flex-grow-1">
                            @foreach (var p in _pagamenti)
                            {
                                <MudSelectItem T="Guid?" Value="@p.IdCodicePagamento">@p.DescrPag</MudSelectItem>
                            }
                        </MudSelect>
                        <MudTooltip Text="Nuovo codice di pagamento">
                            <MudIconButton Icon="@Icons.Material.Filled.Add"
                                           Variant="Variant.Outlined"
                                           Ripple="false"
                                           OnClick="AggiungiPagamentoAsync" />
                        </MudTooltip>
                    </div>
                </MudItem>

                @* Codice IVA *@
                <MudItem xs="12" sm="6">
                    <div class="d-flex align-center gap-2">
                        <MudSelect T="Guid?"
                                   Label="Codice IVA"
                                   @bind-Value="_model.IdCodiciIVA"
                                   Clearable="true"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="flex-grow-1">
                            @foreach (var iva in _codiciIva)
                            {
                                <MudSelectItem T="Guid?" Value="@iva.IdCodiceIVA">@iva.Descrizione</MudSelectItem>
                            }
                        </MudSelect>
                        <MudTooltip Text="Nuovo codice IVA">
                            <MudIconButton Icon="@Icons.Material.Filled.Add"
                                           Variant="Variant.Outlined"
                                           Ripple="false"
                                           OnClick="AggiungiCodiceIvaAsync" />
                        </MudTooltip>
                    </div>
                </MudItem>

                @* Banca di appoggio: dipende dal pagamento. Disabilitata finché
                   non si sceglie un pagamento. Per i pagamenti "di tipo cliente"
                   il pulsante "Inserisci banca del cliente" si attiva solo dopo
                   il primo salvataggio (serve l'IdAnagrafica per la banca). *@
                <MudItem xs="12">
                    <div class="d-flex align-center gap-2 flex-wrap">
                        <MudSelect T="Guid?"
                                   Label="Banca di appoggio"
                                   @bind-Value="_model.IdBancaAppoggio"
                                   Clearable="true"
                                   Disabled="@(!PagamentoSelezionato)"
                                   HelperText="@HelperBanca()"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="flex-grow-1">
                            @foreach (var b in _banche)
                            {
                                <MudSelectItem T="Guid?" Value="@b.IdBancaAppoggio">@DescriviBanca(b)</MudSelectItem>
                            }
                        </MudSelect>
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Ripple="false"
                                   Disabled="@(!PuoAggiungereBanca)"
                                   OnClick="AggiungiBancaAsync">
                            @EtichettaAggiungiBanca()
                        </MudButton>
                    </div>

                    @* Avviso ben visibile per il caso "pagamento di tipo cliente"
                       prima del primo salvataggio: la banca del cliente è
                       inseribile solo dopo aver creato l'anagrafica. *@
                    @if (FlagPagamentoCorrente() == FlagBanca.Cliente && _idCorrente is null)
                    {
                        <MudAlert Severity="MudBlazor.Severity.Warning"
                                  Variant="Variant.Filled"
                                  Icon="@Icons.Material.Filled.Save"
                                  Class="mt-2">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
                                Salva prima l'anagrafica per inserire la banca del cliente
                            </MudText>
                        </MudAlert>
                    }
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Fatturazione elettronica</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.CodiceDestinatario"
                                  Label="Codice destinatario SDI"
                                  MaxLength="10"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  HelperText="7 caratteri assegnati dal cliente, in alternativa alla PEC" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.PECFatturaElettronica"
                                  Label="PEC fattura elettronica"
                                  InputType="InputType.Email"
                                  MaxLength="200"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Dati fiscali</MudText>
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox T="bool" @bind-Value="_model.SostitutoImposta"
                                 Label="Sostituto d'imposta (applica ritenuta d'acconto in avviso)"
                                 Dense="true" Color="Color.Primary" />
                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                        Proposto in base alla tipologia (Società/Ente = sì, Privato = no); modificabile per i casi particolari (es. forfettari).
                    </MudText>
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrEmpty(_infoMessaggio))
            {
                <MudAlert Severity="MudBlazor.Severity.Info" Class="mt-3" Variant="Variant.Outlined">
                    @_infoMessaggio
                </MudAlert>
            }

            @if (!string.IsNullOrEmpty(_erroreServer))
            {
                <MudAlert Severity="MudBlazor.Severity.Error" Class="mt-3" Variant="Variant.Outlined">
                    @_erroreServer
                </MudAlert>
            }
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text"
                   OnClick="Annulla"
                   Ripple="false">
            Annulla
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Salva"
                   Disabled="@(!_isValid || _salvataggio)"
                   Ripple="false">
            @if (_salvataggio)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            Salva
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    /// <summary>
    /// Anagrafica iniziale: null = modalità Aggiungi, valorizzato = Modifica.
    /// La dialog non muta direttamente il parametro: lavora su una copia
    /// locale (<see cref="_model"/>) per non sporcare il record originale
    /// in caso di Annulla.
    /// </summary>
    [Parameter] public Anagrafica? Iniziale { get; set; }

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm _form = default!;
    private FormModel _model = new();
    private bool _isValid;
    private bool _salvataggio;
    private string? _erroreServer;

    private IReadOnlyList<LookupItem> _paesi = Array.Empty<LookupItem>();
    private IReadOnlyList<LookupItem> _province = Array.Empty<LookupItem>();

    // Id dell'anagrafica se già persistita: in modifica = Iniziale.IdAnagrafica;
    // in creazione resta null finché non avviene il primo salvataggio (dopo il
    // quale il dialog passa a modalità modifica senza chiudersi — flusso "salva
    // fluido" per poter agganciare la banca del cliente).
    private Guid? _idCorrente;
    private string? _infoMessaggio;

    private IReadOnlyList<CodicePagamentoRiga> _pagamenti = Array.Empty<CodicePagamentoRiga>();
    private IReadOnlyList<BancaAppoggioRiga> _banche = Array.Empty<BancaAppoggioRiga>();
    private IReadOnlyList<CodiceIVA> _codiciIva = Array.Empty<CodiceIVA>();

    private bool IsModifica => Iniziale is not null;

    protected override async Task OnInitializedAsync()
    {
        _idCorrente = Iniziale?.IdAnagrafica;

        // Lookup + cataloghi amministrativi in parallelo: riduce il time-to-paint.
        var paesiTask = LookupRepository.GetPaesiAsync();
        var provinceTask = LookupRepository.GetProvinceAsync();
        var pagamentiTask = CodicePagamentoManager.ElencoAsync();
        var ivaTask = CodiceIVAManager.ElencoAsync();
        await Task.WhenAll(paesiTask, provinceTask, pagamentiTask, ivaTask);
        _paesi = paesiTask.Result;
        _province = provinceTask.Result;
        _pagamenti = pagamentiTask.Result;
        _codiciIva = ivaTask.Result;

        if (Iniziale is not null)
        {
            _model = FormModel.FromEntity(Iniziale);
        }

        // In modifica, popola le banche coerenti col pagamento già associato
        // (la combo deve poter mostrare il valore corrente).
        await RicaricaBancheAsync();
    }

    private void Annulla() => MudDialog.Cancel();

    private async Task Salva()
    {
        _erroreServer = null;
        _infoMessaggio = null;
        await _form.ValidateAsync();
        if (!_isValid)
        {
            return;
        }

        _salvataggio = true;
        try
        {
            var entity = _model.ToEntity(_idCorrente ?? Guid.Empty);
            if (_idCorrente is null)
            {
                // Primo salvataggio (creazione): l'Id è assegnato dal manager.
                _idCorrente = await AnagraficaManager.CreaAsync(entity);

                // Flusso "salva fluido" del caso "pagamento di tipo cliente": se
                // non c'è ancora una banca associata, NON chiudo il dialog — passa
                // a modalità modifica così si può inserire la banca del cliente
                // (ora l'IdAnagrafica esiste a DB, niente ciclo FK).
                if (FlagPagamentoCorrente() == FlagBanca.Cliente && _model.IdBancaAppoggio is null)
                {
                    await RicaricaBancheAsync();
                    _infoMessaggio = "Anagrafica salvata. Ora puoi inserire la banca del cliente "
                                   + "con il pulsante qui sopra, poi premi di nuovo Salva.";
                    return; // resta aperto (il finally azzera comunque _salvataggio)
                }

                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                await AnagraficaManager.AggiornaAsync(entity);
                MudDialog.Close(DialogResult.Ok(true));
            }
        }
        catch (AnagraficaInvalidaException ex)
        {
            // Eccezione tipizzata di validazione → messaggio user-friendly già
            // pronto. NON si logga: è flusso previsto, non un errore (Regola 6).
            _erroreServer = ex.Message;
        }
        catch (Exception ex)
        {
            _erroreServer = "Errore durante il salvataggio. Riprovare o contattare l'amministratore.";
            await LogManager.LogErroreAsync(ex,
                "Salvataggio dell'anagrafica fallito per un errore imprevisto.",
                "AnagraficaFormDialog.Salva");
        }
        finally
        {
            _salvataggio = false;
        }
    }

    // ---- Dati amministrativi: stato derivato e azioni ----

    /// <summary>Flag banca (Azienda/Cliente) del pagamento selezionato, o null.</summary>
    private FlagBanca? FlagPagamentoCorrente()
        => _model.IdPag is Guid id
            ? _pagamenti.FirstOrDefault(p => p.IdCodicePagamento == id)?.FlagBanca
            : null;

    private bool PagamentoSelezionato => FlagPagamentoCorrente() is not null;

    /// <summary>
    /// La banca si può aggiungere "al volo" se: pagamento Azienda (le banche
    /// aziendali esistono a prescindere dal cliente) oppure pagamento Cliente ma
    /// solo dopo il primo salvataggio (serve l'IdAnagrafica per la FK).
    /// </summary>
    private bool PuoAggiungereBanca
    {
        get
        {
            var f = FlagPagamentoCorrente();
            if (f is null) return false;
            return f == FlagBanca.Azienda || _idCorrente is not null;
        }
    }

    private string EtichettaAggiungiBanca()
        => FlagPagamentoCorrente() == FlagBanca.Cliente ? "Inserisci banca del cliente" : "Nuova banca aziendale";

    private string? HelperBanca()
        // Il caso "pagamento cliente non ancora salvato" è ora segnalato da un
        // MudAlert ben visibile sotto la combo: qui resta solo il caso neutro.
        => FlagPagamentoCorrente() is null ? "Scegli prima il pagamento" : null;

    private static string DescriviBanca(BancaAppoggioRiga b)
        => string.IsNullOrWhiteSpace(b.AgenziaNome) ? b.BancaNome : $"{b.BancaNome} — {b.AgenziaNome}";

    // Cambio tipologia: in INSERIMENTO ricalcola il default del flag sostituto
    // d'imposta (Privato → no, Società/Ente → sì); resta sovrascrivibile. In
    // MODIFICA non si tocca il valore già impostato sul cliente.
    private void OnTipoAnagraficaChanged(TipoAnagrafica nuovo)
    {
        _model.TipoAnagrafica = nuovo;
        if (_idCorrente is null)
            _model.SostitutoImposta = nuovo != TipoAnagrafica.Privato;
    }

    private async Task OnPagamentoChangedAsync(Guid? value)
    {
        _model.IdPag = value;
        await RicaricaBancheAsync();
        // Cambiando la natura del pagamento la banca scelta può non essere più
        // coerente: la azzeriamo se non rientra tra le selezionabili.
        if (_model.IdBancaAppoggio is Guid idB && !_banche.Any(b => b.IdBancaAppoggio == idB))
        {
            _model.IdBancaAppoggio = null;
        }
    }

    /// <summary>Ricarica le banche selezionabili in base al flag del pagamento.</summary>
    private async Task RicaricaBancheAsync()
    {
        _banche = FlagPagamentoCorrente() switch
        {
            FlagBanca.Azienda => await BancaAppoggioManager.SelezionabiliAsync(null, bancheAzienda: true),
            FlagBanca.Cliente when _idCorrente is not null
                => await BancaAppoggioManager.SelezionabiliAsync(_idCorrente, bancheAzienda: false),
            _ => Array.Empty<BancaAppoggioRiga>(),
        };
    }

    private async Task AggiungiPagamentoAsync()
    {
        var dialog = await DialogService.ShowAsync<CodicePagamentoFormDialog>("Nuovo codice di pagamento");
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            _pagamenti = await CodicePagamentoManager.ElencoAsync();
        }
    }

    private async Task AggiungiCodiceIvaAsync()
    {
        var dialog = await DialogService.ShowAsync<CodiceIVAFormDialog>("Nuovo codice IVA");
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            _codiciIva = await CodiceIVAManager.ElencoAsync();
        }
    }

    private async Task AggiungiBancaAsync()
    {
        var parametri = new DialogParameters();
        if (FlagPagamentoCorrente() == FlagBanca.Cliente)
        {
            // Apre il dialog banca bloccato sul cliente corrente (già persistito).
            parametri.Add(nameof(BancaAppoggioFormDialog.ForzaCliente), true);
            parametri.Add(nameof(BancaAppoggioFormDialog.IdClientePreimpostato), _idCorrente);
        }
        else
        {
            // Pagamento di tipo azienda: il dialog banca parte bloccato su Azienda.
            parametri.Add(nameof(BancaAppoggioFormDialog.ForzaAzienda), true);
        }

        // Memorizza gli id presenti per individuare e preselezionare la nuova banca.
        var idPrima = _banche.Select(b => b.IdBancaAppoggio).ToHashSet();

        var dialog = await DialogService.ShowAsync<BancaAppoggioFormDialog>("Banca di appoggio", parametri);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await RicaricaBancheAsync();
            var nuova = _banche.FirstOrDefault(b => !idPrima.Contains(b.IdBancaAppoggio));
            if (nuova is not null)
            {
                _model.IdBancaAppoggio = nuova.IdBancaAppoggio;
            }
        }
    }

    /// <summary>
    /// View-model del form: campi tutti mutabili (richiesti da @bind-Value),
    /// mentre l'Entity è immutable. Conversioni esplicite alle estremità.
    /// </summary>
    private sealed class FormModel
    {
        public TipoAnagrafica TipoAnagrafica { get; set; } = TipoAnagrafica.Societa;
        public string RagioneSociale { get; set; } = string.Empty;
        public string? Indirizzo { get; set; }
        public string? CAP { get; set; }
        public string? City { get; set; }
        public string? Provincia { get; set; }
        public string SiglaPaese { get; set; } = "IT";
        public string? Telefono { get; set; }
        public string? Cellulare { get; set; }
        public string? Fax { get; set; }
        public string? Email { get; set; }
        public string? PIVA { get; set; }
        public string? Contatto { get; set; }
        public string? CodiceDestinatario { get; set; }
        public string? PECFatturaElettronica { get; set; }

        // Sostituto d'imposta: pilota la ritenuta d'acconto in avviso (cap. 7).
        // Default true (impresa); ricalcolato dal tipo in inserimento.
        public bool SostitutoImposta { get; set; } = true;

        // Riferimenti amministrativi (Tappa 6). Nullable: l'anagrafica può non
        // avere ancora pagamento/banca/codice IVA associati.
        public Guid? IdPag { get; set; }
        public Guid? IdBancaAppoggio { get; set; }
        public Guid? IdCodiciIVA { get; set; }

        public static FormModel FromEntity(Anagrafica a) => new()
        {
            TipoAnagrafica        = a.TipoAnagrafica,
            RagioneSociale        = a.RagioneSociale,
            Indirizzo             = a.Indirizzo,
            CAP                   = a.CAP,
            City                  = a.City,
            Provincia             = a.Provincia,
            SiglaPaese            = a.SiglaPaese,
            Telefono              = a.Telefono,
            Cellulare             = a.Cellulare,
            Fax                   = a.Fax,
            Email                 = a.Email,
            PIVA                  = a.PIVA,
            Contatto              = a.Contatto,
