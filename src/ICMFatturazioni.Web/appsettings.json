{
  // Configurazione di BASE (committata in git). Contiene i default e i SEGNAPOSTO
  // vuoti dei secret. I valori reali NON vanno mai qui: in sviluppo si usano gli
  // User Secrets, in produzione le variabili d'ambiente di sistema.

  // DB UNIFICATO: ICMFatturazioni e ICMVerbali condividono ICMVerbaliDb (lo schema
  // "fatt" e' stato fuso in ICMVerbali, vedi i suoi CLAUDE.md/Migrations). Il vecchio
  // DB "ICMFatturazioni" non e' piu' usato. La stringa e' valorizzata dall'ambiente
  // (appsettings.{Environment}.json). Vuota qui.
  "ConnectionStrings": {
    "Default": ""
  },

  "UtenteToken": {
    "AttivazioneOreDefault": 168,
    "ResetOreDefault": 1
  },

  // Provider di invio email: "Graph" | "Smtp" | "Log" | "Auto".
  // "Auto" (default): Graph se la sezione "Graph" e' configurata, altrimenti SMTP
  // se "Smtp:Host" e' presente, altrimenti Log (sviluppo, link nei log).
  // In produzione ISO 27001 impostare "Graph" (canale conforme via Entra ID);
  // l'SMTP resta come fallback selezionabile per dev/demo/ambienti non-ISO.
  "Email": {
    "Provider": "Auto"
  },

  "Smtp": {
    "Host": "smtp-relay.brevo.com",
    "Port": 587,
    "User": "9d8639001@smtp-brevo.com",
    "FromAddress": "job@lucaschiavon.eu",
    "FromName": "ICM Fatturazioni",
    "UseStartTls": true,
    // Segnaposto: il valore reale va SOLO in user-secrets (dev) o nella variabile
    // d'ambiente Smtp__Password (prod). MAI la chiave vera in questo file.
    // dotnet user-secrets set "Smtp:Password" "<SMTP-key-Brevo>" --project src/ICMFatturazioni.Web
    "Password": ""
  },

  // Microsoft Graph (App Registration "ICMWEBAPP" su Entra ID, mirror di ICMVerbali).
  // ClientSecret NON qui: user-secrets in dev (Graph:ClientSecret) o variabile
  // d'ambiente di sistema Graph__ClientSecret in produzione (leggibile solo
  // dall'account App Pool IIS). SenderAddress vincolato dalla Application Access
  // Policy a noreply@icmsolutions.it.
  "Graph": {
    "TenantId": "1f57e406-df23-4105-b2b8-e8ec722e74ff",
    "ClientId": "eaca366b-721e-4d75-89e8-ab049e79daab",
    "SenderAddress": "noreply@icmsolutions.it",
    "FromName": "ICM Fatturazioni",
    // Segnaposto: valore reale SOLO in user-secrets (dev) o env var Graph__ClientSecret (prod).
    "ClientSecret": ""
  },

  "Admin": {
    "DefaultUsername": "admin",
    "DefaultEmail": "",
    // Segnaposto: valore reale via env var Admin__DefaultPassword (prod).
    "DefaultPassword": ""
  },

  // Superadmin: account di servizio dello sviluppatore (vede anche il log errori).
  // Password vuota = NON creato (caso normale in dev). In produzione impostala via
  // variabile d'ambiente Superadmin__Password (mai qui in chiaro).
  "Superadmin": {
    "Username": "superadmin",
    "Email": "",
    // Segnaposto: valore reale via env var Superadmin__Password (prod).
    "Password": ""
  },

  // Retention di fatt.Audit e sentinella sul tetto 10 GB di SQL Express (vedi
  // docs/audit-dimensionamento-sql-express.pdf). JobAbilitato=false lascia solo la
  // purga manuale in /admin/audit. SogliaAllarmeGb: superata, il job scrive un
  // Warning in fatt.Log (NON cancella).
  "AuditRetention": {
    "JobAbilitato": true,
    "MesiConservazione": 36,
    "IntervalloOreJob": 24,
    "SogliaAllarmeGb": 8
  },

  // Fase D1: cartella unica dove vengono depositati i tracciati XML FatturaPA generati
  // (l'invio allo SdI e' manuale, fuori dall'app). I codici fiscali del cedente
  // (cassa/ritenuta) NON stanno qui: sono sul profilo fiscale di fatt.Azienda
  // (TipoCassaFe/TipoRitenutaFe/CausalePagamentoRitenutaFe), perche' dipendono dal
  // tipo di cedente. Il path reale (dipende dalla macchina) sta in
  // appsettings.{Environment}.json. Vuoto qui.
  "FatturaPA": {
    "CartellaOutput": ""
  },

  // Consultazione verbali (dominio ICMVerbali). BasePath = cartella "uploads" di
  // ICMVerbali (quella che contiene la sottocartella "report" con i PDF firmati).
  // Sola lettura: l'App Pool di ICMFatturazioni deve avere permesso di lettura su
  // questa cartella (icacls ... /grant "IIS AppPool\ICMFatturazioni:(OI)(CI)(RX)").
  // In dev il valore reale sta in appsettings.Development.json. Vuoto = nessun
  // verbale scaricabile.
  "VerbaliReport": {
    "BasePath": ""
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
